      "what_makes_different_v2_rRVmVL": {
        "type": "what-makes-different-v2",
        "name": "What Makes Different V2",
        "settings": {
          "heading": "<p>So, why does Rejuvia <em>actually work</em>?</p>",
          "subtitle": "Most sleep aids take 45–60 minutes to kick in — if they work at all. Rejuvia's sublingual formula absorbs directly under your tongue and into your bloodstream in minutes.",
          "image": "shopify://shop_images/IMG.png",
          "card_title": "Why oral sprays work better",
          "card_text": "<p>The tissue under your tongue is packed with blood vessels. Spray Rejuvia there and it bypasses your digestive system entirely — the same process that destroys up to 80% of every pill and gummy you've ever taken.</p><p><strong>More ingredients reach your body intact. You feel it faster.</strong></p>"
        }
      },
      "use_in_just_v2_JAWTbF": {
        "type": "use-in-just-v2",
        "blocks": {
          "step_FCja3B": {
            "type": "step",
            "settings": {
              "title": "Step 1: Spray",
              "description": "Spray Rejuvia 6–8 times under your tongue or inside your cheek and let it sit for a few seconds before swallowing. This helps the ingredients absorb quickly so you can ease into sleep without waiting around.",
              "tip1_icon": "shopify://shop_images/Frame_1.svg",
              "tip1_label": "When to use",
              "tip1_text": "Brush your teeth first, then use Rejuvia. A clean mouth helps the spray absorb more effectively and keeps your routine simple and consistent. We suggest about 10-15 minutes before you head to bed.",
              "tip2_icon": "shopify://shop_images/Frame_2.svg",
              "tip2_label": "While traveling",
              "tip2_text": "Rejuvia is easy to travel with since it's TSA-approved and small enough to keep in your pocket or carry-on. Use it on planes, in hotel rooms, or anytime travel throws off your sleep schedule.",
              "image": "shopify://shop_images/Step_1.webp",
              "watermark": "shopify://shop_images/Frame.svg",
              "watermark_opacity": 60,
              "watermark_position": "top-right"
            }
          },
          "step_9t4thq": {
            "type": "step",
            "settings": {
              "title": "Step 2: Settle In",
              "description": "Once you take your sprays, get into bed and allow your mind to slow down. Avoid scrolling on your phone and let your body transition into rest.",
              "tip1_label": "Usage Tip",
              "tip1_text": "If you wake up during the night, it’s completely fine to use Rejuvia again. Most people take 1–2 sprays to help their mind settle back down without feeling groggy in the morning.",
              "tip2_label": "Finding Your Dose",
              "tip2_text": "Everyone responds differently to Rejuvia - that's normal. If 6 sprays feels perfect, stick with it. If you need 8 or even a couple more, that’s completely normal too.",
              "image": "shopify://shop_images/Step_2.webp",
              "watermark_opacity": 20,
              "watermark_position": "top-right"
            }
          },
          "step_cxFni4": {
            "type": "step",
            "settings": {
              "title": "Step 3: Store & Repeat",
              "description": "Store Rejuvia in the place where you naturally wind down at night. Most people keep it in their nightstand or right next to their bed so it becomes part of their rhythm without needing to think about it. The simpler you make it, the more consistent your results will be.",
              "tip1_label": "Building a Routine",
              "tip1_text": "Using Rejuvia at the same time each night helps your body recognize it as a signal to wind down. The more consistent your routine, the faster and deeper your sleep becomes over time. Think of it as building momentum that makes falling asleep feel automatic.",
              "tip2_label": "",
              "tip2_text": "",
              "image": "shopify://shop_images/Step_3.webp",
              "watermark_opacity": 20,
              "watermark_position": "top-right"
            }
          }
        },
