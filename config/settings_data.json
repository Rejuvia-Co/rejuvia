      "product_intro_v2_mcmr7P": {
        "type": "product-intro-v2",
        "blocks": {
          "tab_MBEqta": {
            "type": "tab",
            "settings": {
              "title": "Melatonin Gummies",
              "content": "<p>Gummies have to <strong>survive your entire digestive system</strong> before they can do anything. By the time they reach your bloodstream, up to 80% of the active ingredients are gone. You wait 45 minutes for a fraction of what you paid for.</p>",
              "image": "shopify://shop_images/melatonin_gummies.png",
              "badge_text": "80% lost to digestion",
              "badge_position_desktop": "bottom-right",
              "badge_position_mobile": "top-left"
            }
          },
          "tab_iLBcRm": {
            "type": "tab",
            "settings": {
              "title": "Sleeping Pills",
              "content": "<p>Sleep pills pack in high doses because they know <strong>most of it won't make it through your stomach</strong>. So you end up overdosing on ingredients to get a fraction of the effect. That's why you wake up groggy — your body's still processing what it couldn't absorb.</p>",
              "image": "shopify://shop_images/Generated_Image_March_18_2026_-_6_12PM_1.png",
              "badge_text": "Too Much, Poorly Absorbed",
              "badge_icon": "shopify://shop_images/Frame_3.svg",
              "badge_position_desktop": "top-right",
              "badge_position_mobile": "top-right"
            }
          },
          "tab_TfaWen": {
            "type": "tab",
            "settings": {
              "title": "The \"Natural\" Cycle",
              "content": "<p>Teas, tinctures, magnesium baths. The ingredients are real, but the doses are too small and the absorption is too slow to actually shift your sleep. You feel calmer for 20 minutes, then you're staring at the ceiling at 2 a.m. again.</p>",
              "image": "shopify://shop_images/Frame_1948755839.png",
              "badge_text": "Inconsistent Results",
              "badge_icon": "shopify://shop_images/Frame_4.svg",
              "badge_position_desktop": "bottom-left",
              "badge_position_mobile": "top-right"
            }
          }
        },
        "block_order": [
          "tab_MBEqta",
          "tab_iLBcRm",
          "tab_TfaWen"
        ],
        "name": "Product Intro V2",
        "settings": {
          "heading": "<p>You've tried it all and <em>nothing's ever stuck</em></p>",
          "description": "<p>Most sleep products lose the fight before they reach your bloodstream. Here's why.</p>",
          "accent_color": "#672666"
        }
      },
      "listicle_v2_N8G8nM": {
        "type": "listicle-v2",
        "name": "Listicle V2",
        "settings": {
          "heading": "<p>The real issue was never what you took, it was <em>how your body absorbed it</em></p>",
          "description": "<p>Every pill, capsule, and gummy has to survive your stomach — acid, enzymes, your liver — before anything reaches your bloodstream. Most of it doesn't make it.</p><p>A 5mg melatonin gummy might deliver 1mg to where it's actually needed.</p><p><strong>That's not a bad product. It's a bad delivery system.</strong></p>",
          "graph_image": "shopify://shop_images/Listicle.png"
        }
