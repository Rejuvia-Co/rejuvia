{{ 'article-new.css' | asset_url | stylesheet_tag }}

<div id="article">
  <article class="post clearfix">
    <div class="heading medium-down--direction-column align-items-start">
      <div class="bread-crumbs">
        <a href="{{ shop.url }}">
          Home
        </a>
        <span>/</span>
        <a href="{{ blog.url }}">
          Blog
        </a>
        <span>/</span>
        <span>{{- article.title -}}</span>
      </div>
      <div class="medium-down--one-whole">
        <div class="article-tags">
          {%- for tag in article.tags -%}
            <span class="article-tag">
              {{ tag }}
            </span>
          {%- endfor -%}
        </div>
        <h1 id="page-title" class="article-new__title custom_subtitle_font">{{ article.title }}</h1>
        <div class="author">
          {%- if article.metafields.custom.author_photo != blank -%}
            <img
              class="article-new__author--img"
              src="{{ article.metafields.custom.author_photo | file_url }}"
              alt="{{ article.metafields.custom.author_photo.alt | file_url }}">
          {% endif %}
          <div class="article-new__author--box">
            <span class="article-new__author--name">
              {{ article.author }}
            </span>
            <div class="article-new__author--date-box">
              <span class="article-new__author--date">
                {{ article.published_at | date: "%d %b %Y" }}
              </span>
              {%- if article.metafields.custom.minutes_to_read != blank -%}
                <span class="article-new__author--time">
                  {{ article.metafields.custom.minutes_to_read }} mins read
                </span>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
    {% if article.image %}
      <img
        class="featured-image"
        fetchpirority="high"
        loading="eager"
        src="{{ article.image | img_url: '1296x' }}"
        alt="{{ article.title }}" />
    {% endif %}
    <div class="article-content__box">
      {%- if article.metafields.custom.first_block_link_text != blank -%}
        <div class="table-content">
          <h5 class="table-content__title">
            Table of contents
          </h5>
          <div class="table-content__links">
            <a href="#block-1" class="table-content__link">
              <span>
                {% render 'icon-article-new-arrow' %}
              </span>
              {{- article.metafields.custom.first_block_link_text -}}
            </a>
  
            {%- if article.metafields.custom.second_block_link_text != blank -%}
              <a href="#block-2" class="table-content__link">
                <span>
                  {% render 'icon-article-new-arrow' %}
                </span>
                {{- article.metafields.custom.second_block_link_text -}}
              </a>
            {%- endif -%}
  
            {%- if article.metafields.custom.third_block_link_text != blank -%}
              <a href="#block-3" class="table-content__link">
                <span>
                  {% render 'icon-article-new-arrow' %}
                </span>
                {{- article.metafields.custom.third_block_link_text -}}
              </a>
            {%- endif -%}
  
            {%- if article.metafields.custom.fourth_block_link_text != blank -%}
              <a href="#block-4" class="table-content__link">
                <span>
                  {% render 'icon-article-new-arrow' %}
                </span>
                {{- article.metafields.custom.fourth_block_link_text -}}
              </a>
            {%- endif -%}
  
            {%- if article.metafields.custom.fifth_block_link_text != blank -%}
              <a href="#block-5" class="table-content__link">
                <span>
                  {% render 'icon-article-new-arrow' %}
                </span>
                {{- article.metafields.custom.fifth_block_link_text -}}
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
      <div class="content">
        {{ article.content }}
        {%- if article.metafields.custom.author_info != blank or article.metafields.custom.author_photo != blank -%}
          <div class="article-new__author--info-border">
            <div class="article-new__author--info">
              <h2 class="article-new__author--info-title">
                About the author
              </h2>
              <div class="article-new__author--info-box">
                {%- if article.metafields.custom.author_photo != blank -%}
                  <img
                    class="article-new__author--info-img"
                    src="{{ article.metafields.custom.author_photo | file_url }}"
                    alt="{{ article.metafields.custom.author_photo.alt | file_url }}">
                {%- endif -%}
                <span>{{ article.author }}</span>
              </div>
              {%- if article.metafields.custom.author_info != blank -%}
                <div class="article-new__author--info-content">
                  {{ article.metafields.custom.author_info | metafield_tag }}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
    {%- if blog.comments_enabled? -%}
      {%- include 'blog_comments' -%}
    {%- endif -%}
  </article>
</div>

<script>
  
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
  anchor.addEventListener('click', function(e) {
    e.preventDefault();
    const target = document.querySelector(this.getAttribute('href'));
    if (target) {
      target.scrollIntoView({
        behavior: 'smooth',
        block: 'center'
      });
    }
  });
  });
</script>

{% schema %}
  {
    "name": "Article New",
    "presets": [
      {
        "name": "Article New",
        "category": "Blog"
      }
    ],
    "settings": [],
    "blocks": []
  }
{% endschema %}