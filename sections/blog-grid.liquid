{{ 'sections-common.css' | asset_url | stylesheet_tag }}
{{ 'blog-grid.css' | asset_url | stylesheet_tag }}

<div class="blog">

  <div class="blog-grid__top">
    <div class="bread-crumbs">
      <a href="{{ shop.url }}">
        Home
      </a>
      <span>/</span>
      <span>
        {{- blog.title -}}
      </span>
    </div>

    <h1 class="blog-grid__top-title">
      {{- blog.title -}}
    </h1>
  </div>

  {%- paginate blog.articles by 8 -%}
    {%- if blog.tags.size > 0 -%}
      <div class="block-tabs">
        <div class="tabs-blog">
          <a href="{{ blog.url }}" class="{% unless current_tags %}active{% endunless %}">
            <span>All</span>
          </a>
          {% for tag in blog.tags %}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="{% if current_tags contains tag %}active{% endif %}">
              <span>{{ tag }}</span>
            </a>
          {% endfor %}
        </div>
      </div>
    {%- endif -%}
    <div class="articles-wrapper template-list">
      {%- for article in blog.articles -%}
        {%- render 'blog_item_grid', article: article, section: section -%}
      {%- endfor -%}
    </div>
    {%- render 'pagination-grid', paginate: paginate -%}
  {%- endpaginate -%}
</div>

{% schema %}
  {
    "name": "Blog Grid",
    "presets": [
      {
        "name": "Blog",
        "category": "Blog"
      }
    ],
    "settings": [
      {
        "type": "checkbox",
        "id": "show_tags",
        "label": "Show tags",
        "default": true
      }, {
        "type": "checkbox",
        "id": "show_text",
        "label": "Show text",
        "default": true
      }
    ]
  }
{% endschema %}
