<script>
    $(function(){

        /********* SPECIAL INSTRUCTIONS NOTE *********/
        var checkInstructions = function() {
            if($('#chk-instructions').is(':checked')) {
                $('#instructions-note').show();
            } else {
                $('#instructions-note').hide();
                $('#instructions-note').find('textarea').val("");
            }
        }
        $(document).on('click', '#chk-instructions',function(){
            checkInstructions();
        });
        checkInstructions();

        $(document).on('click', '#cart .remove-from-cart', function(){
            var $item = $(this).closest('.item');
            var $input = $item.find('input[type=number]');
            var lineIndex = $input.attr('id').replace('updates_', '');

            $('#loading-overlay').show();


            $.ajax({
                type: 'POST',
                url: '/cart/change.js',
                data: {
                    id: lineIndex,
                    quantity: 0
                },
                dataType: 'json'
            }).fail(function(xhr){
                console.log('error', xhr.responseText);
                $('#loading-overlay').hide();
            }).done(function(){
                if (typeof updateCartDesc === 'function') updateCartDesc();
                location.reload();
            });

            return false;
        });

        $(document).on('change', '#cart input[type=number]', function(){
            updateCart();
        });


        /********* UPDATE QUANTITY *********/
        function updateCart(){
            $('#loading-overlay').show();

            $.ajax({
                type: 'POST',
                url: '/cart/update.js',
                data: $('#cart .main-form').serialize(),
                dataType: 'json'
            }).fail(function(){console.log('error');}).done(function(){
                if (typeof updateCartDesc === 'function') updateCartDesc();
                $('#add-cart-overlay').fadeOut();
                location.reload();
            });
        }

        {%- if settings.allow_quick_view -%}
        /********* EDIT ITEM *********/
        $(document).on('click', '#cart .edit-item', function(){
            var url = $(this).data('url');
            var qty = $(this).data('qty');
            var variantId = $(this).data('variant');
            var itemKey = $(this).data('item-key');

            $('#loading-overlay').show();

            $.ajax({
                url: url,
                cache: false
            }).success(function(data){
                $('#loading-overlay').hide();
                Simplistic.openModal(data, 'quick-view');
                $('.quick-view [name=quantity]').val(qty).change();
                $('.quick-view #add-to-cart-button').text('SAVE CHANGES');
                $('.quick-view .initialized').on('productLoaded', function(){
                    $('.quick-view .initialized').data('productjs').setVariant(variantId);
                });

                $('.quick-view .add-to-cart-form').submit(function(){
                    $('#loading-overlay').show();
                    if(modal) modal.close();

                    var form = $(this);
                    $.ajax({
                        type: 'POST',
                        url: '/cart/change.js',
                        dataType: 'json',
                        data: {id: itemKey, quantity: 0}
                    }).success(function(){
                        addToCart(form, function(){
                            location.reload();
                        });
                    });
                    return false;
                });
            });
            return false;
        });
        {%- endif -%}

    });
</script>


<div id="cart" class="cart-page{% if cart.items == empty %} cart-page--empty{% else %} cart-page--full{% endif %}">

    {%- if cart.items == empty -%}

        <div class="cart-page__hero">
            <div class="container">
                <h1 class="cart-page__title">Your Cart</h1>
            </div>
        </div>

        <div class="cart-page__body">
            <div class="container">
                <div class="cart-empty">
                    <div class="cart-empty__icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 40 40" fill="none">
                            <path d="M13.3327 36.6666C14.2532 36.6666 14.9993 35.9205 14.9993 35C14.9993 34.0795 14.2532 33.3333 13.3327 33.3333C12.4122 33.3333 11.666 34.0795 11.666 35C11.666 35.9205 12.4122 36.6666 13.3327 36.6666Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M31.6667 36.6666C32.5871 36.6666 33.3333 35.9205 33.3333 35C33.3333 34.0795 32.5871 33.3333 31.6667 33.3333C30.7462 33.3333 30 34.0795 30 35C30 35.9205 30.7462 36.6666 31.6667 36.6666Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M3.41602 3.41663H6.74935L11.1827 24.1166C11.3453 24.8747 11.7671 25.5524 12.3755 26.0331C12.9839 26.5137 13.7409 26.7672 14.516 26.75H30.816C31.5746 26.7487 32.3102 26.4888 32.9011 26.013C33.492 25.5373 33.9029 24.8742 34.066 24.1333L36.816 11.75H8.53268" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <div class="cart-empty__text">
                        <h2 class="cart-empty__title">Your Cart is Empty</h2>
                        <p class="cart-empty__subtitle">Start Shopping Rejuvia Today</p>
                    </div>
                    <a href="https://www.rejuvia.co/collections/more-products" class="cart-empty__btn">
                        Try Rejuvia
                    </a>
                </div>
            </div>
        </div>

    {%- else -%}

        <div class="cart-page__hero">
            <div class="container">
                <div class="cart-page__hero-inner">
                    <h1 class="cart-page__title">Your Cart</h1>
                    <div class="cart-page__hero-actions">
                        <a href="{{ routes.cart_clear_url }}" class="cart-page__action cart-page__action--clear">
                            Clear cart
                        </a>
                        <a href="https://www.rejuvia.co/collections/more-products" class="cart-page__action">
                            Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <form action="/cart" method="post" id="cartform" class="main-form main-form__cart--unempty">
            <div class="cart-page__body">
                <div class="container">
                    <div class="cart-grid">
                        <div class="cart-items items">
                            {%- for item in cart.items -%}
                                {%- assign unit_compare = item.variant.compare_at_price | default: 0 -%}
                                {%- assign unit_price = item.variant.price | default: 0 -%}
                                {%- assign qty = item.quantity | default: 1 -%}
                                {%- if unit_compare > 0 -%}
                                    {%- assign full_total = unit_compare | times: qty -%}
                                {%- else -%}
                                    {%- assign full_total = unit_price | times: qty -%}
                                {%- endif -%}
                                {%- assign sale_total = item.line_price | default: 0 -%}

                                <div class="cart-item item {{ item.product.handle }}">
                                    <a href="{{ item.product.url }}" class="cart-item__image">
                                        {%- if item.variant.image -%}
                                            {%- assign variantImg = item.variant.image -%}
                                        {%- else -%}
                                            {%- assign variantImg = item.product.featured_image -%}
                                        {%- endif -%}
                                        <img src="{{ variantImg | image_url: width: 240 }}" srcset="{{ variantImg | image_url: width: 240 }} 1x, {{ variantImg | image_url: width: 360 }} 1.5x, {{ variantImg | image_url: width: 480 }} 2x" width="120" height="120" loading="lazy" alt="{{ item.product.title | escape }}" />
                                    </a>

                                    <div class="cart-item__main">
                                        <div class="cart-item__info">
                                            <a href="{{ item.url }}" class="cart-item__title-link">
                                                {%- assign titlePart = item.product.title | split: ' - ' -%}
                                                <h3 class="cart-item__name">{{ titlePart[0] }}</h3>
                                            </a>
                                            {%- if item.variant.title != "Default Title" -%}
                                                <p class="cart-item__variant">{{ item.variant.title }}</p>
                                            {%- endif -%}

                                            {%- unless item.variant.title contains 'Default' -%}
                                                <div class="variants hide">
                                                    {%- for option in item.options_with_values -%}
                                                        <strong>{{ option.name }}</strong>: {{ option.value }}{%- unless forloop.last -%}<br/>{%- endunless -%}
                                                    {%- endfor -%}
                                                </div>
                                            {%- endunless -%}
                                        </div>

                                        <div class="cart-item__quantity quantity">
                                            <div class="quantity-box">
                                                <div class="flex">
                                                    <input type="button" value="" class="minus animation" aria-label="Decrease the quantity" />
                                                    <input type="number" step="1" class="cart-unempty__number" name="updates[]" id="updates_{{ item.id }}" value="{{ item.quantity }}" title="Qty" min="0" aria-label="Quantity" />
                                                    <input type="button" value="" class="plus animation" aria-label="Increase the quantity" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="cart-item__pricing">
                                        {%- if full_total > sale_total and full_total > 0 -%}
                                            {%- assign discount_amount = full_total | minus: sale_total -%}
                                            {%- assign discount_percent = discount_amount | times: 100 | divided_by: full_total -%}
                                            {%- assign discount_percent_rounded = discount_percent | round -%}

                                            <span class="cart-item__discount">
                                                <span>-{{ discount_percent_rounded }}%</span>
                                            </span>

                                            <div class="cart-item__price-stack">
                                                <span class="cart-item__price--full">{{ full_total | money }}</span>
                                                <span class="cart-item__price--sale{% if sale_total == 0 %} cart-item__price--free{% endif %}">
                                                    {%- if sale_total == 0 -%}
                                                        {{- 'sections.cart.free' | t -}}
                                                    {%- else -%}
                                                        {{ sale_total | money }}
                                                    {%- endif -%}
                                                </span>
                                            </div>

                                            {%- if item.variant.compare_at_price != blank -%}
                                                <input class="input-hidden__price" type="hidden" value="{{ total_discount | plus: item.variant.compare_at_price | minus: item.variant.price | times: item.quantity | money | remove: ',' }}">
                                            {%- else -%}
                                                {%- assign single_discount = unit_price | times: item.quantity -%}
                                                <input class="input-hidden__price" type="hidden" value="{{ total_discount | plus: single_discount | minus: item.line_price | money | remove: ',' }}">
                                            {%- endif -%}
                                        {%- else -%}
                                            <div class="cart-item__price-stack">
                                                <span class="cart-item__price--sale">{{ sale_total | money }}</span>
                                            </div>
                                        {%- endif -%}
                                    </div>

                                    <a href="/cart" class="cart-item__remove remove-from-cart" aria-label="Remove Item">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M18 6L6 18M6 6L18 18" stroke="#141414" stroke-width="1.5" stroke-linecap="round"/>
                                        </svg>
                                    </a>
                                </div>
                            {%- endfor -%}
                        </div>

                        <aside class="cart-summary summary">
                            <h2 class="cart-summary__title">Summary</h2>
                            <div class="cart-summary__divider"></div>

                            <div class="cart-summary__row subtotal">
                                <span class="cart-summary__label">Subtotal</span>
                                <span class="cart-summary__value">
                                    {%- assign subtotal = 0 -%}
                                    {%- for item in cart.items -%}
                                        {%- assign discount = item.variant.price | times: item.quantity -%}
                                        {%- if item.variant.compare_at_price != blank -%}
                                            {%- assign subtotal = subtotal | plus: item.variant.compare_at_price | minus: item.variant.price | times: item.quantity -%}
                                        {%- elsif item.line_price != discount -%}
                                            {%- assign subtotal = subtotal | plus: discount | minus: item.line_price | times: item.quantity -%}
                                        {%- endif -%}
                                    {%- endfor -%}
                                    {{ cart.items_subtotal_price | plus: subtotal | money }}
                                </span>
                            </div>

                            <div class="cart-summary__row sale">
                                <span class="cart-summary__label">Discount</span>
                                <span class="cart-summary__value cart-unempty__sale"></span>
                            </div>

                            <div class="cart-summary__row cart-summary__row--right shipping">
                                <span class="cart-summary__hint">Shipping calculated at Checkout</span>
                            </div>

                            <div class="cart-summary__divider"></div>

                            <div class="cart-summary__row total">
                                <span class="cart-summary__label cart-summary__label--total">Total</span>
                                <span class="cart-summary__value cart-summary__value--total">{{ cart.total_price | money }}</span>
                            </div>

                            <div id="corso-protection-placeholder-pr"></div>

                            {%- if settings.cart_additional_msg != "" -%}
                                <div class="additional-message">{{ settings.cart_additional_msg }}</div>
                            {%- endif -%}

                            {%- if settings.cart_return_policy != "" -%}
                                <div class="hide"><div id="return-policy"><div class="title">Return Policy</div>{{ settings.cart_return_policy }}</div></div>
                                <div class="return-policy-button"><a href="#" onclick="Simplistic.openModal($('#return-policy')); return false;">Return Policy</a></div>
                            {%- endif -%}

                            <button type="submit" class="cart-summary__btn" name="checkout">
                                Go to Checkout
                            </button>

                            {%- if additional_checkout_buttons -%}
                                <div class="additional-checkout-buttons">
                                    {{ content_for_additional_checkout_buttons }}
                                </div>
                            {%- endif -%}
                        </aside>
                    </div>
                </div>
            </div>
        </form>

    {%- endif -%}
</div>

<script>
    // Highlight "5-star" in Okendo carousel heading (Figma styling)
    (function () {
        function highlightStar() {
            document.querySelectorAll('.templateCart .oke-reviewCarousel-header-title').forEach(function (el) {
                if (el.dataset.okeStarHighlighted) return;
                if (el.innerHTML.indexOf('5-star') === -1) return;
                el.innerHTML = el.innerHTML.replace(
                    /5-star/g,
                    '<span class="oke-highlight-5star">5-star</span>'
                );
                el.dataset.okeStarHighlighted = 'true';
            });
        }
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', highlightStar);
        } else {
            highlightStar();
        }
        // Re-run when Okendo loads asynchronously
        var attempts = 0;
        var interval = setInterval(function () {
            highlightStar();
            attempts++;
            if (attempts > 20) clearInterval(interval);
        }, 500);
    })();

    document.addEventListener("DOMContentLoaded", () => {
        let inputs = document.querySelectorAll('.input-hidden__price');
        let total = 0;
        let currencySymbol = '';

        inputs.forEach((input, index) => {
            let value = input.value;

            if (index === 0) {
                currencySymbol = value.match(/[^0-9.]/g)?.join('') || '';
            }

            let numericValue = parseFloat(value.replace(/[^0-9.]/g, ''));

            if (!isNaN(numericValue)) {
                total += numericValue;
            }
        });

        let formattedTotal = total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

        const saleEl = document.querySelector('.cart-unempty__sale');
        if (saleEl) {
            saleEl.innerHTML = total > 0 ? `-${currencySymbol}${formattedTotal}` : `${currencySymbol}0.00`;
        }
    });
</script>

