<script>
    $(function(){

        /********* SPECIAL INSTRUCTIONS NOTE *********/
        var checkInstructions = function() {
            if($('#chk-instructions').is(':checked')) {
                $('#instructions-note').show();
            } else {
                $('#instructions-note').hide();
                $('#instructions-note').find('textarea').val("");
            }
        }
        $(document).on('click', '#chk-instructions',function(){
            checkInstructions();
        });
        checkInstructions();

        $(document).on('click', '#cart .remove-from-cart', function(){
            var $item = $(this).closest('.item');
            var $input = $item.find('input[type=number]');
            var lineIndex = $input.attr('id').replace('updates_', '');

            $('#loading-overlay').show();


            $.ajax({
                type: 'POST',
                url: '/cart/change.js',
                data: {
                    id: lineIndex,
                    quantity: 0
                },
                dataType: 'json'
            }).fail(function(xhr){
                console.log('error', xhr.responseText);
                $('#loading-overlay').hide();
            }).done(function(){
                if (typeof updateCartDesc === 'function') updateCartDesc();
                location.reload();
            });

            return false;
        });

        $(document).on('change', '#cart input[type=number]', function(){
            updateCart();
        });


        /********* UPDATE QUANTITY *********/
        function updateCart(){
            $('#loading-overlay').show();

            $.ajax({
                type: 'POST',
                url: '/cart/update.js',
                data: $('#cart .main-form').serialize(),
                dataType: 'json'
            }).fail(function(){console.log('error');}).done(function(){
                if (typeof updateCartDesc === 'function') updateCartDesc();
                $('#add-cart-overlay').fadeOut();
                location.reload();
            });
        }

        {%- if settings.allow_quick_view -%}
        /********* EDIT ITEM *********/
        $(document).on('click', '#cart .edit-item', function(){
            var url = $(this).data('url');
            var qty = $(this).data('qty');
            var variantId = $(this).data('variant');
            var itemKey = $(this).data('item-key');

            $('#loading-overlay').show();

            $.ajax({
                url: url,
                cache: false
            }).success(function(data){
                $('#loading-overlay').hide();
                Simplistic.openModal(data, 'quick-view');
                $('.quick-view [name=quantity]').val(qty).change();
                $('.quick-view #add-to-cart-button').text('SAVE CHANGES');
                $('.quick-view .initialized').on('productLoaded', function(){
                    $('.quick-view .initialized').data('productjs').setVariant(variantId);
                });

                $('.quick-view .add-to-cart-form').submit(function(){
                    $('#loading-overlay').show();
                    if(modal) modal.close();

                    var form = $(this);
                    $.ajax({
                        type: 'POST',
                        url: '/cart/change.js',
                        dataType: 'json',
                        data: {id: itemKey, quantity: 0}
                    }).success(function(){
                        addToCart(form, function(){
                            location.reload();
                        });
                    });
                    return false;
                });
            });
            return false;
        });
        {%- endif -%}

    });
</script>


<div id="cart" class="cart-page{% if cart.items == empty %} cart-page--empty{% else %} cart-page--full{% endif %}">

    {%- if cart.items == empty -%}

        <div class="cart-page__body cart-page__body--empty">
            <div class="cart-empty">
                <div class="cart-empty__hero">
                    <span class="cart-empty__moon" aria-hidden="true">
                        <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <defs><mask id="cartEmptyMoon"><rect x="0" y="0" width="72" height="72" fill="#fff"/><circle cx="46" cy="28" r="22" fill="#000"/></mask></defs>
                            <circle cx="36" cy="36" r="30" fill="#f9f2ff"/>
                            <circle cx="33" cy="34" r="22" fill="#672666" mask="url(#cartEmptyMoon)"/>
                            <path d="M55 14 q1.4 4 4.6 5 q-3.2 1-4.6 5 q-1.4-4-4.6-5 q3.2-1 4.6-5Z" fill="#fab851"/>
                            <path d="M53 40 q0.9 2.6 3 3.3 q-2.1 0.7-3 3.3 q-0.9-2.6-3-3.3 q2.1-0.7 3-3.3Z" fill="#eac78b"/>
                        </svg>
                    </span>

                    <h1 class="cart-empty__title">Your Cart is Empty</h1>
                    <p class="cart-empty__subtitle">Start Shopping Rejuvia Today</p>

                    <a href="https://www.rejuvia.co/products/sleep-spray?selling_plan=29054009564" class="cart-empty__cta">
                        Try Rejuvia
                        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9h11M10 4l5 5-5 5"/></svg>
                    </a>
                </div>
            </div>
        </div>

    {%- else -%}

        <div class="cart-page__hero">
            <div class="container">
                <div class="cart-page__hero-inner">
                    <h1 class="cart-page__title">Your Cart</h1>
                    {%- if section.settings.show_clear_cart or section.settings.show_continue_shopping -%}
                        <div class="cart-page__hero-actions">
                            {%- if section.settings.show_clear_cart -%}
                                <a href="{{ routes.cart_clear_url }}" class="cart-page__action cart-page__action--clear">
                                    Clear cart
                                </a>
                            {%- endif -%}
                            {%- if section.settings.show_continue_shopping -%}
                                <a href="https://www.rejuvia.co/collections/more-products" class="cart-page__action">
                                    Continue Shopping
                                </a>
                            {%- endif -%}
                        </div>
                    {%- endif -%}
                </div>
            </div>
        </div>

        <form action="/cart" method="post" id="cartform" class="main-form main-form__cart--unempty">
            <div class="cart-page__body">
                <div class="container">
                    <div class="cart-grid">
                        <div class="cart-items items">
                            {%- for item in cart.items -%}
                                {%- assign unit_compare = item.variant.compare_at_price | default: 0 -%}
                                {%- assign unit_price = item.variant.price | default: 0 -%}
                                {%- assign qty = item.quantity | default: 1 -%}
                                {%- if unit_compare > 0 -%}
                                    {%- assign full_total = unit_compare | times: qty -%}
                                {%- else -%}
                                    {%- assign full_total = unit_price | times: qty -%}
                                {%- endif -%}
                                {%- assign sale_total = item.line_price | default: 0 -%}

                                <div class="cart-item item {{ item.product.handle }}">
                                    <a href="{{ item.product.url }}" class="cart-item__image">
                                        {%- if item.variant.image -%}
                                            {%- assign variantImg = item.variant.image -%}
                                        {%- else -%}
                                            {%- assign variantImg = item.product.featured_image -%}
                                        {%- endif -%}
                                        <img src="{{ variantImg | image_url: width: 240 }}" srcset="{{ variantImg | image_url: width: 240 }} 1x, {{ variantImg | image_url: width: 360 }} 1.5x, {{ variantImg | image_url: width: 480 }} 2x" width="120" height="120" loading="lazy" alt="{{ item.product.title | escape }}" />
                                    </a>

                                    <div class="cart-item__main">
                                        <div class="cart-item__info">
                                            <a href="{{ item.url }}" class="cart-item__title-link">
                                                {%- assign titlePart = item.product.title | split: ' - ' -%}
                                                <h3 class="cart-item__name">{{ titlePart[0] }}</h3>
                                            </a>
                                            {%- if item.variant.title != "Default Title" -%}
                                                <p class="cart-item__variant">{{ item.variant.title }}</p>
                                            {%- endif -%}

                                            {%- unless item.variant.title contains 'Default' -%}
                                                <div class="variants hide">
                                                    {%- for option in item.options_with_values -%}
                                                        <strong>{{ option.name }}</strong>: {{ option.value }}{%- unless forloop.last -%}<br/>{%- endunless -%}
                                                    {%- endfor -%}
                                                </div>
                                            {%- endunless -%}
                                        </div>
                                    </div>

                                    <div class="cart-item__side">
                                        <div class="cart-item__pricing">
                                            {%- if full_total > sale_total and full_total > 0 -%}
                                                {%- assign discount_amount = full_total | minus: sale_total -%}
                                                {%- assign discount_percent = discount_amount | times: 100 | divided_by: full_total -%}
                                                {%- assign discount_percent_rounded = discount_percent | round -%}

                                                <span class="cart-item__discount">
                                                    <span>-{{ discount_percent_rounded }}%</span>
                                                </span>

                                                <div class="cart-item__price-stack">
                                                    <span class="cart-item__price--full">{{ full_total | money }}</span>
                                                    <span class="cart-item__price--sale{% if sale_total == 0 %} cart-item__price--free{% endif %}">
                                                        {%- if sale_total == 0 -%}
                                                            {{- 'sections.cart.free' | t -}}
                                                        {%- else -%}
                                                            {{ sale_total | money }}
                                                        {%- endif -%}
                                                    </span>
                                                </div>
                                            {%- else -%}
                                                <div class="cart-item__price-stack">
                                                    <span class="cart-item__price--sale">{{ sale_total | money }}</span>
                                                </div>
                                            {%- endif -%}
                                        </div>

                                        <div class="cart-item__quantity quantity">
                                            <div class="quantity-box">
                                                <div class="flex">
                                                    <input type="button" value="" class="minus animation" aria-label="Decrease the quantity" />
                                                    <input type="number" step="1" class="cart-unempty__number" name="updates[]" id="updates_{{ item.id }}" value="{{ item.quantity }}" title="Qty" min="0" aria-label="Quantity" />
                                                    <input type="button" value="" class="plus animation" aria-label="Increase the quantity" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <a href="/cart" class="cart-item__remove remove-from-cart" aria-label="Remove Item">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M18 6L6 18M6 6L18 18" stroke="#141414" stroke-width="1.5" stroke-linecap="round"/>
                                        </svg>
                                    </a>
                                </div>
                            {%- endfor -%}
                        </div>

                        <div class="cart-checkout">
                            <div class="cart-checkout__row subtotal">
                                <span class="cart-checkout__label">Subtotal</span>
                                <span class="cart-checkout__value">{{ cart.items_subtotal_price | money }}</span>
                            </div>

                            {%- if cart.cart_level_discount_applications.size > 0 -%}
                                {%- for discount in cart.cart_level_discount_applications -%}
                                    <div class="cart-checkout__row savings">
                                        <span class="cart-promo__chip">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M3.6 3.6H10.2L20.4 13.8L13.8 20.4L3.6 10.2V3.6Z" stroke="#141414" stroke-width="1.5" stroke-linejoin="round"/>
                                                <circle cx="7.5" cy="7.5" r="1.25" fill="#141414"/>
                                            </svg>
                                            <span class="cart-promo__chip-code">{{ discount.title }}</span>
                                            <button type="button" class="cart-promo__remove" data-code="{{ discount.title | escape }}" aria-label="Remove discount {{ discount.title | escape }}">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                                    <path d="M18 6L6 18M6 6L18 18" stroke="#141414" stroke-width="1.5" stroke-linecap="round"/>
                                                </svg>
                                            </button>
                                        </span>
                                        <span class="cart-checkout__value cart-checkout__value--savings">-{{ discount.total_allocated_amount | money }}</span>
                                    </div>
                                {%- endfor -%}
                            {%- endif -%}

                            <p class="cart-checkout__note">Shipping &amp; taxes calculated at checkout</p>

                            <div class="cart-promo" data-cart-promo>
                                <button type="button" class="cart-promo__toggle" aria-expanded="false">
                                    <span>Have a promo code?</span>
                                    <svg class="cart-promo__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M6 9L12 15L18 9" stroke="#141414" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                    </svg>
                                </button>
                                <div class="cart-promo__panel" hidden>
                                    <div class="cart-promo__field">
                                        <input type="text" class="cart-promo__input" placeholder="Promo code" aria-label="Promo code" autocomplete="off" />
                                        <button type="button" class="cart-promo__apply">Apply</button>
                                    </div>
                                    <p class="cart-promo__error" role="alert" hidden>
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                                            <path d="M12 8V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                            <circle cx="12" cy="16" r="0.9" fill="currentColor"/>
                                        </svg>
                                        <span class="cart-promo__error-text">Invalid promo code.</span>
                                    </p>
                                </div>
                            </div>

                            <div id="corso-protection-placeholder-pr"></div>

                            {%- if settings.cart_additional_msg != "" -%}
                                <div class="additional-message">{{ settings.cart_additional_msg }}</div>
                            {%- endif -%}

                            {%- if settings.cart_return_policy != "" -%}
                                <div class="hide"><div id="return-policy"><div class="title">Return Policy</div>{{ settings.cart_return_policy }}</div></div>
                                <div class="return-policy-button"><a href="#" onclick="Simplistic.openModal($('#return-policy')); return false;">Return Policy</a></div>
                            {%- endif -%}

                            <button type="submit" class="cart-checkout__btn" name="checkout">
                                Go to Checkout
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </form>

    {%- endif -%}
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Promo code: expandable, AJAX apply/validate/remove via Cart API
        const getCart = () => fetch('/cart.js', { headers: { 'Accept': 'application/json' } }).then(r => r.json());
        const setDiscounts = (codes) => fetch('/cart/update.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ discount: codes.join(',') })
        }).then(r => r.json());

        const promo = document.querySelector('[data-cart-promo]');
        if (promo) {
            const toggle = promo.querySelector('.cart-promo__toggle');
            const panel = promo.querySelector('.cart-promo__panel');
            const field = promo.querySelector('.cart-promo__field');
            const input = promo.querySelector('.cart-promo__input');
            const apply = promo.querySelector('.cart-promo__apply');
            const errorEl = promo.querySelector('.cart-promo__error');

            toggle.addEventListener('click', () => {
                const open = panel.hasAttribute('hidden');
                if (open) { panel.removeAttribute('hidden'); input.focus(); } else { panel.setAttribute('hidden', ''); }
                toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
            });

            const showError = (msg) => {
                field.classList.add('has-error');
                if (msg) errorEl.querySelector('.cart-promo__error-text').textContent = msg;
                errorEl.removeAttribute('hidden');
            };
            const clearError = () => {
                field.classList.remove('has-error');
                errorEl.setAttribute('hidden', '');
            };
            input.addEventListener('input', clearError);

            const applyCode = async () => {
                const code = (input.value || '').trim();
                if (!code) { input.focus(); return; }
                clearError();
                apply.disabled = true;
                apply.textContent = 'Applying…';
                try {
                    const before = await getCart();
                    const existing = (before.discount_codes || []).filter(d => d.applicable).map(d => d.code);
                    const codes = existing.filter(c => c.toLowerCase() !== code.toLowerCase()).concat(code);
                    const cart = await setDiscounts(codes);

                    let applied = false;
                    if (Array.isArray(cart.discount_codes)) {
                        const match = cart.discount_codes.find(d => d.code.toLowerCase() === code.toLowerCase());
                        applied = !!(match && match.applicable);
                    } else {
                        const apps = cart.cart_level_discount_applications || [];
                        applied = apps.some(a => (a.title || '').toLowerCase() === code.toLowerCase())
                            || (cart.total_discount || 0) > (before.total_discount || 0);
                    }

                    if (applied) {
                        location.reload();
                        return;
                    }
                    showError('Invalid promo code.');
                } catch (e) {
                    showError('Something went wrong. Please try again.');
                }
                apply.disabled = false;
                apply.textContent = 'Apply';
            };
            apply.addEventListener('click', applyCode);
            input.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') { e.preventDefault(); applyCode(); }
            });
        }

        // Remove an applied discount code (chip × button)
        document.addEventListener('click', async (e) => {
            const rm = e.target.closest('.cart-promo__remove');
            if (!rm) return;
            e.preventDefault();
            rm.disabled = true;
            const code = (rm.getAttribute('data-code') || '').toLowerCase();
            try {
                const current = await getCart();
                const remaining = (current.discount_codes || [])
                    .filter(d => d.applicable && d.code.toLowerCase() !== code)
                    .map(d => d.code);
                await setDiscounts(remaining);
            } catch (err) { /* fall through to reload */ }
            location.reload();
        });

        // Quantity control: show trash icon when qty is 1, minus when qty > 1
        const syncRemoveState = (input) => {
            const minus = input.parentNode.querySelector('.minus');
            if (!minus) return;
            const v = parseInt(input.value, 10);
            minus.classList.toggle('is-remove', !(v > 1));
        };
        document.querySelectorAll('.cart-item__quantity input[type="number"]').forEach(syncRemoveState);
        document.addEventListener('input', (e) => {
            if (e.target.matches('.cart-item__quantity input[type="number"]')) syncRemoveState(e.target);
        });
    });
</script>

{% schema %}
{
  "name": "Cart page",
  "settings": [
    {
      "type": "header",
      "content": "Header actions"
    },
    {
      "type": "checkbox",
      "id": "show_clear_cart",
      "label": "Show Clear cart link",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_continue_shopping",
      "label": "Show Continue shopping link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Cart page",
      "category": "Custom"
    }
  ]
}

{% endschema %}
