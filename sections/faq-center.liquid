{% style %}
.fc {
  background-color: {{ section.settings.bg_color }};
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}
.fc__container {
  max-width: {{ section.settings.max_width | default: 960 }}px;
  margin: 0 auto;
  padding: {{ section.settings.padding_top | default: 64 }}px 24px {{ section.settings.padding_bottom | default: 64 }}px;
}
.fc__eyebrow {
  text-align: center;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: {{ section.settings.accent_color }};
  margin: 0 0 10px;
}
.fc__title {
  font-family: 'HelveticaNeueL', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  text-align: center;
  font-size: {{ section.settings.title_size | default: 40 }}px;
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -0.02em;
  color: {{ section.settings.title_color }};
  margin: 0 0 36px;
}
.fc__list { border-top: 1px solid rgba(0,0,0,0.1); }
.fc__item { border-bottom: 1px solid rgba(0,0,0,0.1); }
.fc__q {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  padding: 22px 4px;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  font-family: inherit;
  font-size: {{ section.settings.question_size | default: 18 }}px;
  font-weight: 500;
  line-height: 1.4;
  color: {{ section.settings.title_color }};
}
.fc__icon {
  position: relative;
  flex-shrink: 0;
  width: 18px;
  height: 18px;
  transition: transform 0.25s ease;
}
.fc__icon::before,
.fc__icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  background: {{ section.settings.accent_color }};
  transform: translate(-50%, -50%);
}
.fc__icon::before { width: 16px; height: 2px; }
.fc__icon::after { width: 2px; height: 16px; }
.fc__item.is-open .fc__icon { transform: rotate(45deg); }
.fc__a {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}
.fc__item.is-open .fc__a { max-height: 800px; }
.fc__a-inner {
  padding: 0 4px 24px;
  font-size: {{ section.settings.answer_size | default: 16 }}px;
  font-weight: 400;
  line-height: 1.6;
  color: {{ section.settings.answer_color }};
}
.fc__a-inner p { margin: 0 0 12px; }
.fc__a-inner p:last-child { margin-bottom: 0; }

@media (max-width: 749px) {
  .fc__container { padding: {{ section.settings.padding_top | default: 64 | times: 0.6 | round }}px 16px {{ section.settings.padding_bottom | default: 64 | times: 0.6 | round }}px; }
  .fc__title { font-size: {{ section.settings.title_size_mobile | default: 28 }}px; margin-bottom: 24px; }
  .fc__q { font-size: {{ section.settings.question_size | default: 18 | minus: 2 }}px; padding: 20px 2px; }
}
{% endstyle %}

<section class="fc" id="fc-{{ section.id }}">
  <div class="fc__container">
    {%- if section.settings.eyebrow != blank -%}<p class="fc__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="fc__title">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="fc__list">
      {%- for block in section.blocks -%}
        <div class="fc__item{% if section.settings.open_first and forloop.first %} is-open{% endif %}" {{ block.shopify_attributes }}>
          <button class="fc__q" type="button" aria-expanded="{% if section.settings.open_first and forloop.first %}true{% else %}false{% endif %}">
            <span>{{ block.settings.question }}</span>
            <span class="fc__icon" aria-hidden="true"></span>
          </button>
          <div class="fc__a">
            <div class="fc__a-inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
(function () {
  var sec = document.getElementById('fc-{{ section.id }}');
  if (!sec) return;
  var items = sec.querySelectorAll('.fc__item');
  sec.querySelectorAll('.fc__q').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.fc__item');
      var willOpen = !item.classList.contains('is-open');
      items.forEach(function (i) {
        i.classList.remove('is-open');
        var b = i.querySelector('.fc__q');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
      if (willOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "FAQ Center",
  "tag": "section",
  "max_blocks": 24,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "GOOD TO KNOW" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently asked questions" },
    { "type": "checkbox", "id": "open_first", "label": "Open first question by default", "default": true },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "title_size", "min": 24, "max": 56, "step": 1, "unit": "px", "label": "Heading size (desktop)", "default": 40 },
    { "type": "range", "id": "title_size_mobile", "min": 18, "max": 40, "step": 1, "unit": "px", "label": "Heading size (mobile)", "default": 28 },
    { "type": "range", "id": "question_size", "min": 14, "max": 24, "step": 1, "unit": "px", "label": "Question size", "default": 18 },
    { "type": "range", "id": "answer_size", "min": 12, "max": 20, "step": 1, "unit": "px", "label": "Answer size", "default": 16 },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "max_width", "min": 600, "max": 1200, "step": 20, "unit": "px", "label": "Content width", "default": 960 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Eyebrow & icon color", "default": "#672666" },
    { "type": "color", "id": "title_color", "label": "Heading & question color", "default": "#141414" },
    { "type": "color", "id": "answer_color", "label": "Answer color", "default": "#5C5C5C" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Center",
      "category": "Listicle",
      "blocks": [
        { "type": "faq", "settings": { "question": "What if it doesn't work for me?", "answer": "<p>Every order is backed by our 90-Day Money-Back Guarantee. Try Rejuvia risk-free for a full 90 nights — if you're not sleeping better, send it back for a complete refund, no questions asked.</p>" } },
        { "type": "faq", "settings": { "question": "Will I wake up groggy in the morning?", "answer": "<p>No. Rejuvia uses a low 2mg dose of melatonin — most gummies pack 5-10mg — paired with natural sleep herbs that calm your mind without knocking you out. You get deep, restorative sleep and wake up clear-headed, not hungover.</p>" } },
        { "type": "faq", "settings": { "question": "How fast will I feel Rejuvia working?", "answer": "<p>Because you spray it under your tongue, it absorbs directly into your bloodstream with no waiting on digestion. Most customers feel calm and drift off within 10-15 minutes, instead of the 60-90 minutes pills can take.</p>" } },
        { "type": "faq", "settings": { "question": "Is Rejuvia habit-forming? Will I become dependent on it?", "answer": "<p>No. Rejuvia is drug-free and non-habit-forming. There's no tolerance buildup, no dependency, and no withdrawal — it works with your body's natural sleep cycle instead of overriding it.</p>" } },
        { "type": "faq", "settings": { "question": "What are the ingredients in Rejuvia?", "answer": "<p>A blend of 13 natural sleep ingredients including melatonin (just 2mg), 5-HTP, valerian root, passionflower, chamomile, lemon balm, skullcap, magnolia bark, hops, cramp bark, ginkgo biloba, peppermint, and feverfew. Every batch is triple lab-tested for purity — no fillers, no junk.</p>" } },
        { "type": "faq", "settings": { "question": "What flavor is Rejuvia?", "answer": "<p>Rejuvia has a light, naturally pleasant taste made for a quick spray under the tongue.</p>" } },
        { "type": "faq", "settings": { "question": "Is this a subscription?", "answer": "<p>No. Rejuvia is a one-time purchase, not a subscription — you're only charged once for the bundle you choose.</p>" } },
        { "type": "faq", "settings": { "question": "How long does one bottle last and when will my order arrive?", "answer": "<p>Each bottle is about a 30-night supply. Orders typically ship within 1-2 business days and arrive within a few business days after that.</p>" } }
      ]
    }
  ]
}
{% endschema %}
