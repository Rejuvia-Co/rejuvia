<style>
.footer-v2 {
    width: 100%;
    background-color: {{ section.settings.bg_color | default: '#EAEAF7' }};
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    color: {{ section.settings.text_color | default: '#141414' }};
}

.footer-v2-container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 64px;
}

/* Top section */
.footer-v2-top {
    display: flex;
    justify-content: space-between;
    padding-bottom: 32px;
}

/* Logo + socials */
.footer-v2-brand {
    display: flex;
    flex-direction: column;
    gap: 24px;
    min-width: 180px;
}

.footer-v2-logo {
    max-width: 180px;
    height: auto;
}

.footer-v2-socials {
    display: flex;
    gap: 24px;
    align-items: center;
}

.footer-v2-socials a {
    color: #141414;
    display: flex;
    text-decoration: none;
}

.footer-v2-socials svg {
    width: 24px;
    height: 24px;
}

/* Nav columns */
.footer-v2-nav {
    display: flex;
    gap: 100px;
}

.footer-v2-nav-col {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.footer-v2-nav-title {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.4;
    color: #141414;
    text-transform: uppercase;
    letter-spacing: 0;
    margin: 0;
}

.footer-v2-nav-col a {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
    text-decoration: none;
}

.footer-v2-nav-col a:hover {
    text-decoration: underline;
}

.footer-v2-nav-links {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

/* Newsletter */
.footer-v2-newsletter {
    width: 368px;
    max-width: 368px;
    flex-shrink: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
}

.footer-v2-newsletter-title {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.4;
    color: #141414;
    margin: 0;
}

.footer-v2-newsletter-desc {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
    margin: 0;
    margin-top: -18px;
}

.footer-v2-form {
    position: relative;
}

/* White pill containing the input and an inline arrow/submit */
.footer-v2-field {
    display: flex;
    align-items: center;
    gap: 8px;
    height: 64px;
    padding: 0 10px 0 24px;
    background: #fff;
    border: 1px solid #141414;
    border-radius: 100px;
    box-sizing: border-box;
}

.footer-v2-input {
    flex: 1 1 0 !important;
    width: auto !important;
    min-width: 0;
    height: 100% !important;
    padding: 0 !important;
    border: none !important;
    border-radius: 0 !important;
    font-size: 16px !important;
    font-family: inherit;
    background: transparent !important;
    color: #141414 !important;
    outline: none;
    box-sizing: border-box;
    -webkit-appearance: none;
}

.footer-v2-input::placeholder {
    color: #999;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
}

.footer-v2-submit {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: transparent;
    border: none;
    border-radius: 100px;
    color: #141414;
    cursor: pointer;
    transition: transform 0.15s ease;
}

.footer-v2-submit:hover {
    transform: translateX(2px);
}

/* Loading spinner (replaces the arrow while submitting) */
.footer-v2-spinner {
    display: none;
    width: 22px;
    height: 22px;
    border: 2px solid rgba(20, 20, 20, 0.2);
    border-top-color: #141414;
    border-radius: 50%;
    animation: footer-v2-spin 0.7s linear infinite;
}

@keyframes footer-v2-spin {
    to { transform: rotate(360deg); }
}

.footer-v2-form.is-loading .footer-v2-submit-arrow { display: none; }
.footer-v2-form.is-loading .footer-v2-spinner { display: block; }
.footer-v2-form.is-loading .footer-v2-submit { cursor: default; transform: none; }

/* Success state (replaces the field) */
.footer-v2-success {
    display: none;
    align-items: center;
    justify-content: center;
    height: 64px;
    margin: 0;
    padding: 0 24px;
    background: #fff;
    border: 1px solid #141414;
    border-radius: 100px;
    color: #2e7d32;
    font-size: 18px;
    font-weight: 500;
    text-align: center;
}

.footer-v2-form.is-done .footer-v2-field { display: none; }
.footer-v2-form.is-done .footer-v2-success { display: flex; }

/* Hidden submit target (keeps the newsletter POST off the top window) */
.footer-v2-newsletter-sink { display: none; }

/* Divider */
.footer-v2-divider {
    width: 100%;
    height: 1px;
    background: rgba(0,0,0,0.1);
}

/* Disclaimer */
.footer-v2-bottom-section {
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding-top: 32px;
}

.footer-v2-disclaimer {
    font-size: 12px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    padding: 0;
    margin: 0;
    font-style: italic;
}

.footer-v2-disclaimer + .footer-v2-divider {
    display: none;
}

/* Bottom */
.footer-v2-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
}

.footer-v2-bottom-left {
    display: flex;
    align-items: center;
    gap: 16px;
    font-size: 16px;
    color: #141414;
}

.footer-v2-bottom-left a {
    color: #141414;
    text-decoration: underline;
}

.footer-v2-legal-links {
    display: flex;
    gap: 16px;
}

.footer-v2-payment-icons {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
}

.footer-v2-payment-icons svg {
    height: 32px;
    width: auto;
}

/* Mobile accordion */
.footer-v2-nav-toggle {
    display: none;
}

.footer-v2-nav-chevron {
    display: none;
}

.footer-v2-socials-mobile {
    display: none;
}

/* ===== Responsive ===== */
@media (max-width: 900px) {
    .footer-v2-container {
        padding: 40px 16px;
    }
    .footer-v2-top {
        flex-direction: column;
        gap: 32px;
        padding-bottom: 0;
        border-bottom: none;
    }
    /* Order: logo, newsletter, nav, socials */
    .footer-v2-brand {
        order: 1;
    }
    .footer-v2-brand .footer-v2-logo {
        max-width: 160px;
    }
    .footer-v2-brand .footer-v2-socials {
        display: none;
    }
    .footer-v2-newsletter {
        width: 100%;
        max-width: 100%;
        order: 2;
    }
    .footer-v2-newsletter-desc {
        font-size: 16px;
        margin-top: 0;
    }
    .footer-v2-submit {
        font-size: 16px;
    }
    .footer-v2-nav {
        flex-direction: column;
        gap: 0;
        order: 3;
    }
    .footer-v2-nav-col {
        border-top: 1px solid rgba(0,0,0,0.1);
        padding: 24px 0;
        gap: 0;
    }
    .footer-v2-nav-col:last-child {
        border-bottom: 1px solid rgba(0,0,0,0.1);
    }
    .footer-v2-nav-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        margin: 0;
        font-size: 16px;
    }
    .footer-v2-nav-chevron {
        display: block;
        width: 24px;
        height: 24px;
        transition: transform 0.3s ease;
    }
    .footer-v2-nav-col.is-open .footer-v2-nav-chevron {
        transform: rotate(180deg);
    }
    .footer-v2-nav-links {
        display: none;
        flex-direction: column;
        gap: 16px;
        padding-top: 16px;
    }
    .footer-v2-nav-col.is-open .footer-v2-nav-links {
        display: flex;
    }
    /* Mobile socials after nav */
    .footer-v2-socials-mobile {
        display: flex;
        gap: 24px;
        align-items: center;
        padding: 24px 0;
        padding-top: 0;
        border-bottom: none;
        order: 4;
    }
    .footer-v2-socials-mobile a {
        color: #141414;
        display: flex;
        text-decoration: none;
    }
    .footer-v2-socials-mobile svg {
        width: 24px;
        height: 24px;
    }
    /* Bottom */
    .footer-v2-disclaimer {
        font-size: 12px;
    }
    .footer-v2-bottom {
        flex-direction: column;
        align-items: flex-start;
        gap: 24px;
    }
    .footer-v2-payment-icons {
        order: -1;
    }
    .footer-v2-bottom-left {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
        font-size: 16px;
    }
}
</style>

<footer class="footer-v2">
    <div class="footer-v2-container">
        <div class="footer-v2-top">
            {%- comment -%} Logo + Socials {%- endcomment -%}
            <div class="footer-v2-brand">
                {% if section.settings.logo != blank %}
                    <a href="{{ routes.root_url }}">
<img class="footer-v2-logo"
     src="{{ section.settings.logo | image_url: width: 400 }}"
     width="{{ section.settings.logo.width }}"
     height="{{ section.settings.logo.height }}"
     loading="lazy"
     alt="{{ shop.name }}">                    </a>
                {% endif %}
                <div class="footer-v2-socials">
                    {% if settings.instagram_link != blank %}
                        <a href="{{ settings.instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
                        </a>
                    {% endif %}
                    {% if settings.facebook_link != blank %}
                        <a href="{{ settings.facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                        </a>
                    {% endif %}
                    {% if settings.twitter_link != blank %}
                        <a href="{{ settings.twitter_link }}" target="_blank" rel="noopener" aria-label="X">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                        </a>
                    {% endif %}
                </div>
            </div>

            {%- comment -%} Nav columns {%- endcomment -%}
            <div class="footer-v2-nav">
                {% for block in section.blocks %}
                    {% if block.type == 'nav_column' %}
                        <div class="footer-v2-nav-col" data-footer-v2-col {{ block.shopify_attributes }}>
                            <div class="footer-v2-nav-title" data-footer-v2-toggle>
                                {{ block.settings.title }}
                                <svg class="footer-v2-nav-chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none">
                                    <path d="M5 8L10 13L15 8" stroke="#141414" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                            <div class="footer-v2-nav-links">
                                {% if block.settings.menu != blank %}
                                    {% for link in linklists[block.settings.menu].links %}
                                        <a href="{{ link.url }}">{{ link.title }}</a>
                                    {% endfor %}
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}
                {% endfor %}
            </div>

            {%- comment -%} Mobile socials (after nav, hidden on desktop) {%- endcomment -%}
            <div class="footer-v2-socials-mobile">
                {% if settings.instagram_link != blank %}
                    <a href="{{ settings.instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
                    </a>
                {% endif %}
                {% if settings.facebook_link != blank %}
                    <a href="{{ settings.facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                    </a>
                {% endif %}
                {% if settings.twitter_link != blank %}
                    <a href="{{ settings.twitter_link }}" target="_blank" rel="noopener" aria-label="X">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                {% endif %}
            </div>

            {%- comment -%} Newsletter {%- endcomment -%}
            <div class="footer-v2-newsletter">
                <h3 class="footer-v2-newsletter-title">{{ section.settings.newsletter_title }}</h3>
                <p class="footer-v2-newsletter-desc">{{ section.settings.newsletter_desc }}</p>
                <form class="footer-v2-form" method="post" action="/contact#contact_form" accept-charset="UTF-8" target="footer-newsletter-sink" data-newsletter-form>
                    <input type="hidden" name="form_type" value="customer">
                    <input type="hidden" name="utf8" value="✓">
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <div class="footer-v2-field">
                        <input class="footer-v2-input" type="email" name="contact[email]" placeholder="Your Email" required autocomplete="email" aria-label="Email address">
                        <button class="footer-v2-submit" type="submit" aria-label="Subscribe">
                            <svg class="footer-v2-submit-arrow" width="20" height="20" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9h11M10 4l5 5-5 5"/></svg>
                            <span class="footer-v2-spinner" aria-hidden="true"></span>
                        </button>
                    </div>
                    <p class="footer-v2-success" role="status">Thanks! You're in!</p>
                </form>
                {%- comment -%} Submit target: keeps the POST off the top window so the page never reloads, even with JS disabled/deferred {%- endcomment -%}
                <iframe name="footer-newsletter-sink" class="footer-v2-newsletter-sink" title="Newsletter signup" tabindex="-1" aria-hidden="true"></iframe>
            </div>
        </div>

        <div class="footer-v2-divider"></div>

        <div class="footer-v2-bottom-section">
            {%- comment -%} Disclaimer {%- endcomment -%}
            {% if section.settings.disclaimer != blank %}
                <p class="footer-v2-disclaimer">{{ section.settings.disclaimer }}</p>
            {% endif %}

            {%- comment -%} Bottom {%- endcomment -%}
            <div class="footer-v2-bottom">
            <div class="footer-v2-bottom-left">
                <span>Copyright &copy; {{ 'now' | date: '%Y' }}. All rights reserved.</span>
                <div class="footer-v2-legal-links">
                    {% if section.settings.terms_url != blank %}
                        <a href="{{ section.settings.terms_url }}">Terms of Service</a>
                    {% endif %}
                    {% if section.settings.privacy_url != blank %}
                        <a href="{{ section.settings.privacy_url }}">Privacy Policy</a>
                    {% endif %}
                </div>
            </div>
            {% if section.settings.show_payment_methods %}
                <div class="footer-v2-payment-icons">
                    {%- for type in shop.enabled_payment_types -%}
                        {{ type | payment_type_svg_tag }}
                    {%- endfor -%}
                </div>
            {% endif %}
            </div>
        </div>
    </div>
</footer>

<script>
(function() {
    document.querySelectorAll('[data-footer-v2-toggle]').forEach(function(toggle) {
        toggle.addEventListener('click', function() {
            toggle.closest('[data-footer-v2-col]').classList.toggle('is-open');
        });
    });

    // Newsletter: the form posts into a hidden iframe (target), so the page never
    // reloads regardless of JS timing. This handler just layers on the loading
    // spinner + "Thanks! You're in!" success state once the iframe responds.
    document.addEventListener('submit', function(e) {
        var form = e.target.closest && e.target.closest('[data-newsletter-form]');
        if (!form) return;
        if (form.classList.contains('is-done')) { e.preventDefault(); return; }
        // invalid input -> let the browser show its native validation, no submit happens
        var email = form.querySelector('input[type="email"]');
        if (email && !email.checkValidity()) return;
        // NOTE: no preventDefault — the form submits natively into the iframe target
        form.classList.add('is-loading');
        var sink = document.getElementsByName(form.getAttribute('target'))[0];
        if (!sink) return;
        var onLoad = function() {
            sink.removeEventListener('load', onLoad);
            form.classList.remove('is-loading');
            var ok = false;
            try { ok = (sink.contentWindow.location.href || '').indexOf('customer_posted=true') !== -1; } catch (err) {}
            if (ok) form.classList.add('is-done'); // else leave the field so they can retry
        };
        sink.addEventListener('load', onLoad);
    });
})();
</script>

{% schema %}
{
    "name": "Footer V2",
    "settings": [
        {
            "type": "header",
            "content": "Colors"
        },
        {
            "type": "color",
            "id": "bg_color",
            "label": "Background color",
            "default": "#EAEAF7"
        },
        {
            "type": "color",
            "id": "text_color",
            "label": "Text color",
            "default": "#141414"
        },
        {
            "type": "header",
            "content": "Brand"
        },
        {
            "type": "image_picker",
            "id": "logo",
            "label": "Logo"
        },
        {
            "type": "header",
            "content": "Newsletter"
        },
        {
            "type": "text",
            "id": "newsletter_title",
            "label": "Title",
            "default": "Save 10% on Your Order"
        },
        {
            "type": "text",
            "id": "newsletter_desc",
            "label": "Description",
            "default": "Sign up for news and exclusive discounts, plus 10% off your first order!"
        },
        {
            "type": "text",
            "id": "newsletter_btn",
            "label": "Button text",
            "default": "Sign Up & Save 10%"
        },
        {
            "type": "header",
            "content": "Bottom"
        },
        {
            "type": "textarea",
            "id": "disclaimer",
            "label": "FDA Disclaimer",
            "default": "*These statements have not been evaluated by the FDA. This product is not intended to diagnose, treat, cure or prevent any disease. Discontinue use and consult with your health care professional if you experience any adverse reaction to this product."
        },
        {
            "type": "url",
            "id": "terms_url",
            "label": "Terms of Service URL"
        },
        {
            "type": "url",
            "id": "privacy_url",
            "label": "Privacy Policy URL"
        },
        {
            "type": "checkbox",
            "id": "show_payment_methods",
            "label": "Show payment methods",
            "default": true
        }
    ],
    "blocks": [
        {
            "type": "nav_column",
            "name": "Nav Column",
            "settings": [
                {
                    "type": "text",
                    "id": "title",
                    "label": "Column title",
                    "default": "SHOP"
                },
                {
                    "type": "link_list",
                    "id": "menu",
                    "label": "Menu"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Footer V2",
            "blocks": [
                { "type": "nav_column", "settings": { "title": "SHOP" } },
                { "type": "nav_column", "settings": { "title": "ABOUT" } },
                { "type": "nav_column", "settings": { "title": "HELP" } }
            ]
        }
    ]
}
{% endschema %}
