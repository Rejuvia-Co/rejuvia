{% style %}
.fs-{{ section.id }} {
  --fs-plum: #672666;
  --fs-deep: #3a153a;
  --fs-body: #5c5c66;
  --fs-muted: #8a8a94;
  --fs-ink: #141414;
  --fs-mauve: #c694a0;
  --fs-divider: #d7d2e2;
  background: {{ section.settings.section_bg | default: '#672666' }};
  font-family: 'Helvetica Neue', Arimo, Helvetica, Arial, sans-serif;
}
.fs-{{ section.id }} .fs__wrap { max-width: 1280px; margin: 0 auto; padding: 48px 40px; }
.fs-{{ section.id }} .fs__band {
  background: {{ section.settings.card_bg | default: '#ffffff' }};
  border-radius: 20px;
  overflow: hidden;
  display: flex;
  align-items: center;
  gap: 60px;
  padding: 64px 72px;
}

/* Polaroid */
.fs-{{ section.id }} .fs__polaroid {
  flex-shrink: 0;
  background: #fff;
  padding: 14px 14px 20px;
  border-radius: 6px;
  box-shadow: 0 18px 40px -16px {{ section.settings.image_shadow_color | default: '#2a0e2a' | color_modify: 'alpha', 0.26 }};
  transform: rotate(-3deg);
}
.fs-{{ section.id }} .fs__photo { width: 290px; height: 346px; overflow: hidden; border-radius: 2px; }
.fs-{{ section.id }} .fs__photo img { width: 100%; height: 100%; object-fit: cover; object-position: center 22%; display: block; }
.fs-{{ section.id }} .fs__cap1 { font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif; font-size: 14px; font-weight: 600; color: var(--fs-plum); text-align: center; margin-top: 12px; }
.fs-{{ section.id }} .fs__cap2 { font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif; font-size: 12px; color: var(--fs-muted); text-align: center; margin-top: 2px; }

/* Text column */
.fs-{{ section.id }} .fs__text { flex: 1; min-width: 0; }
.fs-{{ section.id }} .fs__quote { font-family: Georgia, serif; font-size: 76px; line-height: 0.5; display: block; height: 40px; color: var(--fs-mauve); }
.fs-{{ section.id }} .fs__headline { font-size: {{ section.settings.headline_size | default: 30 }}px; font-weight: 700; line-height: 1.3; letter-spacing: -0.5px; color: var(--fs-deep); margin: 0 0 18px; }
.fs-{{ section.id }} .fs__p { font-size: {{ section.settings.body_size | default: 18 }}px; line-height: 1.62; color: var(--fs-body); max-width: 620px; margin: 0 0 16px; }
.fs-{{ section.id }} .fs__p:last-of-type { margin-bottom: 28px; }

/* Stats */
.fs-{{ section.id }} .fs__stats { display: flex; align-items: center; margin-bottom: 28px; }
.fs-{{ section.id }} .fs__stat { padding-right: 28px; }
.fs-{{ section.id }} .fs__stat + .fs__stat { border-left: 1px solid var(--fs-divider); padding: 0 28px; }
.fs-{{ section.id }} .fs__stat-num { font-size: {{ section.settings.stat_num_size | default: 28 }}px; font-weight: 700; color: var(--fs-plum); letter-spacing: -0.5px; line-height: 1.1; }
.fs-{{ section.id }} .fs__stat-label { font-size: {{ section.settings.stat_label_size | default: 14 }}px; color: var(--fs-muted); }

/* Signature */
.fs-{{ section.id }} .fs__sig { height: 54px; width: auto; display: block; margin: 0 0 4px -2px; }
.fs-{{ section.id }} .fs__name-row { display: flex; align-items: center; gap: 10px; }
.fs-{{ section.id }} .fs__name { font-size: {{ section.settings.name_size | default: 19 }}px; font-weight: 700; color: var(--fs-ink); }
.fs-{{ section.id }} .fs__dot { width: 4px; height: 4px; border-radius: 50%; background: var(--fs-mauve); flex-shrink: 0; }
.fs-{{ section.id }} .fs__attr { font-size: {{ section.settings.title_size | default: 15 }}px; font-style: italic; color: var(--fs-muted); }

/* Mobile: full-bleed lavender section, centered */
@media (max-width: 767px) {
  .fs-{{ section.id }} .fs__wrap { max-width: none; padding: 0; }
  .fs-{{ section.id }} .fs__band {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
    background: linear-gradient(150deg, #eaeaf7, #f9f2ff);
    border-radius: 0;
    box-shadow: none;
    padding: 36px 26px;
  }
  .fs-{{ section.id }} .fs__polaroid { padding: 10px 10px 14px; box-shadow: 0 14px 28px -12px rgba(40,12,40,0.4); margin-bottom: 24px; }
  .fs-{{ section.id }} .fs__photo { width: 200px; height: 200px; }
  .fs-{{ section.id }} .fs__cap1 { font-size: 12px; margin-top: 8px; }
  .fs-{{ section.id }} .fs__text { width: 100%; }
  .fs-{{ section.id }} .fs__quote { display: none; }
  .fs-{{ section.id }} .fs__headline { font-size: {{ section.settings.headline_size_mobile | default: 22 }}px; line-height: 1.28; letter-spacing: -0.4px; margin: 0 0 12px; }
  .fs-{{ section.id }} .fs__p { font-size: {{ section.settings.body_size_mobile | default: 15 }}px; line-height: 1.6; max-width: 100%; margin: 0 0 12px; }
  .fs-{{ section.id }} .fs__p:last-of-type { margin-bottom: 20px; }
  .fs-{{ section.id }} .fs__stats { justify-content: center; margin-bottom: 20px; }
  .fs-{{ section.id }} .fs__stat { padding: 0 16px; }
  .fs-{{ section.id }} .fs__stat:first-child { padding-left: 0; }
  .fs-{{ section.id }} .fs__stat + .fs__stat { padding: 0 16px; }
  .fs-{{ section.id }} .fs__stat-num { font-size: {{ section.settings.stat_num_size_mobile | default: 20 }}px; }
  .fs-{{ section.id }} .fs__stat-label { font-size: {{ section.settings.stat_label_size_mobile | default: 12 }}px; }
  .fs-{{ section.id }} .fs__sig { height: 42px; margin: 0 auto 4px; }
  .fs-{{ section.id }} .fs__name-row { justify-content: center; gap: 9px; }
  .fs-{{ section.id }} .fs__name { font-size: {{ section.settings.name_size_mobile | default: 16 }}px; }
  .fs-{{ section.id }} .fs__attr { font-size: {{ section.settings.title_size_mobile | default: 13 }}px; }
}
{% endstyle %}

{%- assign fs_photo = section.settings.image -%}
{%- assign fs_sig = section.settings.signature -%}

<section class="fs-{{ section.id }}">
  <div class="fs__wrap">
    <div class="fs__band">

      <div class="fs__polaroid">
        <div class="fs__photo">
          {%- if fs_photo != blank -%}
            <img src="{{ fs_photo | image_url: width: 580 }}" alt="{{ fs_photo.alt | default: section.settings.caption_1 | escape }}" loading="lazy">
          {%- else -%}
            <img src="{{ 'founder-selfie.png' | asset_url }}" alt="{{ section.settings.caption_1 | escape }}" loading="lazy">
          {%- endif -%}
        </div>
        {%- if section.settings.caption_1 != blank -%}<div class="fs__cap1">{{ section.settings.caption_1 }}</div>{%- endif -%}
        {%- if section.settings.caption_2 != blank -%}<div class="fs__cap2">{{ section.settings.caption_2 }}</div>{%- endif -%}
      </div>

      <div class="fs__text">
        <span class="fs__quote" aria-hidden="true">&ldquo;</span>
        {%- if section.settings.headline != blank -%}<h2 class="fs__headline">{{ section.settings.headline }}</h2>{%- endif -%}
        {%- if section.settings.paragraph_1 != blank -%}<p class="fs__p">{{ section.settings.paragraph_1 }}</p>{%- endif -%}
        {%- if section.settings.paragraph_2 != blank -%}<p class="fs__p">{{ section.settings.paragraph_2 }}</p>{%- endif -%}

        <div class="fs__stats">
          {%- if section.settings.stat1_number != blank -%}
            <div class="fs__stat"><div class="fs__stat-num">{{ section.settings.stat1_number }}</div><div class="fs__stat-label">{{ section.settings.stat1_label }}</div></div>
          {%- endif -%}
          {%- if section.settings.stat2_number != blank -%}
            <div class="fs__stat"><div class="fs__stat-num">{{ section.settings.stat2_number }}</div><div class="fs__stat-label">{{ section.settings.stat2_label }}</div></div>
          {%- endif -%}
          {%- if section.settings.stat3_number != blank -%}
            <div class="fs__stat"><div class="fs__stat-num">{{ section.settings.stat3_number }}</div><div class="fs__stat-label">{{ section.settings.stat3_label }}</div></div>
          {%- endif -%}
        </div>

        {%- if fs_sig != blank -%}
          <img class="fs__sig" src="{{ fs_sig | image_url: width: 220 }}" alt="{{ section.settings.founder_name | escape }} signature" loading="lazy">
        {%- else -%}
          <img class="fs__sig" src="{{ 'rc-signature.png' | asset_url }}" alt="{{ section.settings.founder_name | escape }} signature" loading="lazy">
        {%- endif -%}
        <div class="fs__name-row">
          {%- if section.settings.founder_name != blank -%}<span class="fs__name">{{ section.settings.founder_name }}</span>{%- endif -%}
          <span class="fs__dot" aria-hidden="true"></span>
          {%- if section.settings.founder_title != blank -%}<span class="fs__attr">{{ section.settings.founder_title }}</span>{%- endif -%}
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Founder Story V2",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Photo" },
    { "type": "image_picker", "id": "image", "label": "Founder photo", "info": "Defaults to the bundled founder selfie." },
    { "type": "text", "id": "caption_1", "label": "Photo caption (line 1)", "default": "RC & Mom · 2019" },
    { "type": "text", "id": "caption_2", "label": "Photo caption (line 2)", "default": "Founders of Rejuvia" },
    { "type": "header", "content": "Story" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Built for my mom. Now for everyone." },
    { "type": "textarea", "id": "paragraph_1", "label": "Paragraph 1", "default": "She was 55, going through menopause, and couldn't sleep — she'd tried everything and nothing helped. So at the University of Pennsylvania we built an oral sleep spray with 13 natural ingredients that absorbs under your tongue and works in minutes, not hours." },
    { "type": "textarea", "id": "paragraph_2", "label": "Paragraph 2", "default": "We just wanted to fix her sleep so she could be herself again. Five years later, it's the nightly ritual for over 300,000 people — and it all started with my mom." },
    { "type": "header", "content": "Stats" },
    { "type": "text", "id": "stat1_number", "label": "Stat 1 number", "default": "100%" },
    { "type": "text", "id": "stat1_label", "label": "Stat 1 label", "default": "Made in the USA" },
    { "type": "text", "id": "stat2_number", "label": "Stat 2 number", "default": "8 yrs" },
    { "type": "text", "id": "stat2_label", "label": "Stat 2 label", "default": "Family business" },
    { "type": "text", "id": "stat3_number", "label": "Stat 3 number", "default": "300K+" },
    { "type": "text", "id": "stat3_label", "label": "Stat 3 label", "default": "Customers nationwide" },
    { "type": "header", "content": "Signature" },
    { "type": "image_picker", "id": "signature", "label": "Signature image", "info": "Transparent PNG. Defaults to the bundled RC signature." },
    { "type": "text", "id": "founder_name", "label": "Founder name", "default": "RC Williams" },
    { "type": "text", "id": "founder_title", "label": "Founder title", "default": "Co-Founder, CEO of Rejuvia" },
    { "type": "header", "content": "Text sizes (desktop)" },
    { "type": "range", "id": "headline_size", "min": 18, "max": 56, "step": 1, "unit": "px", "label": "Headline", "default": 30 },
    { "type": "range", "id": "body_size", "min": 12, "max": 28, "step": 1, "unit": "px", "label": "Body paragraphs", "default": 18 },
    { "type": "range", "id": "stat_num_size", "min": 14, "max": 44, "step": 1, "unit": "px", "label": "Stat numbers", "default": 28 },
    { "type": "range", "id": "stat_label_size", "min": 10, "max": 22, "step": 1, "unit": "px", "label": "Stat labels", "default": 14 },
    { "type": "range", "id": "name_size", "min": 12, "max": 28, "step": 1, "unit": "px", "label": "Founder name", "default": 19 },
    { "type": "range", "id": "title_size", "min": 10, "max": 24, "step": 1, "unit": "px", "label": "Founder title", "default": 15 },
    { "type": "header", "content": "Text sizes (mobile)" },
    { "type": "range", "id": "headline_size_mobile", "min": 16, "max": 40, "step": 1, "unit": "px", "label": "Headline", "default": 22 },
    { "type": "range", "id": "body_size_mobile", "min": 11, "max": 24, "step": 1, "unit": "px", "label": "Body paragraphs", "default": 15 },
    { "type": "range", "id": "stat_num_size_mobile", "min": 12, "max": 36, "step": 1, "unit": "px", "label": "Stat numbers", "default": 20 },
    { "type": "range", "id": "stat_label_size_mobile", "min": 9, "max": 20, "step": 1, "unit": "px", "label": "Stat labels", "default": 12 },
    { "type": "range", "id": "name_size_mobile", "min": 11, "max": 24, "step": 1, "unit": "px", "label": "Founder name", "default": 16 },
    { "type": "range", "id": "title_size_mobile", "min": 9, "max": 20, "step": 1, "unit": "px", "label": "Founder title", "default": 13 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_bg", "label": "Section background (outside the band)", "default": "#672666" },
    { "type": "color", "id": "card_bg", "label": "Band background", "default": "#ffffff" },
    { "type": "color", "id": "image_shadow_color", "label": "Photo shadow color", "default": "#2a0e2a" }
  ],
  "presets": [
    { "name": "Founder Story V2", "category": "Rejuvia" }
  ]
}
{% endschema %}
