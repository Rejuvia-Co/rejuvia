{% style %}
.guarantees-v2-section {
    width: 100%;
    background-color: {{ section.settings.bg_color }};
}

.guarantees-v2-container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 100px;
    padding: 16px 32px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.guarantees-v2-item {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
}

.guarantees-v2-icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
}

.guarantees-v2-text {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
    white-space: nowrap;
}

@media (max-width: 900px) {
    .guarantees-v2-container {
        justify-content: flex-start;
        gap: 40px;
        padding: 16px 16px;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
    }
    .guarantees-v2-container::-webkit-scrollbar {
        display: none;
    }
    .guarantees-v2-icon {
        width: 20px;
        height: 20px;
    }
    .guarantees-v2-text {
        font-size: 14px;
    }
}
{% endstyle %}

<div class="guarantees-v2-container"{% if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id }}"{% endif %}>
    {% for block in section.blocks %}
        <div class="guarantees-v2-item" {{ block.shopify_attributes }}>
            <svg class="guarantees-v2-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 22 22" fill="none">
                <circle cx="11" cy="11" r="11" fill="{{ section.settings.icon_color }}"/>
                <path d="M6.5 11.5L9.5 14.5L15.5 8.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="guarantees-v2-text">{{ block.settings.text }}</span>
        </div>
    {% endfor %}
</div>

{% schema %}
{
    "name": "Guarantees V2",
    "class": "guarantees-v2-section",
    "settings": [
        {
            "type": "text",
            "id": "anchor_id",
            "label": "Anchor ID",
            "info": "Optional. Used with hero nav links."
        },
        {
            "type": "color",
            "id": "bg_color",
            "label": "Background color",
            "default": "#EAEAF7"
        },
        {
            "type": "color",
            "id": "icon_color",
            "label": "Icon color",
            "default": "#672666"
        }
    ],
    "blocks": [
        {
            "type": "guarantee",
            "name": "Guarantee",
            "settings": [
                {
                    "type": "text",
                    "id": "text",
                    "label": "Text",
                    "default": "5,000+ 5-Star Reviews"
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Guarantees V2",
            "category": "Custom",
            "blocks": [
                {
                    "type": "guarantee",
                    "settings": { "text": "5,000+ 5-Star Reviews" }
                },
                {
                    "type": "guarantee",
                    "settings": { "text": "Free US Shipping over $79" }
                },
                {
                    "type": "guarantee",
                    "settings": { "text": "150,000+ Happy Customers" }
                }
            ]
        }
    ]
}
{% endschema %}
