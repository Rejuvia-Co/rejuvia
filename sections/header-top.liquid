{% style %}
  .announcement-bar {
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
    padding: 0 32px;
    padding-top: 16px;
    box-sizing: border-box;
  }

  .announcement-bar__inner {
    background: #FFFFFF;
    border-radius: 10px;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0px 3px 16px -3px rgba(0, 0, 0, 0.06);
    padding: 12px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    overflow: hidden;
    position: relative;
  }

  .announcement-bar__dot {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
  }

  .announcement-bar__dot svg {
    width: 44px;
    height: 40px;
    display: block;
  }

  .announcement-bar__dot--prev svg {
    transform: rotate(180deg);
  }

  .announcement-bar__slides {
    flex: 1;
    overflow: hidden;
    position: relative;
    min-height: 20px;
  }

  .announcement-bar__slide {
    text-align: center;
    width: 100%;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }

  .announcement-bar__slide.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    position: relative;
  }

  .announcement-bar__slide p {
    margin: 0;
    font-size: 14px;
    line-height: 1.4;
    color: #141414;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }

  .announcement-bar__slide p a {
    color: #141414;
    font-weight: 700;
    text-decoration: underline;
  }

  .announcement-bar__slide p strong {
    font-weight: 700;
    text-decoration: underline;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .announcement-bar {
      padding: 0;
      padding-top: 0;
    }

    .announcement-bar__inner {
      border-radius: 0;
      padding: 12px 16px;
      box-shadow: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }

    .announcement-bar__dot {
      display: none;
    }

    .announcement-bar__slide p {
      font-size: 12px;
    }
  }
{% endstyle %}

<div class="announcement-bar" data-announcement-bar>
  {%- assign slide_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'utility_bar' and block.settings.show -%}
      {%- assign slide_count = slide_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  <div class="announcement-bar__inner">
    <button class="announcement-bar__dot announcement-bar__dot--prev" aria-label="Previous announcement" data-announcement-prev>
      <svg width="44" height="40" viewBox="0 0 44 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M25.3 8.5C25.3 8.5 28 14.2 32 17.5C36 20.8 42 22 42 22" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <path d="M22 2C22 2 22 12 22 20C22 28 22 38 22 38" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <path d="M18.7 8.5C18.7 8.5 16 14.2 12 17.5C8 20.8 2 22 2 22" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <path d="M25.3 31.5C25.3 31.5 28 25.8 32 22.5C36 19.2 42 18 42 18" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <path d="M18.7 31.5C18.7 31.5 16 25.8 12 22.5C8 19.2 2 18 2 18" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <circle cx="22" cy="20" r="2" fill="#141414" opacity="0.3"/>
      </svg>
    </button>

    <div class="announcement-bar__slides">
      {%- assign slide_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'utility_bar' and block.settings.show -%}
          <div class="announcement-bar__slide{% if slide_index == 0 %} is-active{% endif %}" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>
          {%- assign slide_index = slide_index | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    <button class="announcement-bar__dot announcement-bar__dot--next" aria-label="Next announcement" data-announcement-next>
      <svg width="44" height="40" viewBox="0 0 44 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M25.3 8.5C25.3 8.5 28 14.2 32 17.5C36 20.8 42 22 42 22" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <path d="M22 2C22 2 22 12 22 20C22 28 22 38 22 38" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <path d="M18.7 8.5C18.7 8.5 16 14.2 12 17.5C8 20.8 2 22 2 22" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <path d="M25.3 31.5C25.3 31.5 28 25.8 32 22.5C36 19.2 42 18 42 18" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <path d="M18.7 31.5C18.7 31.5 16 25.8 12 22.5C8 19.2 2 18 2 18" stroke="#141414" stroke-width="0.8" stroke-linecap="round" opacity="0.3"/>
        <circle cx="22" cy="20" r="2" fill="#141414" opacity="0.3"/>
      </svg>
    </button>
  </div>
</div>

<script>
  (function() {
    var bar = document.querySelector('[data-announcement-bar]');
    if (!bar) return;

    var slides = bar.querySelectorAll('.announcement-bar__slide');
    if (slides.length < 2) return;

    var current = 0;
    var total = slides.length;
    var speed = {{ section.settings.carousel_speed | default: 5 }} * 1000;
    var autoplayEnabled = {{ section.settings.enable_carousel | default: true }};
    var timer = null;

    function goTo(index) {
      slides[current].classList.remove('is-active');
      current = (index + total) % total;
      slides[current].classList.add('is-active');
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function startAutoplay() {
      if (!autoplayEnabled || total < 2) return;
      stopAutoplay();
      timer = setInterval(next, speed);
    }

    function stopAutoplay() {
      if (timer) { clearInterval(timer); timer = null; }
    }

    var prevBtn = bar.querySelector('[data-announcement-prev]');
    var nextBtn = bar.querySelector('[data-announcement-next]');

    if (prevBtn) {
      prevBtn.addEventListener('click', function() {
        prev();
        stopAutoplay();
        startAutoplay();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        next();
        stopAutoplay();
        startAutoplay();
      });
    }

    startAutoplay();
  })();
</script>

{% schema %}
  {
    "name": "Announcement Bar",
    "presets": [
      {
        "name": "Announcement Bar",
        "category": "Header"
      }
    ],
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_carousel",
        "label": "Enable auto-rotate",
        "default": true
      },
      {
        "type": "range",
        "id": "carousel_speed",
        "label": "Auto-rotate interval (seconds)",
        "min": 3,
        "max": 10,
        "step": 1,
        "default": 5,
        "unit": "s"
      }
    ],
    "blocks": [
      {
        "type": "utility_bar",
        "name": "Announcement Slide",
        "settings": [
          {
            "type": "checkbox",
            "id": "show",
            "label": "Show this slide?",
            "default": true
          },
          {
            "type": "richtext",
            "id": "text",
            "label": "Announcement text",
            "default": "<p>Get 53% OFF Today – <strong>Shop Sleep Spray 6-Pack</strong></p>"
          }
        ]
      }
    ]
  }
{% endschema %}
