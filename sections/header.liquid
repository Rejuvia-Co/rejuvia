<style>
  /* ===== Header Nav V2 ===== */
  html, body { overflow: visible !important; overflow-x: hidden; }
  #page > header { z-index: 110; }

  .main-header {
    background: transparent;
  }


  #header.header {
    background: transparent;
    border: none;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    margin-bottom: -10px;
    padding: 12px 32px 24px;
    box-sizing: border-box;
    position: sticky;
    top: 0;
    z-index: 110;
    pointer-events: none;
  }



  #header .main-content {
    background: #EAEAF7;
    border-radius: 10px;
    box-shadow: 0px 3px 16px -3px rgba(0, 0, 0, 0.06);
    padding: 12px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
  }


  /* Logo */
  #header .logo {
    flex-shrink: 0;
    width: auto;
    max-width: none;
    margin: 0;
    line-height: 0;
  }

  #header .logo .logo-rejuvia-svg {
    width: 164px;
    height: 20px;
    display: block;
  }

  #header .logo .logo-rejuvia-svg path {
    fill: #141414;
  }

  /* Nav links container */
  #header .nav-wrapper {
    width: auto;
    flex: 1;
    display: flex;
    justify-content: center;
  }

  #header .nav-wrapper .utils-wrap {
    display: none;
  }

  /* Menu items */
  #header .main-menu {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0;
  }

  #header .main-menu .item {
    margin: 0;
    border: none;
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    line-height: 1;
    position: relative;
  }

  #header .main-menu .item a {
    display: flex !important;
    align-items: center !important;
    justify-content: center;
    padding: 12px 24px;
    border-radius: 80px;
    color: #141414;
    font-size: 16px;
    font-weight: 400;
    line-height: 1;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    transition: background 0.2s ease, box-shadow 0.2s ease;
    text-decoration: none;
  }

  #header .main-menu .item a:hover {
    color: #141414;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.4);
  }

  #header .main-menu .item.has-dropdown--mega:hover > a,
  #header .main-menu .item.has-dropdown--mega.menu-open > a {
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0px 2px 12px 0px rgba(0, 0, 0, 0.06);
  }

  /* Hide old SVG icons in menu */
  #header .main-menu .item a svg.icon,
  #header .main-menu .item a svg.icon-dropdown {
    display: none !important;
  }

  /* Chevron */
  #header .main-menu .item .nav-chevron {
    display: inline-flex;
    align-items: center;
    margin-left: 6px;
    transition: transform 0.2s ease;
  }

  #header .main-menu .item .nav-chevron svg {
    width: 20px;
    height: 12px;
  }

  #header .main-menu .item.menu-open .nav-chevron {
    transform: rotate(180deg);
  }

  /* Hide old submenus */
  #header .main-menu .has-dropdown .submenu {
    display: none !important;
  }

  /* Right side: account + cart */
  #header .navigator-right {
    width: auto;
    flex-shrink: 0;
  }

  #header .navigator-right .btn {
    display: none;
  }

  .nav-v2-icons {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav-v2-account {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 100px;
    padding: 12px 24px;
    box-shadow: 0px 2px 12px 0px rgba(0, 0, 0, 0.06);
    color: #141414;
    font-size: 16px;
    font-weight: 400;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    line-height: normal;
    height: 44px;
    white-space: nowrap;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .nav-v2-account:hover {
    background: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    color: #141414;
  }

  .nav-v2-account svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .nav-v2-icons .cart-wrap {
    display: flex;
    align-items: center;
  }

  /* Star ratings */
  .mega-menu-v2__card-stars svg path {
    fill: #FAB851;
  }

  /* Trait icons */
  .mega-menu-v2__trait-icon {
    min-width: 20px;
    min-height: 20px;
    display: flex;
    align-items: center;
  }

  .mega-menu-v2__trait-icon svg {
    width: 20px;
    height: 20px;
  }

  /* Hidden utility bar */
  #header .utility-bar {
    display: none;
  }

  .hidden {
    display: none !important;
  }

  .header-open {
    background-color: transparent !important;
  }

  /* ===== Responsive ===== */
  @media all and (max-width: 1200px) {
    #header .main-menu .item a {
      padding: 12px 14px;
    }
  }

  @media all and (max-width: 1099px) {
    #header .main-menu .item a {
      padding: 12px 12px;
    }
  }

  /* ===== Mobile ===== */
  @media all and (max-width: 1024px) {
    #header.header {
      padding: 0 12px 6px;
    }

    #header .main-content {
      display: none;
    }

    #header .navigator-mobile {
      background: #EAEAF7;
      border-radius: 10px;
      box-shadow: 0px 3px 16px -3px rgba(0, 0, 0, 0.06);
      height: 44px;
      padding: 0 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
    }

    #header .navigator-mobile .logo {
      max-width: 110px;
      order: 1;
      flex: 1;
    }

    #header .navigator-mobile .logo .logo-rejuvia-svg {
      height: 14px;
      width: auto;
    }

    #header .navigator-mobile .mobile-right {
      display: flex;
      align-items: center;
    }

    #header .navigator-mobile .eg-close-mobile-div {
      order: 3;
      min-width: auto;
    }

    #header .navigator-mobile .cart-wrap {
      position: relative;
    }

    #header .navigator-mobile .btn-open-mobile-menu {
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 0;
    }

    #header .navigator-mobile .btn-open-mobile-menu svg,
    #header .navigator-mobile .close svg {
      width: 20px;
      height: 20px;
    }

    #menu-mobile { display: block; }
  }
</style>

<div id="header" class="header nav-v2 {{ section.settings.behavior }}-desktop {{ section.settings.behavior_mobile }}-mobile">
    <div class="main-content flex align-items-center justify-content-between">

      <a href="/" class="logo medium-down--hide">
        {% render 'logo-rejuvia' %}
      </a>

      <div class="nav-wrapper medium--hide small--hide">
        <nav class="main-menu flex align-items-center" role="navigation">
          {% render 'mega-menu', menu: section.settings.menu_desktop.links %}
        </nav>
      </div>

      {%- assign total_items = 0 -%}
      {%- for item in cart.items -%}
        {%- assign total_items = total_items | plus: item.quantity -%}
      {%- endfor -%}

      <div class="navigator-mobile flex align-items-center large--hide">
        <div class="mobile-right eg-close-mobile-div">
          <a href="#" class="btn-open-mobile-menu" aria-label="Open menu" role="button">{% render 'icon-hamburger' %}</a>
          <a class="close hidden" aria-label="Close menu" role="button">{% render 'icon-close_button' %}</a>
        </div>
        <a href="/" class="logo large--hide">
          {% render 'logo-rejuvia' %}
        </a>
        <div class="mobile-right">
          <a class="cart-wrap" href="/cart" title="Bag" aria-label="Cart">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M6.66659 18.3333C7.12682 18.3333 7.49992 17.9602 7.49992 17.5C7.49992 17.0397 7.12682 16.6666 6.66659 16.6666C6.20635 16.6666 5.83325 17.0397 5.83325 17.5C5.83325 17.9602 6.20635 18.3333 6.66659 18.3333Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.8333 18.3333C16.2936 18.3333 16.6667 17.9602 16.6667 17.5C16.6667 17.0397 16.2936 16.6666 15.8333 16.6666C15.3731 16.6666 15 17.0397 15 17.5C15 17.9602 15.3731 18.3333 15.8333 18.3333Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M1.7085 1.70837H3.37516L5.59183 12.0584C5.67314 12.4374 5.88405 12.7763 6.18826 13.0166C6.49246 13.2569 6.87092 13.3837 7.2585 13.375H15.4085C15.7878 13.3744 16.1556 13.2444 16.451 13.0066C16.7465 12.7687 16.9519 12.4371 17.0335 12.0667L18.4085 5.87504H4.26683" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>

      <div class="navigator navigator-right flex align-items-center small--hide medium--hide">
        <div class="nav-v2-icons">
          <a class="nav-v2-account" href="{% if customer %}/account{% else %}/a/account/login{% endif %}" title="My Account" aria-label="My Account">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M15 16.6666C15 15.3405 14.4732 14.0688 13.5355 13.1311C12.5979 12.1934 11.3261 11.6666 10 11.6666C8.67392 11.6666 7.40215 12.1934 6.46447 13.1311C5.52678 14.0688 5 15.3405 5 16.6666" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10.0001 11.6667C11.841 11.6667 13.3334 10.1743 13.3334 8.33333C13.3334 6.49238 11.841 5 10.0001 5C8.15913 5 6.66675 6.49238 6.66675 8.33333C6.66675 10.1743 8.15913 11.6667 10.0001 11.6667Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M10.0001 18.3333C14.6025 18.3333 18.3334 14.6023 18.3334 9.99996C18.3334 5.39759 14.6025 1.66663 10.0001 1.66663C5.39771 1.66663 1.66675 5.39759 1.66675 9.99996C1.66675 14.6023 5.39771 18.3333 10.0001 18.3333Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Account Log In
          </a>
          <a class="flex cart-wrap" href="/cart" title="Bag" aria-label="Cart">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M6.66659 18.3333C7.12682 18.3333 7.49992 17.9602 7.49992 17.5C7.49992 17.0397 7.12682 16.6666 6.66659 16.6666C6.20635 16.6666 5.83325 17.0397 5.83325 17.5C5.83325 17.9602 6.20635 18.3333 6.66659 18.3333Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15.8333 18.3333C16.2936 18.3333 16.6667 17.9602 16.6667 17.5C16.6667 17.0397 16.2936 16.6666 15.8333 16.6666C15.3731 16.6666 15 17.0397 15 17.5C15 17.9602 15.3731 18.3333 15.8333 18.3333Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M1.7085 1.70837H3.37516L5.59183 12.0584C5.67314 12.4374 5.88405 12.7763 6.18826 13.0166C6.49246 13.2569 6.87092 13.3837 7.2585 13.375H15.4085C15.7878 13.3744 16.1556 13.2444 16.451 13.0066C16.7465 12.7687 16.9519 12.4371 17.0335 12.0667L18.4085 5.87504H4.26683" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>

      {%- include 'menu_mobile' -%}
    </div>

    {% for block in section.blocks %}
      {% if block.type == 'mega_menu' %}
    <div class="menu-desktop menu-desktop-v2 hidden" data-menu-handle="{{ block.settings.menu_item_handle }}" {{ block.shopify_attributes }}>
      <div class="mega-menu-v2__products">
        {%- assign product_fields = 'product_1,product_2,product_3,product_4,product_5' | split: ',' -%}
        {%- assign desc_fields = 'product_1_desc,product_2_desc,product_3_desc,product_4_desc,product_5_desc' | split: ',' -%}
        {%- for i in (0..4) -%}
          {%- assign prod_field = product_fields[i] -%}
          {%- assign desc_field = desc_fields[i] -%}
          {%- if block.settings[prod_field] != blank -%}
            {%- assign product = all_products[block.settings[prod_field]] -%}
            <a href="{{ product.url }}" class="mega-menu-v2__card">
              <div class="mega-menu-v2__card-image">
                <img
                  src="{{ product.featured_image | img_url: '300x' }}"
                  alt="{{ product.title }}"
                  loading="lazy"
                  width="175"
                  height="175"
                />
              </div>
              <div class="mega-menu-v2__card-content">
                <div class="mega-menu-v2__card-rating">
                  <div class="mega-menu-v2__card-stars">
                    {% render 'icon-star-rating' %}
                    {% render 'icon-star-rating' %}
                    {% render 'icon-star-rating' %}
                    {% render 'icon-star-rating' %}
                    {% render 'icon-star-rating' %}
                  </div>
                  <span class="mega-menu-v2__card-rating-text">
                    <strong>{% if product.metafields.okendo.summaryData.reviewCount > 0 %}{{ product.metafields.okendo.summaryData.reviewAverageValue | round: 1 }}{% else %}5.0{% endif %}</strong>&nbsp;<span class="mega-menu-v2__card-rating-count">({% if product.metafields.okendo.summaryData.reviewCount > 0 %}{{ product.metafields.okendo.summaryData.reviewCount | append: ' Reviews' }}{% else %}Reviews{% endif %})</span>
                  </span>
                </div>
                <h3 class="mega-menu-v2__card-title">{{ product.title }}</h3>
                <p class="mega-menu-v2__card-desc">{{ block.settings[desc_field] }}</p>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="mega-menu-v2__traits">
        {% if block.settings.benefit_1_text != blank %}
        <div class="mega-menu-v2__trait">
          <span class="mega-menu-v2__trait-icon">{% render 'icon-benefit-shipping' %}</span>
          <span class="mega-menu-v2__trait-label">{{ block.settings.benefit_1_text }}</span>
        </div>
        {% endif %}
        {% if block.settings.benefit_2_text != blank %}
        <div class="mega-menu-v2__trait">
          <span class="mega-menu-v2__trait-icon">{% render 'icon-benefit-reviews' %}</span>
          <span class="mega-menu-v2__trait-label">{{ block.settings.benefit_2_text }}</span>
        </div>
        {% endif %}
        {% if block.settings.benefit_3_text != blank %}
        <div class="mega-menu-v2__trait">
          <span class="mega-menu-v2__trait-icon">{% render 'icon-benefit-family' %}</span>
          <span class="mega-menu-v2__trait-label">{{ block.settings.benefit_3_text }}</span>
        </div>
        {% endif %}
      </div>
    </div>
      {% endif %}
    {% endfor %}
</div>

<script>
  (function() {
    var header = document.getElementById('header');
    if (!header) return;

    var oldScrollY = 0;
    var ticking = false;

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function() {
        var scrollY = window.scrollY;
        if (scrollY > 1) {
          header.classList.add('is-ticky');
        } else {
          header.classList.remove('is-ticky');
        }
        if (oldScrollY > scrollY) {
          document.body.classList.add('sticky-header');
        } else {
          document.body.classList.remove('sticky-header');
        }
        oldScrollY = scrollY;
        ticking = false;
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    header.classList.remove('fixed-pending');
  })();
</script>

{% schema %}
  {
    "name": "Header",
    "class": "main-header",
    "settings": [
      {
        "type": "link_list",
        "id": "menu_desktop",
        "label": "Navigation Menu"
      },
      {
        "type": "header",
        "content": "Desktop"
      },
      {
        "type": "select",
        "id": "behavior",
        "label": "Behavior",
        "options": [
          { "value": "static", "label": "Static" },
          { "value": "fixed", "label": "Fixed" }
        ],
        "default": "static"
      },
      {
        "type": "header",
        "content": "Mobile"
      },
      {
        "type": "select",
        "id": "behavior_mobile",
        "label": "Behavior (Mobile)",
        "options": [
          { "value": "static", "label": "Static" },
          { "value": "fixed", "label": "Fixed" }
        ],
        "default": "static"
      }
    ],
    "blocks": [
      {
        "type": "mega_menu",
        "name": "Mega Menu",
        "limit": 3,
        "settings": [
          {
            "type": "text",
            "id": "menu_item_handle",
            "label": "Menu item handle",
            "info": "Handle of the nav link this mega menu belongs to (e.g. 'products')"
          },
          {
            "type": "header",
            "content": "Products"
          },
          { "type": "product", "id": "product_1", "label": "Product 1" },
          { "type": "text", "id": "product_1_desc", "label": "Product 1 description" },
          { "type": "product", "id": "product_2", "label": "Product 2" },
          { "type": "text", "id": "product_2_desc", "label": "Product 2 description" },
          { "type": "product", "id": "product_3", "label": "Product 3" },
          { "type": "text", "id": "product_3_desc", "label": "Product 3 description" },
          { "type": "product", "id": "product_4", "label": "Product 4" },
          { "type": "text", "id": "product_4_desc", "label": "Product 4 description" },
          { "type": "product", "id": "product_5", "label": "Product 5" },
          { "type": "text", "id": "product_5_desc", "label": "Product 5 description" },
          {
            "type": "header",
            "content": "Footer Benefits"
          },
          { "type": "text", "id": "benefit_1_text", "label": "Benefit 1 text", "default": "Free Same-Day Shipping" },
          { "type": "text", "id": "benefit_2_text", "label": "Benefit 2 text", "default": "3,000+ 5-Star Reviews" },
          { "type": "text", "id": "benefit_3_text", "label": "Benefit 3 text", "default": "Family-Founded Brand" }
        ]
      },
      {
        "type": "mobile-menu-links",
        "name": "Mobile Menu Links",
        "limit": 1,
        "settings": [
          { "type": "text", "id": "first_label", "label": "Link 1 Label" },
          { "type": "url", "id": "first_url", "label": "Link 1 URL" },
          { "type": "text", "id": "second_label", "label": "Link 2 Label" },
          { "type": "url", "id": "second_url", "label": "Link 2 URL" },
          { "type": "text", "id": "third_label", "label": "Link 3 Label" },
          { "type": "url", "id": "third_url", "label": "Link 3 URL" },
          { "type": "text", "id": "fourth_label", "label": "Link 4 Label" },
          { "type": "url", "id": "fourth_url", "label": "Link 4 URL" }
        ]
      }
    ]
  }
{% endschema %}
