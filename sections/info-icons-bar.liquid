{% style %}
  .info-icons-bar.section-{{ section.id }} {
    background: {{ section.settings.bg_color | default: '#eaeaf7' }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .info-icons-bar.section-{{ section.id }} .info-icons-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 100px;
    padding-left: 64px;
    padding-right: 64px;
    margin: 0 auto;
    max-width: 1440px;
    width: 100%;
    box-sizing: border-box;
    flex-wrap: wrap;
  }

  .info-icons-bar.section-{{ section.id }} .info-icons-bar__item {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .info-icons-bar.section-{{ section.id }} .info-icons-bar__icon {
    width: 22px;
    height: 22px;
    display: block;
    flex-shrink: 0;
  }

  .info-icons-bar.section-{{ section.id }} .info-icons-bar__text {
    margin: 0;
    color: {{ section.settings.text_color | default: '#141414' }};
    font-family: "Helvetica Neue", sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    white-space: nowrap;
  }

  @media only screen and (max-width: 999px) {
    .info-icons-bar.section-{{ section.id }} .info-icons-bar__inner {
      gap: 48px;
    }
  }

  @media only screen and (max-width: 749px) {
    .info-icons-bar.section-{{ section.id }} .info-icons-bar__inner {
      gap: 40px;
      padding-left: 16px;
      padding-right: 16px;
      justify-content: flex-start;
    }

    .info-icons-bar.section-{{ section.id }} .info-icons-bar__icon {
      width: 20px;
      height: 20px;
    }

    .info-icons-bar.section-{{ section.id }} .info-icons-bar__text {
      font-size: 14px;
      white-space: normal;
    }
  }
{% endstyle %}

<div class="info-icons-bar section-{{ section.id }}">
  <div class="info-icons-bar__inner">
    {%- for block in section.blocks -%}
      {%- if block.settings.text != blank -%}
        <div class="info-icons-bar__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <img
              src="{{ block.settings.icon | image_url: width: 44 }}"
              srcset="{{ block.settings.icon | image_url: width: 44 }} 1x, {{ block.settings.icon | image_url: width: 88 }} 2x"
              width="22"
              height="22"
              loading="lazy"
              alt="{{ block.settings.text | escape }}"
              class="info-icons-bar__icon">
          {%- else -%}
            {% render 'icon-guarantee-check' %}
          {%- endif -%}
          <p class="info-icons-bar__text">{{ block.settings.text }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Info icons bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#eaeaf7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#141414"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom padding",
      "default": 16
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Icon item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "22x22 px. Leave blank to use default purple checkmark."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "5,000+ 5-Star Reviews"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Info icons bar",
      "category": "Custom",
      "blocks": [
        { "type": "item", "settings": { "text": "5,000+ 5-Star Reviews" } },
        { "type": "item", "settings": { "text": "Free US Shipping over $79" } },
        { "type": "item", "settings": { "text": "150,000+ Happy Customers" } }
      ]
    }
  ]
}
{% endschema %}
