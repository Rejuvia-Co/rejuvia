{{ 'key-ingredients-v2.css' | asset_url | stylesheet_tag }}

{% assign source_product = section.settings.product %}
{% assign base_colour = source_product.metafields.custom.base_colour %}
{% assign ingredients = source_product.metafields.custom.key_ingredients.value %}

{% if ingredients != blank %}
<section class="key-ingredients-v2"{% if base_colour != blank %} style="--base-colour: {{ base_colour }};"{% endif %}>
  <div class="key-ingredients-v2__container">

    <div class="key-ingredients-v2__header">
      <h2 class="key-ingredients-v2__title">{{ section.settings.heading | default: 'The key ingredients' }}</h2>
      {% if section.settings.button_label != blank and source_product != blank %}
        <button type="button" class="key-ingredients-v2__btn key-ingredients-v2__btn--desktop" data-open-supplement-popup>{{ section.settings.button_label }}</button>
      {% endif %}
    </div>

    <div class="key-ingredients-v2__grid">
      {% for ingredient in ingredients %}
        <div class="key-ingredients-v2__card">
          {% if ingredient.image != blank %}
            <div class="key-ingredients-v2__card-image">
              <img src="{{ ingredient.image | image_url: width: 400 }}"
                   alt="{{ ingredient.title | default: 'Ingredient' }}"
                   loading="lazy"
                   width="165"
                   height="165">
            </div>
          {% endif %}
          <div class="key-ingredients-v2__card-content">
            {% if ingredient.title != blank %}
              <h3 class="key-ingredients-v2__card-title">{{ ingredient.title }}</h3>
            {% endif %}
            {% if ingredient.description != blank %}
              <div class="key-ingredients-v2__card-desc">{{ ingredient.description | metafield_tag }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank and source_product != blank %}
      <div class="key-ingredients-v2__mobile-btn">
        <button type="button" class="key-ingredients-v2__btn" data-open-supplement-popup>{{ section.settings.button_label }}</button>
      </div>
    {% endif %}

  </div>
</section>

{% if source_product != blank %}
  {% render 'supplement-label-popup', product: source_product %}
{% endif %}
{% endif %}

{% schema %}
{
  "name": "Key Ingredients Page V2",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Page-template version of Key Ingredients V2. Select a product — ingredients and the supplement label popup are pulled from its metafields (custom.key_ingredients, custom.supplement_label, custom.base_colour)."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Source product",
      "info": "Provides key_ingredients, supplement_label and base_colour."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The key ingredients"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View Supplement Label"
    }
  ],
  "presets": [
    {
      "name": "Key Ingredients Page V2",
      "category": "Custom"
    }
  ]
}
{% endschema %}
