{{ 'key-ingredients-v2.css' | asset_url | stylesheet_tag }}

{% assign currentProduct = product %}
{% assign base_colour = currentProduct.metafields.custom.base_colour %}
{% assign ingredients = currentProduct.metafields.custom.key_ingredients.value %}

{% if ingredients != blank %}
<section class="key-ingredients-v2"{% if base_colour != blank %} style="--base-colour: {{ base_colour }};"{% endif %}>
  <div class="key-ingredients-v2__container">

    <div class="key-ingredients-v2__header">
      <h2 class="key-ingredients-v2__title">{{ section.settings.heading | default: 'The key ingredients' }}</h2>
      {% if section.settings.button_label != blank %}
        {% if section.settings.button_url != blank %}
          <a href="{{ section.settings.button_url }}" class="key-ingredients-v2__btn key-ingredients-v2__btn--desktop">{{ section.settings.button_label }}</a>
        {% else %}
          <span class="key-ingredients-v2__btn key-ingredients-v2__btn--desktop">{{ section.settings.button_label }}</span>
        {% endif %}
      {% endif %}
    </div>

    <div class="key-ingredients-v2__grid">
      {% for ingredient in ingredients %}
        <div class="key-ingredients-v2__card">
          {% if ingredient.image != blank %}
            <div class="key-ingredients-v2__card-image">
              <img src="{{ ingredient.image | image_url: width: 400 }}"
                   alt="{{ ingredient.title | default: 'Ingredient' }}"
                   loading="lazy"
                   width="165"
                   height="165">
            </div>
          {% endif %}
          <div class="key-ingredients-v2__card-content">
            {% if ingredient.title != blank %}
              <h3 class="key-ingredients-v2__card-title">{{ ingredient.title }}</h3>
            {% endif %}
            {% if ingredient.description != blank %}
              <div class="key-ingredients-v2__card-desc">{{ ingredient.description | metafield_tag }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="key-ingredients-v2__mobile-btn">
        {% if section.settings.button_url != blank %}
          <a href="{{ section.settings.button_url }}" class="key-ingredients-v2__btn">{{ section.settings.button_label }}</a>
        {% else %}
          <span class="key-ingredients-v2__btn">{{ section.settings.button_label }}</span>
        {% endif %}
      </div>
    {% endif %}

  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Key Ingredients V2",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Ingredients from product metafield custom.key_ingredients (list of metaobjects with image, title, description). Section hidden when metafield is empty."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The key ingredients"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View Supplement Label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Key Ingredients V2"
    }
  ]
}
{% endschema %}
