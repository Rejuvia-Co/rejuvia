{% style %}
.lfaq {
  background-color: {{ section.settings.bg_color }};
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}
.lfaq__container {
  max-width: 760px;
  margin: 0 auto;
  padding: 56px 24px;
}
.lfaq__title {
  font-family: 'HelveticaNeueL', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  text-align: center;
  font-size: 36px;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: -0.01em;
  color: #141414;
  margin: 0 0 28px;
}
.lfaq__list { border-top: 1px solid rgba(0,0,0,0.1); }
.lfaq__item { border-bottom: 1px solid rgba(0,0,0,0.1); }
.lfaq__q {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 20px 4px;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  font-family: inherit;
  font-size: 17px;
  font-weight: 500;
  line-height: 1.4;
  color: #141414;
}
.lfaq__icon {
  position: relative;
  flex-shrink: 0;
  width: 18px;
  height: 18px;
}
.lfaq__icon::before,
.lfaq__icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  background: {{ section.settings.accent_color }};
  transform: translate(-50%, -50%);
  transition: opacity 0.2s ease, transform 0.2s ease;
}
.lfaq__icon::before { width: 16px; height: 2px; }
.lfaq__icon::after { width: 2px; height: 16px; }
.lfaq__item.is-open .lfaq__icon::after { opacity: 0; transform: translate(-50%, -50%) rotate(90deg); }
.lfaq__a {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
}
.lfaq__item.is-open .lfaq__a { max-height: 600px; }
.lfaq__a-inner {
  padding: 0 4px 22px;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.6;
  color: #5C5C5C;
}
.lfaq__a-inner p { margin: 0 0 12px; }
.lfaq__a-inner p:last-child { margin-bottom: 0; }

@media (max-width: 749px) {
  .lfaq__container { padding: 36px 16px; }
  .lfaq__title { font-size: 28px; margin-bottom: 20px; }
  .lfaq__q { font-size: 16px; padding: 18px 2px; }
}
{% endstyle %}

<section class="lfaq" id="lfaq-{{ section.id }}">
  <div class="lfaq__container">
    {%- if section.settings.heading != blank -%}
      <h2 class="lfaq__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="lfaq__list">
      {%- for block in section.blocks -%}
        <div class="lfaq__item" {{ block.shopify_attributes }}>
          <button class="lfaq__q" type="button" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <span class="lfaq__icon" aria-hidden="true"></span>
          </button>
          <div class="lfaq__a">
            <div class="lfaq__a-inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
(function () {
  var sec = document.getElementById('lfaq-{{ section.id }}');
  if (!sec) return;
  var items = sec.querySelectorAll('.lfaq__item');
  sec.querySelectorAll('.lfaq__q').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var item = btn.closest('.lfaq__item');
      var willOpen = !item.classList.contains('is-open');
      items.forEach(function (i) {
        i.classList.remove('is-open');
        var b = i.querySelector('.lfaq__q');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
      if (willOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Listicle FAQ",
  "tag": "section",
  "max_blocks": 20,
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Toggle icon color", "default": "#672666" }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Question",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Listicle FAQ",
      "category": "Listicle",
      "blocks": [
        { "type": "faq", "settings": { "question": "What if it doesn't work for me?" } },
        { "type": "faq", "settings": { "question": "Will I wake up groggy in the morning?" } },
        { "type": "faq", "settings": { "question": "How fast will I feel Rejuvia working?" } },
        { "type": "faq", "settings": { "question": "Is Rejuvia habit-forming? Will I become dependent on it?" } },
        { "type": "faq", "settings": { "question": "What are the ingredients in Rejuvia?" } },
        { "type": "faq", "settings": { "question": "What flavor is Rejuvia?" } },
        { "type": "faq", "settings": { "question": "Is this a subscription?" } },
        { "type": "faq", "settings": { "question": "How long does one bottle last and when will my order arrive?" } }
      ]
    }
  ]
}
{% endschema %}
