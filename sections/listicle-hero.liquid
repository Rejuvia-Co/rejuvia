{% style %}
.listicle-hero {
  background-color: {{ section.settings.bg_color }};
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

.listicle-hero__container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 48px 24px;
  display: flex;
  align-items: center;
  gap: 56px;
}

.listicle-hero__media {
  flex: 0 0 44%;
  max-width: 44%;
}

.listicle-hero__media-inner {
  background-color: {{ section.settings.image_bg_color }};
  border-radius: 16px;
  overflow: hidden;
}

.listicle-hero__media img {
  display: block;
  width: 100%;
  height: auto;
}

.listicle-hero__content {
  flex: 1 1 auto;
  min-width: 0;
}

.listicle-hero__rating {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
}

.listicle-hero__stars {
  display: inline-flex;
  gap: 2px;
}

.listicle-hero__stars svg {
  width: 19.2px;
  height: 18px;
}

.listicle-hero__eyebrow {
  font-size: 16px;
  font-weight: 500;
  line-height: 1.3;
  color: #141414;
}

.listicle-hero__title {
  font-family: 'HelveticaNeueL', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  font-size: {{ section.settings.heading_size | default: 52 }}px;
  font-weight: 700;
  line-height: 1.08;
  letter-spacing: -0.02em;
  color: #141414;
  margin: 0 0 20px;
}

.listicle-hero__text {
  font-size: {{ section.settings.text_size | default: 19 }}px;
  font-weight: 400;
  line-height: 1.5;
  color: #5C5C5C;
  margin: 0 0 28px;
}

.listicle-hero__text p { margin: 0; }

.listicle-hero__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  width: 100%;
  max-width: 520px;
  padding: 22px 32px;
  background-color: {{ section.settings.accent_color }};
  color: #fff;
  font-size: 18px;
  font-weight: 700;
  line-height: 1;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  text-decoration: none;
  border-radius: 100px;
  transition: opacity 0.2s ease;
}

.listicle-hero__btn:hover { opacity: 0.92; color: #fff; }
.listicle-hero__btn svg { flex-shrink: 0; }

.listicle-hero__guarantee {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 16px;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: #141414;
}

.listicle-hero__guarantee svg { flex-shrink: 0; }

@media (max-width: 900px) {
  .listicle-hero__container {
    flex-direction: column;
    align-items: stretch;
    gap: 28px;
    padding: 28px 16px;
  }
  .listicle-hero__media,
  .listicle-hero__content {
    flex: 1 1 auto;
    max-width: 100%;
  }
  .listicle-hero__title { font-size: {{ section.settings.heading_size | default: 52 | times: 0.65 | round }}px; margin-bottom: 16px; }
  .listicle-hero__text { font-size: {{ section.settings.text_size | default: 19 | times: 0.9 | round }}px; margin-bottom: 22px; }
  .listicle-hero__btn { max-width: 100%; padding: 18px 24px; }
  .listicle-hero__rating { margin-bottom: 14px; }
}
{% endstyle %}

{%- capture gold_star -%}
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 16" fill="none" aria-hidden="true"><path d="M3.85124 15.9392C3.43952 16.1504 2.97233 15.7803 3.05553 15.3078L3.94083 10.2626L0.183091 6.68298C-0.167831 6.34806 0.0145632 5.73581 0.484948 5.66968L5.70931 4.9273L8.03883 0.31199C8.24895 -0.103997 8.81747 -0.103997 9.0276 0.31199L11.3571 4.9273L16.5815 5.66968C17.0519 5.73581 17.2343 6.34806 16.8823 6.68298L13.1256 10.2626L14.0109 15.3078C14.0941 15.7803 13.6269 16.1504 13.2152 15.9392L8.53161 13.5329L3.85124 15.9392Z" fill="{{ section.settings.stars_color }}"/></svg>
{%- endcapture -%}

<section class="listicle-hero">
  <div class="listicle-hero__container">
    {%- if section.settings.image != blank -%}
      <div class="listicle-hero__media">
        <div class="listicle-hero__media-inner">
          <img src="{{ section.settings.image | image_url: width: 1100 }}"
               width="{{ section.settings.image.width }}"
               height="{{ section.settings.image.height }}"
               alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
               loading="eager" fetchpriority="high">
        </div>
      </div>
    {%- endif -%}

    <div class="listicle-hero__content">
      {%- if section.settings.show_stars or section.settings.eyebrow != blank -%}
        <div class="listicle-hero__rating">
          {%- if section.settings.show_stars -%}
            <span class="listicle-hero__stars" aria-label="5 stars">{{ gold_star }}{{ gold_star }}{{ gold_star }}{{ gold_star }}{{ gold_star }}</span>
          {%- endif -%}
          {%- if section.settings.eyebrow != blank -%}
            <span class="listicle-hero__eyebrow">{{ section.settings.eyebrow }}</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="listicle-hero__title">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="listicle-hero__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <a class="listicle-hero__btn" href="{{ section.settings.button_link | default: '#' }}">
          {{ section.settings.button_text }}
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 12h16M14 6l6 6-6 6" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      {%- endif -%}

      {%- if section.settings.guarantee_text != blank -%}
        <div class="listicle-hero__guarantee">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 9a9 9 0 1 1 1.5 5" stroke="#141414" stroke-width="1.6" stroke-linecap="round"/><path d="M3 4v5h5" stroke="#141414" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <span>{{ section.settings.guarantee_text }}</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Listicle Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "checkbox", "id": "show_stars", "label": "Show 5 stars", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "Trusted By 300,000+ Sleepers" },
    { "type": "text", "id": "heading", "label": "Heading (H1)", "default": "5 Reasons Millions Are Ditching Sleeping Pills and Gummies For Rejuvia" },
    { "type": "richtext", "id": "text", "label": "Paragraph", "default": "<p>Fall asleep faster. Stay asleep through the full night. Wake up rested and energized — without the morning hangover from sleeping pills or 10mg melatonin gummies. Here's why 300,000+ sleepers switched to Rejuvia.</p>" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Try Rejuvia Now" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "text", "id": "guarantee_text", "label": "Guarantee text", "default": "90-Day Money Back Guarantee" },
    { "type": "header", "content": "Typography" },
    { "type": "range", "id": "heading_size", "min": 24, "max": 72, "step": 1, "unit": "px", "label": "Heading size", "default": 52 },
    { "type": "range", "id": "text_size", "min": 14, "max": 28, "step": 1, "unit": "px", "label": "Paragraph size", "default": 19 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "image_bg_color", "label": "Image background", "default": "#F8E9EE" },
    { "type": "color", "id": "accent_color", "label": "Button color", "default": "#672666" },
    { "type": "color", "id": "stars_color", "label": "Stars color", "default": "#EAC78B" }
  ],
  "presets": [
    { "name": "Listicle Hero", "category": "Listicle" }
  ]
}
{% endschema %}
