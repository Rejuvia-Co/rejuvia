{{ 'section-rejuvia-sleep-listicle.css' | asset_url | stylesheet_tag }}

<div class="rej-lp">
  <section class="rej-lp__cred">
    <div class="rej-lp__container">
      <p class="rej-lp__cred-quote">{{ section.settings.quote }}</p>
      <div class="rej-lp__cred-logos">
        {%- for block in section.blocks -%}
          <div class="rej-lp__cred-logo" {{ block.shopify_attributes }}>
            {%- if block.settings.logo != blank -%}
              <img src="{{ block.settings.logo | image_url: height: 40 }}" alt="{{ block.settings.name }}" loading="lazy">
            {%- else -%}
              <span class="rej-lp__cred-logo-text">{{ block.settings.name }}</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP - Credibility Bar",
  "tag": "section",
  "class": "lp-cred-section",
  "settings": [
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote Text",
      "default": "\"Rejuvia is not only incredibly effective at night, but it's also 100% safe and made with all-natural ingredients.\""
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo / Publication",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Publication Name",
          "default": "Forbes"
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo Image (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP - Credibility Bar",
      "blocks": [
        { "type": "logo", "settings": { "name": "Forbes" } },
        { "type": "logo", "settings": { "name": "Healthline" } },
        { "type": "logo", "settings": { "name": "Women's Health" } },
        { "type": "logo", "settings": { "name": "FabFitFun" } },
        { "type": "logo", "settings": { "name": "Bustle" } },
        { "type": "logo", "settings": { "name": "ScaryMommy" } }
      ]
    }
  ]
}
{% endschema %}
