{{ 'section-rejuvia-sleep-listicle.css' | asset_url | stylesheet_tag }}

<div class="rej-lp">
  <section class="rej-lp__faq">
    <div class="rej-lp__container">
      <h2 class="rej-lp__section-heading">{{ section.settings.heading }}</h2>
      <div class="rej-lp__faq-list">
        {%- for block in section.blocks -%}
          <details class="rej-lp__faq-item" {{ block.shopify_attributes }}>
            <summary class="rej-lp__faq-question">{{ block.settings.question }}</summary>
            <div class="rej-lp__faq-answer rte">
              {{ block.settings.answer }}
            </div>
          </details>
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP - FAQ",
  "tag": "section",
  "class": "lp-faq-section",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Section Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What are the ingredients in Rejuvia?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Rejuvia contains 13+ all-natural sleep ingredients including Passionflower, Hops Flower Head, Organic Feverfew Leaf, Melatonin (2.0mg), 5-HTP, Peppermint Leaf, Valerian Root, Lemon Balm, Magnolia, Chamomile, Cramp Bark, Gingko Biloba Extract, Skullcap Root, and Natural Peppermint Flavor.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP - FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "What are the ingredients in Rejuvia?",
            "answer": "<p>Rejuvia contains 13+ all-natural sleep ingredients including Passionflower, Hops Flower Head, Organic Feverfew Leaf, Melatonin (2.0mg), 5-HTP, Peppermint Leaf, Valerian Root, Lemon Balm, Magnolia, Chamomile, Cramp Bark, Gingko Biloba Extract, Skullcap Root, and Natural Peppermint Flavor.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How long does one spray last?",
            "answer": "<p>Each Rejuvia Sleep Spray bottle lasts approximately 30-35 days with nightly use (6-8 sprays per night).</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Will Rejuvia make me feel groggy?",
            "answer": "<p>No. Unlike sleeping pills and many gummies, Rejuvia is made with 100% natural ingredients that work with your body's natural sleep processes. You'll wake up feeling refreshed and clear-headed, not groggy or drugged.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is Rejuvia safe to use long-term?",
            "answer": "<p>Yes. Rejuvia is completely drug-free and non-habit forming, so it can be used nightly without worrying about dependency or withdrawal. It does not build tolerance over time.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How do I use the sleep spray?",
            "answer": "<p>Spray 6-8 times under your tongue or on the inside of your cheek about 15-20 minutes before bed, then swallow. The spray has a delicious, all-natural mint flavor.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What is Rejuvia's return policy?",
            "answer": "<p>Your first Rejuvia order is covered by our 90-day money-back guarantee. If it doesn't work for you, just send us an email and we'll personally refund you — no questions asked.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
