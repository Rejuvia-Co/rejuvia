{{ 'section-rejuvia-sleep-listicle.css' | asset_url | stylesheet_tag }}

<div class="rej-lp">
  <section class="rej-lp__hero">
    <div class="rej-lp__container rej-lp__hero-grid">
      <div class="rej-lp__hero-content">
        <p class="rej-lp__eyebrow">{{ section.settings.eyebrow }}</p>
        <h1 class="rej-lp__hero-heading">{{ section.settings.heading }}</h1>
        <p class="rej-lp__hero-sub">{{ section.settings.subheading }}</p>
        <div class="rej-lp__stars">
          <span class="rej-lp__stars-icons">★★★★★</span>
          <span class="rej-lp__stars-text">{{ section.settings.rating_text }}</span>
        </div>
        <a href="{{ section.settings.cta_link }}" class="rej-lp__btn rej-lp__btn--primary">{{ section.settings.cta_text }}</a>
      </div>
      <div class="rej-lp__hero-media">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | default: 'Rejuvia Sleep Spray' }}"
            loading="eager"
            width="800"
            height="{{ 800 | divided_by: section.settings.image.aspect_ratio | round }}"
            class="rej-lp__hero-img"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'rej-lp__hero-placeholder' }}
        {%- endif -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP - Hero",
  "tag": "section",
  "class": "lp-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "★★★★★ Used Nightly By 300,000+ Sleepers"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "5 Reasons Why 300,000+ Adults Are Ditching Pills For This Sleep Spray"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Thousands of adults who have tried everything to help them sleep at night have finally found an all-natural solution. It helps you fall asleep 3x faster, sleep through the full night, and wake up refreshed — not groggy."
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "4.6 | 6,020+ Reviews"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "default": "TRY REJUVIA RISK-FREE →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "presets": [
    {
      "name": "LP - Hero"
    }
  ]
}
{% endschema %}
