{{ 'section-rejuvia-sleep-listicle.css' | asset_url | stylesheet_tag }}

{%- assign reversed_class = '' -%}
{%- if section.settings.reverse_layout -%}
  {%- assign reversed_class = ' rej-lp__item--reversed' -%}
{%- endif -%}

{%- assign bg_class = '' -%}
{%- if section.settings.alt_background -%}
  {%- assign bg_class = ' rej-lp__item--alt' -%}
{%- endif -%}

<div class="rej-lp">
  <section class="rej-lp__item{{ reversed_class }}{{ bg_class }}" style="{% if section.settings.alt_background %}background:#faf9f7;{% else %}background:#fff;{% endif %}">
    <div class="rej-lp__container rej-lp__item-grid">
      <div class="rej-lp__item-media">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 700 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            loading="lazy"
            width="700"
            height="{{ 700 | divided_by: section.settings.image.aspect_ratio | round }}"
            class="rej-lp__item-img"
          >
        {%- else -%}
          {{ 'product-2' | placeholder_svg_tag: 'rej-lp__item-img' }}
        {%- endif -%}
      </div>
      <div class="rej-lp__item-content">
        <span class="rej-lp__item-number">{{ section.settings.number }}</span>
        <h3 class="rej-lp__item-heading">{{ section.settings.heading }}</h3>
        <div class="rej-lp__item-body rte">
          {{ section.settings.body }}
        </div>
        {%- if section.settings.show_cta -%}
          <a href="{{ section.settings.cta_link }}" class="rej-lp__btn rej-lp__btn--primary">{{ section.settings.cta_text }}</a>
        {%- endif -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP - Listicle Item",
  "tag": "section",
  "class": "lp-listicle-item-section",
  "settings": [
    {
      "type": "text",
      "id": "number",
      "label": "Item Number",
      "default": "1"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "A Totally New Take on Sleep"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text",
      "default": "<p>Unlike pills and gummies that travel through your digestive system, Rejuvia is an oral spray that absorbs directly under your tongue. It bypasses your liver and digestive tract entirely, delivering 13 natural sleep ingredients straight into your bloodstream in minutes — not hours.</p><p>That's why most customers fall asleep in just 10-15 minutes after using Rejuvia.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "checkbox",
      "id": "reverse_layout",
      "label": "Reverse Layout (image on right)",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "alt_background",
      "label": "Use Alternate Background",
      "default": false
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA Button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Try Rejuvia Risk-Free →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    }
  ],
  "presets": [
    {
      "name": "LP - Listicle Item"
    }
  ]
}
{% endschema %}
