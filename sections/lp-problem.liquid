{{ 'section-rejuvia-sleep-listicle.css' | asset_url | stylesheet_tag }}

<div class="rej-lp">
  <section class="rej-lp__problem">
    <div class="rej-lp__container rej-lp__problem-inner">
      <h2 class="rej-lp__section-heading">{{ section.settings.heading }}</h2>
      <div class="rej-lp__problem-body rte">
        {{ section.settings.body }}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP - Problem",
  "tag": "section",
  "class": "lp-problem-section",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "If You've Tried Everything For Sleep, You Need to Read This."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text",
      "default": "<p>Gummies. Melatonin. Sleeping pills. Ambien. Teas. Meditation. Yoga. Aromatherapy. Sound familiar?</p><p>If you've cycled through every sleep remedy on the shelf and still can't fall asleep, stay asleep, or wake up without feeling like you got hit by a truck — you're not alone. And you're not broken.</p><p>There's a reason none of those worked. They all rely on the same slow, inefficient delivery through your digestive system. By the time they kick in (if they kick in), you've already been staring at the ceiling for an hour.</p><p>Rejuvia takes a completely different approach — and that's exactly why it works.</p>"
    }
  ],
  "presets": [
    {
      "name": "LP - Problem"
    }
  ]
}
{% endschema %}
