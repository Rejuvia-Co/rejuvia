{{ 'section-rejuvia-sleep-listicle.css' | asset_url | stylesheet_tag }}

<div class="rej-lp">
  <section class="rej-lp__reviews">
    <div class="rej-lp__container">
      <h2 class="rej-lp__section-heading">{{ section.settings.heading }}</h2>
      <div class="rej-lp__reviews-grid">
        {%- for block in section.blocks -%}
          <div class="rej-lp__review-card" {{ block.shopify_attributes }}>
            <div class="rej-lp__review-stars">★★★★★</div>
            <h4 class="rej-lp__review-title">{{ block.settings.title }}</h4>
            <p class="rej-lp__review-quote">"{{ block.settings.quote }}"</p>
            <p class="rej-lp__review-author">{{ block.settings.author }}</p>
            {%- if block.settings.verified -%}
              <span class="rej-lp__review-verified">✓ Verified Buyer</span>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "LP - Reviews",
  "tag": "section",
  "class": "lp-reviews-section",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Section Heading",
      "default": "Join 300,000+ Getting Better Sleep"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Review Title",
          "default": "Best Ever!"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review Text",
          "default": "I worked night shift for 27 years, so I have very bad insomnia. After using Rejuvia, I can't even get thru a chapter in a book before I am sleepy. And I sleep thru the night!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Sandra F."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show Verified Buyer Badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LP - Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
