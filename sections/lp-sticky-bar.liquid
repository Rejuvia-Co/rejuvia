{{ 'section-rejuvia-sleep-listicle.css' | asset_url | stylesheet_tag }}

<div class="rej-lp__bar" style="background:{{ section.settings.bg_color }};color:{{ section.settings.text_color }};">
  <a href="{{ section.settings.link }}" class="rej-lp__bar-link">{{ section.settings.text }}</a>
</div>

{% schema %}
{
  "name": "LP - Sticky Bar",
  "tag": "div",
  "class": "lp-sticky-bar-section",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Bar Text",
      "default": "Buy One, Get One 100% FREE — Try Rejuvia Risk-Free"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Bar Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "LP - Sticky Bar"
    }
  ]
}
{% endschema %}
