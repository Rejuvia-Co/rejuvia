{% style %}
  .main-faq-new.section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: 40px;
  }

  @media screen and (min-width: 750px) {
    .main-faq-new.section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .main-faq-new__heading {
    margin: 0;
    color: #141414;
    font-size: 36px;
    font-style: normal;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: normal;
    font-family: "Helvetica Neue", sans-serif;
  }

  .main-faq-new .container {
    padding: 0 21px;
    max-width: 1344px;
  }

  @media only screen and (max-width: 749px) {
    .main-faq-new__heading {
      font-size: 28px;
      letter-spacing: normal;
    }

    .main-faq-new.section-{{ section.id }} .container {
      padding: 0 16px;
    }
  }
{% endstyle %}

<div class="main-faq-new section-{{ section.id }}">
  <div class="container">
    {%- if section.settings.heading != blank -%}
      <h1 class="main-faq-new__heading" style="color: {{ section.settings.title_color }};">
				{{ page.title }}
			</h1>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    function setHeaderVar() {
      var header = document.querySelector('header.sticky_header_desktop, header.sticky_header_mobile, header[class*="sticky_header"]') || document.querySelector('header');
      if (!header) return;
      var pos = getComputedStyle(header).position;
      var h = (pos === 'sticky' || pos === 'fixed') ? header.offsetHeight : 0;
      document.documentElement.style.setProperty('--faq-header-h', h + 'px');
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', setHeaderVar);
    } else {
      setHeaderVar();
    }
    window.addEventListener('resize', setHeaderVar);
    window.addEventListener('load', setHeaderVar);
  })();
</script>

{% schema %}
  {
    "name": "Main FAQ new",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Faqs Title"
      },
      {
        "type": "color",
        "id": "title_color",
        "label": "Title Color",
        "default": "#141414"
      },
      {
        "type": "header",
        "content": "Section padding"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 200,
        "step": 2,
        "unit": "px",
        "label": "Top padding",
        "default": 24
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 200,
        "step": 2,
        "unit": "px",
        "label": "Bottom padding",
        "default": 24
      }
    ],

    "presets": [
      {
        "name": "Main FAQ new"
      }
    ]
  }
{% endschema %}