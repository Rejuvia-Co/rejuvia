<div class="new-product-grid container">
    {% for block in section.blocks %}
        {% if block.type == 'collection-header' %}
            {% assign heading_tag = block.settings.heading %}
            {% assign block_products = '' %}
            {% assign index = 0 %}

            {% for product in collection.products %}
                {% if product.tags contains heading_tag %}
                    {% assign index = index | plus: 1 %}
                    {% capture block_products %}
                        {{ block_products }}
                        {% render 'new-product-grid', product: product %}

                    {% endcapture %}
                {% endif %}
            {% endfor %}

            {% if block_products != blank %}
                <div class="collection__title">{{ block.settings.text }}</div>
                <div class="eg-marginY">
                    <div class="product-recommendations">
                        {{ block_products }}
                    </div>
                </div>
            {% endif %}
        {% endif %}
    {% endfor %}
</div>

{% schema %}
{
  "name": "Collection products grid",
  "tag": "section",
  "class": "custom-section",
  "settings": [],
  "blocks": [
    {
      "type": "collection-header",
      "name": "Collection heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Tag to Match Products (Heading Tag)"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Display Title"
        }
      ]
    },
    {
      "type": "content_card",
      "name": "Content Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "text",
          "id": "text_over_image",
          "label": "Text over image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Card content"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        },
        {
          "type": "number",
          "id": "insert_after",
          "label": "Insert after product #",
          "default": 2
        },
        {
          "type": "text",
          "id": "group",
          "label": "Tag to Match Group",
          "default": "functional"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection products grid"
    }
  ],
  "templates": [
    "collection"
  ]
}
{% endschema %}
