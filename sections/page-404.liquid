{{ 'feature-products-v2.css' | asset_url | stylesheet_tag }}
{% style %}
.p404 {
  --plum-700: {{ section.settings.accent_color | default: '#672666' }};
  --plum-800: #5d215f;
  --ink-800: #141414;
  --gray-500: #767676;
  --surface-lilac: #f9f2ff;
  --surface-periwinkle: #d2d7f4;
  --gold-500: #fab851;
  --gold-300: #eac78b;
  --radius-pill: 100px;
  position: relative;
  overflow: hidden;
  background: {{ section.settings.bg_color | default: '#ffffff' }};
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}
.p404__glow, .p404__glow2 { position: absolute; pointer-events: none; z-index: 0; border-radius: 50%; }
.p404__glow { width: 980px; height: 980px; top: -200px; left: 50%; transform: translateX(-50%); background: radial-gradient(circle, var(--surface-lilac) 0%, rgba(249,242,255,0.55) 38%, rgba(255,255,255,0) 70%); }
.p404__glow2 { width: 420px; height: 420px; top: 80px; right: 40px; opacity: 0.5; background: radial-gradient(circle, var(--surface-periwinkle) 0%, rgba(234,234,247,0) 70%); }

.p404__hero { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; text-align: center; display: flex; flex-direction: column; align-items: center; gap: 26px; padding: 96px 64px 24px; }
.p404__moon svg { display: block; width: 76px; height: 76px; }
.p404__badge { display: inline-flex; align-items: center; background: var(--surface-lilac); color: var(--plum-700); font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif; font-weight: 600; font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; line-height: 1; padding: 9px 18px; border-radius: var(--radius-pill); }
.p404__title { font-weight: 600; letter-spacing: -0.4px; color: var(--ink-800); font-size: 56px; line-height: 1.06; max-width: 560px; margin: 0; }
.p404__subtitle { color: var(--gray-500); font-size: 19px; line-height: 1.5; max-width: 480px; }
.p404__subtitle p { margin: 0; }
.p404__cta { display: inline-flex; align-items: center; justify-content: center; gap: 10px; background: var(--plum-700); color: #fff; font-weight: 500; font-size: 18px; line-height: 1; letter-spacing: -0.2px; padding: 18px 34px; border-radius: var(--radius-pill); text-decoration: none; transition: background .15s ease, transform .15s ease; }
.p404__cta:hover { background: var(--plum-800); color: #fff; }
.p404__cta:active { transform: scale(0.98); }
.p404__cta svg { flex-shrink: 0; }

.p404 .fp-v2-section { position: relative; z-index: 1; background: transparent; }
.p404__grid-header { display: flex; flex-direction: column; align-items: center; gap: 8px; }
.p404__eyebrow { font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--plum-700); }

@media screen and (max-width: 749px) {
  .p404__hero { padding: 52px 20px 12px; gap: 20px; }
  .p404__moon svg { width: 60px; height: 60px; }
  .p404__badge { font-size: 12px; padding: 6px 14px; }
  .p404__title { font-size: 34px; line-height: 1.12; }
  .p404__subtitle { font-size: 16px; }
  .p404__cta { width: 100%; }
  .p404__glow { width: 520px; height: 520px; top: -120px; }
  .p404__glow2 { width: 240px; height: 240px; top: 40px; right: -80px; }
}
{% endstyle %}

<section class="p404">
  {%- if section.settings.show_flourish -%}
    <div class="p404__glow" aria-hidden="true"></div>
    <div class="p404__glow2" aria-hidden="true"></div>
  {%- endif -%}

  <div class="p404__hero">
    <span class="p404__moon" aria-hidden="true">
      <svg viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs><mask id="p404moon-{{ section.id }}"><rect x="0" y="0" width="72" height="72" fill="#fff"/><circle cx="46" cy="28" r="22" fill="#000"/></mask></defs>
        <circle cx="36" cy="36" r="30" fill="var(--surface-lilac)"/>
        <circle cx="33" cy="34" r="22" fill="var(--plum-700)" mask="url(#p404moon-{{ section.id }})"/>
        <path d="M55 14 q1.4 4 4.6 5 q-3.2 1-4.6 5 q-1.4-4-4.6-5 q3.2-1 4.6-5Z" fill="var(--gold-500)"/>
        <path d="M53 40 q0.9 2.6 3 3.3 q-2.1 0.7-3 3.3 q-0.9-2.6-3-3.3 q2.1-0.7 3-3.3Z" fill="var(--gold-300)"/>
      </svg>
    </span>

    {%- if section.settings.badge_text != blank -%}<span class="p404__badge">{{ section.settings.badge_text }}</span>{%- endif -%}
    {%- if section.settings.headline != blank -%}<h1 class="p404__title">{{ section.settings.headline }}</h1>{%- endif -%}
    {%- if section.settings.subtitle != blank -%}<div class="p404__subtitle">{{ section.settings.subtitle }}</div>{%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <a class="p404__cta" href="{{ section.settings.cta_link | default: '/' }}">
        {{ section.settings.cta_text }}
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9h11M10 4l5 5-5 5"/></svg>
      </a>
    {%- endif -%}
  </div>

  <div class="fp-v2-section">
    <div class="fp-v2-container">
      {%- if section.settings.grid_eyebrow != blank or section.settings.grid_heading != blank -%}
        <div class="p404__grid-header">
          {%- if section.settings.grid_eyebrow != blank -%}<span class="p404__eyebrow">{{ section.settings.grid_eyebrow }}</span>{%- endif -%}
          {%- if section.settings.grid_heading != blank -%}<h2 class="fp-v2-heading">{{ section.settings.grid_heading }}</h2>{%- endif -%}
        </div>
      {%- endif -%}

      {%- assign item_count = 0 -%}
      <div class="fp-v2-grid" data-fp-v2-grid>
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.settings.product != blank -%}
              {%- assign item_count = item_count | plus: 1 -%}
              {% render 'fp-v2-card', item: block.settings.product %}
            {%- endif -%}
          {%- endfor -%}
        {%- elsif section.settings.collection != blank -%}
          {%- for item in section.settings.collection.products limit: section.settings.products_limit -%}
            {%- assign item_count = item_count | plus: 1 -%}
            {% render 'fp-v2-card', item: item %}
          {%- endfor -%}
        {%- endif -%}
      </div>

      {%- if item_count > 1 -%}
        <div class="fp-v2-indicators" data-fp-v2-indicators>
          {%- for i in (1..item_count) -%}
            <div class="fp-v2-indicator{% if forloop.first %} is-active{% endif %}"></div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<script>
(function() {
  var grid = document.querySelector('#shopify-section-{{ section.id }} [data-fp-v2-grid]');
  var indicators = document.querySelectorAll('#shopify-section-{{ section.id }} [data-fp-v2-indicators] .fp-v2-indicator');
  if (!grid || !indicators.length) return;
  grid.addEventListener('scroll', function() {
    var first = grid.querySelector('.fp-v2-card');
    if (!first) return;
    var cardWidth = first.offsetWidth + 16;
    var index = Math.round(grid.scrollLeft / cardWidth);
    indicators.forEach(function(dot, i) { dot.classList.toggle('is-active', i === index); });
  });
})();
</script>

{% schema %}
{
  "name": "404 Page",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "badge_text", "label": "Badge", "default": "404 · Page not found" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "This page drifted off to sleep" },
    { "type": "richtext", "id": "subtitle", "label": "Subline", "default": "<p>We couldn't find the page you were looking for — but a better night's sleep is still just a spray away.</p>" },
    { "type": "text", "id": "cta_text", "label": "Button text", "default": "Continue Shopping" },
    { "type": "url", "id": "cta_link", "label": "Button link", "default": "/" },
    { "type": "header", "content": "Bestsellers grid" },
    { "type": "text", "id": "grid_eyebrow", "label": "Eyebrow", "default": "BESTSELLERS" },
    { "type": "text", "id": "grid_heading", "label": "Heading", "default": "Shop our bestsellers." },
    { "type": "paragraph", "content": "Add Product blocks to choose exact products, OR pick a collection below (used only when no product blocks are added). Cards reuse the product-page card style and metafields." },
    { "type": "collection", "id": "collection", "label": "Collection (fallback)" },
    { "type": "range", "id": "products_limit", "min": 2, "max": 8, "step": 1, "label": "Max products from collection", "default": 4 },
    { "type": "header", "content": "Decoration" },
    { "type": "checkbox", "id": "show_flourish", "label": "Show background glow", "default": true },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Accent / brand color", "default": "#672666" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" }
      ]
    }
  ],
  "presets": [
    { "name": "404 Page" }
  ]
}
{% endschema %}
