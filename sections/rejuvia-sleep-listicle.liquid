{{ 'section-rejuvia-sleep-listicle.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  ============================================================
  REJUVIA SLEEP LISTICLE LANDING PAGE
  A fully customizer-editable Shopify section for cold traffic
  from Facebook ads. Mobile-first, conversion-optimized.
  ============================================================
{%- endcomment -%}

{%- assign s = section.settings -%}

{%- comment -%} ===== STICKY OFFER BAR ===== {%- endcomment -%}
<div class="rej-lp__bar" style="background:{{ s.bar_bg_color }};color:{{ s.bar_text_color }};">
  <a href="{{ s.bar_link }}" class="rej-lp__bar-link">{{ s.bar_text }}</a>
</div>

<div class="rej-lp">

  {%- comment -%} ===== HERO SECTION ===== {%- endcomment -%}
  <section class="rej-lp__hero">
    <div class="rej-lp__container rej-lp__hero-grid">
      <div class="rej-lp__hero-content">
        <p class="rej-lp__eyebrow">{{ s.hero_eyebrow }}</p>
        <h1 class="rej-lp__hero-heading">{{ s.hero_heading }}</h1>
        <p class="rej-lp__hero-sub">{{ s.hero_subheading }}</p>
        <div class="rej-lp__stars">
          <span class="rej-lp__stars-icons">★★★★★</span>
          <span class="rej-lp__stars-text">{{ s.hero_rating_text }}</span>
        </div>
        <a href="{{ s.hero_cta_link }}" class="rej-lp__btn rej-lp__btn--primary">{{ s.hero_cta_text }}</a>
      </div>
      <div class="rej-lp__hero-media">
        {%- if s.hero_image != blank -%}
          <img
            src="{{ s.hero_image | image_url: width: 800 }}"
            alt="{{ s.hero_image.alt | default: 'Rejuvia Sleep Spray' }}"
            loading="eager"
            width="800"
            height="{{ 800 | divided_by: s.hero_image.aspect_ratio | round }}"
            class="rej-lp__hero-img"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'rej-lp__hero-placeholder' }}
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} ===== CREDIBILITY BAR ===== {%- endcomment -%}
  <section class="rej-lp__cred">
    <div class="rej-lp__container">
      <p class="rej-lp__cred-quote">{{ s.cred_quote }}</p>
      <div class="rej-lp__cred-logos">
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' -%}
            <div class="rej-lp__cred-logo" {{ block.shopify_attributes }}>
              {%- if block.settings.logo_image != blank -%}
                <img
                  src="{{ block.settings.logo_image | image_url: width: 200 }}"
                  alt="{{ block.settings.logo_alt }}"
                  loading="lazy"
                  width="120"
                  height="40"
                >
              {%- else -%}
                <span class="rej-lp__cred-logo-text">{{ block.settings.logo_alt }}</span>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment -%} ===== PROBLEM AGITATION ===== {%- endcomment -%}
  <section class="rej-lp__problem">
    <div class="rej-lp__container rej-lp__problem-inner">
      <h2 class="rej-lp__section-heading">{{ s.problem_heading }}</h2>
      <div class="rej-lp__problem-body rte">{{ s.problem_body }}</div>
    </div>
  </section>

  {%- comment -%} ===== LISTICLE ITEMS ===== {%- endcomment -%}
  {%- assign item_index = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'listicle_item' -%}
      {%- assign item_index = item_index | plus: 1 -%}
      {%- assign is_reversed = item_index | modulo: 2 -%}
      <section class="rej-lp__item {% if is_reversed == 0 %}rej-lp__item--reversed{% endif %}" {{ block.shopify_attributes }}>
        <div class="rej-lp__container rej-lp__item-grid">
          <div class="rej-lp__item-media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 700 }}"
                alt="{{ block.settings.image.alt | default: block.settings.heading }}"
                loading="lazy"
                width="700"
                height="{{ 700 | divided_by: block.settings.image.aspect_ratio | round }}"
                class="rej-lp__item-img"
              >
            {%- else -%}
              {{ 'product-2' | placeholder_svg_tag: 'rej-lp__item-placeholder' }}
            {%- endif -%}
          </div>
          <div class="rej-lp__item-content">
            <span class="rej-lp__item-number">{{ item_index }}</span>
            <h3 class="rej-lp__item-heading">{{ block.settings.heading }}</h3>
            <div class="rej-lp__item-body rte">{{ block.settings.body }}</div>
            <a href="{{ s.hero_cta_link }}" class="rej-lp__btn rej-lp__btn--primary">{{ s.listicle_cta_text }}</a>
          </div>
        </div>
      </section>
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} ===== COMPARISON TABLE ===== {%- endcomment -%}
  <section class="rej-lp__compare">
    <div class="rej-lp__container">
      <h2 class="rej-lp__section-heading">{{ s.compare_heading }}</h2>
      <div class="rej-lp__compare-table-wrap">
        <table class="rej-lp__compare-table">
          <thead>
            <tr>
              <th></th>
              <th class="rej-lp__compare-highlight">{{ s.compare_col1_name }}</th>
              <th>{{ s.compare_col2_name }}</th>
              <th>{{ s.compare_col3_name }}</th>
            </tr>
          </thead>
          <tbody>
            {%- for block in section.blocks -%}
              {%- if block.type == 'compare_row' -%}
                <tr {{ block.shopify_attributes }}>
                  <td class="rej-lp__compare-label">{{ block.settings.row_label }}</td>
                  <td class="rej-lp__compare-highlight">{{ block.settings.col1_value }}</td>
                  <td>{{ block.settings.col2_value }}</td>
                  <td>{{ block.settings.col3_value }}</td>
                </tr>
              {%- endif -%}
            {%- endfor -%}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  {%- comment -%} ===== PRICING / OFFER SECTION ===== {%- endcomment -%}
  <section class="rej-lp__pricing" id="offer">
    <div class="rej-lp__container">
      <p class="rej-lp__eyebrow">{{ s.pricing_eyebrow }}</p>
      <h2 class="rej-lp__section-heading">{{ s.pricing_heading }}</h2>
      <p class="rej-lp__pricing-sub">{{ s.pricing_subheading }}</p>
      <div class="rej-lp__pricing-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'pricing_tier' -%}
            <div class="rej-lp__pricing-card {% if block.settings.is_popular %}rej-lp__pricing-card--popular{% endif %}" {{ block.shopify_attributes }}>
              {%- if block.settings.badge_text != blank -%}
                <span class="rej-lp__pricing-badge">{{ block.settings.badge_text }}</span>
              {%- endif -%}
              <h4 class="rej-lp__pricing-title">{{ block.settings.tier_title }}</h4>
              <div class="rej-lp__pricing-prices">
                <span class="rej-lp__pricing-sale">{{ block.settings.sale_price }}</span>
                <span class="rej-lp__pricing-original">{{ block.settings.original_price }}</span>
              </div>
              <p class="rej-lp__pricing-per-night">{{ block.settings.per_night_text }}</p>
              <p class="rej-lp__pricing-detail">{{ block.settings.detail_text }}</p>
              <a href="{{ block.settings.buy_link }}" class="rej-lp__btn rej-lp__btn--primary rej-lp__btn--full">{{ s.pricing_cta_text }}</a>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="rej-lp__pricing-trust">
        <span>✓ 90-Day Money Back Guarantee</span>
        <span>✓ Free Shipping on 6-Pack</span>
        <span>✓ Cancel Anytime</span>
      </div>
    </div>
  </section>

  {%- comment -%} ===== REVIEWS / SOCIAL PROOF ===== {%- endcomment -%}
  <section class="rej-lp__reviews">
    <div class="rej-lp__container">
      <h2 class="rej-lp__section-heading">{{ s.reviews_heading }}</h2>
      <div class="rej-lp__reviews-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <div class="rej-lp__review-card" {{ block.shopify_attributes }}>
              <div class="rej-lp__review-stars">★★★★★</div>
              <h4 class="rej-lp__review-title">{{ block.settings.review_title }}</h4>
              <p class="rej-lp__review-quote">"{{ block.settings.review_quote }}"</p>
              <p class="rej-lp__review-author">{{ block.settings.review_author }}</p>
              <span class="rej-lp__review-verified">✓ Verified Buyer</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment -%} ===== FAQ SECTION ===== {%- endcomment -%}
  <section class="rej-lp__faq">
    <div class="rej-lp__container">
      <h2 class="rej-lp__section-heading">{{ s.faq_heading }}</h2>
      <div class="rej-lp__faq-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' -%}
            <details class="rej-lp__faq-item" {{ block.shopify_attributes }}>
              <summary class="rej-lp__faq-question">{{ block.settings.question }}</summary>
              <div class="rej-lp__faq-answer rte">{{ block.settings.answer }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {%- comment -%} ===== FINAL CTA ===== {%- endcomment -%}
  <section class="rej-lp__final-cta">
    <div class="rej-lp__container rej-lp__final-cta-inner">
      <h2 class="rej-lp__final-cta-heading">{{ s.final_heading }}</h2>
      <p class="rej-lp__final-cta-sub">{{ s.final_subheading }}</p>
      <a href="{{ s.hero_cta_link }}" class="rej-lp__btn rej-lp__btn--primary rej-lp__btn--lg">{{ s.final_cta_text }}</a>
      <p class="rej-lp__final-guarantee">{{ s.final_guarantee_text }}</p>
    </div>
  </section>

</div>

<script>
  /* Smooth scroll for anchor links */
  document.querySelectorAll('.rej-lp a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>

