                {
                    "type": "item",
                    "settings": {
                        "title": "Formulated with doctors and researchers"
                    }
                },
                {
                    "type": "item",
                    "settings": {
                        "title": "Clean ingredients, nothing hidden"
                    }
                },
                {
                    "type": "item",
