<style>
.sticky-cta-bogo-section {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 100;
    pointer-events: none;
    transform: translateY(100%);
    transition: transform 0.4s ease;
}

.sticky-cta-bogo-section--bottom {
    bottom: 0;
    padding: 0;
    transform: translateY(100%);
}

.sticky-cta-bogo-section--top {
    top: 0;
    padding: 0 12px 16px;
    transform: translateY(-100%);
}

.sticky-cta-bogo-section--top .sticky-cta-bogo-bar {
    border-radius: 0 0 10px 10px;
}

.sticky-cta-bogo-section.is-visible {
    transform: translateY(0);
}

/* Hide whenever an offer section is in view. The offer sections (offer-block
   and bogo-offer) toggle these body classes via IntersectionObserver, so the
   bar stays hidden across the entire offer — gallery, buy button, and the
   info tabs below it — and reappears above and below. */
body.ob-offer-visible .sticky-cta-bogo-section,
body.bogo-offer-visible .sticky-cta-bogo-section {
    transform: translateY(100%) !important;
}
.sticky-cta-bogo-section--top.is-visible {
    transform: translateY(0);
}
body.ob-offer-visible .sticky-cta-bogo-section--top,
body.bogo-offer-visible .sticky-cta-bogo-section--top {
    transform: translateY(-100%) !important;
}

.sticky-cta-bogo-bar {
    width: 100%;
    background: #ffffff;
    box-shadow: 0 -3px 16px -3px rgba(0, 0, 0, 0.12);
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    pointer-events: auto;
}
.sticky-cta-bogo-inner {
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    overflow: hidden;
}

.sticky-cta-bogo-text {
    font-size: 20px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
    white-space: nowrap;
}

.sticky-cta-bogo-text p {
    margin: 0;
    padding: 0;
}

.sticky-cta-bogo-text strong {
    font-weight: 700;
    color: #672666;
}

.sticky-cta-bogo-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 300px;
    padding: 24px 32px;
    background: #672666;
    color: #fff;
    font-size: 18px;
    font-weight: 500;
    font-family: inherit;
    line-height: 0.7;
    text-decoration: none;
    border: none;
    border-radius: 100px;
    cursor: pointer;
    flex-shrink: 0;
    white-space: nowrap;
    transition: opacity 0.25s ease;
}

.sticky-cta-bogo-btn:hover {
    opacity: 0.9;
}

/* ===== Responsive ===== */
/* Mobile: solid white, full-width edge-to-edge, and a bit bigger overall. */
@media (max-width: 900px) {
    .sticky-cta-bogo-inner {
        padding: 15px 16px;
    }
    .sticky-cta-bogo-text {
        font-size: 18px;
        white-space: normal;
        max-width: 230px;
    }
    .sticky-cta-bogo-btn {
        width: auto;
        padding: 20px 30px;
        font-size: 17px;
        line-height: 1;
    }
}
</style>

<div class="sticky-cta-bogo-bar">
    <div class="sticky-cta-bogo-inner">
        <span class="sticky-cta-bogo-text">{{ section.settings.text }}</span>
        <a class="sticky-cta-bogo-btn" href="#" data-sticky-cta-btn data-target="{{ section.settings.scroll_target }}">{{ section.settings.btn_text }}</a>
    </div>
</div>

<script>
(function() {
    var sticky = document.querySelector('.sticky-cta-bogo-section');
    if (!sticky) return;

    var position = '{{ section.settings.position | default: "bottom" }}';
    sticky.classList.add('sticky-cta-bogo-section--' + position);
    var offset = {{ section.settings.show_after | default: 500 }};

    /* Hide on scroll up, show on scroll down (for bottom position only).
       Top position keeps the original behavior so it doesn't fight the header. */
    var lastY = window.scrollY;
    var MIN_DELTA = 4;

    function check() {
        var y = window.scrollY;
        var delta = y - lastY;
        lastY = y;

        /* Near footer → hide */
        var footer = document.querySelector('.footer-v2') || document.querySelector('footer');
        if (footer) {
            var footerTop = footer.getBoundingClientRect().top;
            if (footerTop <= window.innerHeight) {
                sticky.classList.remove('is-visible');
                return;
            }
        }

        /* Hiding while an offer section is on screen is handled by CSS
           (body.ob-offer-visible / body.bogo-offer-visible), toggled by the
           offer sections' own IntersectionObservers. */

        /* Not scrolled enough → hide */
        if (y <= offset) {
            sticky.classList.remove('is-visible');
            return;
        }

        if (position === 'bottom') {
            /* Only show while scrolling down; hide while scrolling up */
            if (delta > MIN_DELTA) {
                sticky.classList.add('is-visible');
            } else if (delta < -MIN_DELTA) {
                sticky.classList.remove('is-visible');
            }
        } else {
            sticky.classList.add('is-visible');
        }
    }

    window.addEventListener('scroll', check, { passive: true });
    check();

    /* Smooth scroll to target */
    var btn = sticky.querySelector('[data-sticky-cta-btn]');
    if (btn) {
        btn.addEventListener('click', function(e) {
            var targetSelector = btn.getAttribute('data-target');
            if (targetSelector) {
                var target = document.querySelector(targetSelector);
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            }
        });
    }

    /* Disable sticky header on this page */
    {% if section.settings.disable_sticky_header %}
    var header = document.querySelector('#header.header');
    if (header) {
        header.style.position = 'relative';
    }
    {% endif %}
})();
</script>

{% schema %}
{
    "name": "Sticky CTA (Bogo)",
    "class": "sticky-cta-bogo-section",
    "settings": [
        {
            "type": "richtext",
            "id": "text",
            "label": "Text",
            "default": "<p>Join <strong>300,000+ people</strong> sleeping through the night</p>"
        },
        {
            "type": "text",
            "id": "btn_text",
            "label": "Button text",
            "default": "Try Rejuvia"
        },
        {
            "type": "text",
            "id": "scroll_target",
            "label": "Scroll to CSS selector",
            "default": ".offer",
            "info": "CSS selector of the target section, e.g. .offer"
        },
        {
            "type": "select",
            "id": "position",
            "label": "Position",
            "options": [
                { "value": "bottom", "label": "Bottom" },
                { "value": "top", "label": "Top" }
            ],
            "default": "bottom"
        },
        {
            "type": "checkbox",
            "id": "disable_sticky_header",
            "label": "Disable sticky header on this page",
            "default": false
        },
        {
            "type": "range",
            "id": "show_after",
            "label": "Show after scroll (px)",
            "min": 100,
            "max": 2000,
            "step": 50,
            "default": 500,
            "unit": "px"
        }
    ],
    "presets": [
        {
            "name": "Sticky CTA (Bogo)",
            "category": "Custom"
        }
    ]
}
{% endschema %}
