{% style %}
.story-reviews-v2-section {
    width: 100%;
    background-color: {{ section.settings.bg_color }};
}

.story-reviews-v2-container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 32px 64px 64px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    box-sizing: border-box;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* ---- Filter pills ---- */
.story-reviews-v2-filters {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
}

.story-reviews-v2-filter {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 32px;
    background: rgba(255, 255, 255, 0.8);
    color: #141414;
    font-size: 14px;
    font-weight: 400;
    line-height: 20px;
    border: none;
    border-radius: 80px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s ease;
    font-family: inherit;
}

.story-reviews-v2-filter.is-active {
    background: {{ section.settings.filter_active_bg }};
}

/* ---- Masonry grid ---- */
.story-reviews-v2-grid {
    column-count: 3;
    column-gap: 24px;
}

.story-reviews-v2-card {
    break-inside: avoid;
    margin-bottom: 24px;
    display: block;
}

/* Text review card */
.story-reviews-v2-review {
    background: {{ section.settings.card_bg_color }};
    border-radius: 10px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.story-reviews-v2-review-header {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
}

.story-reviews-v2-avatar {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 30px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #eaeaf7;
}

.story-reviews-v2-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.story-reviews-v2-avatar-text {
    font-size: 20px;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.03em;
    color: #141414;
    margin: 0;
}

.story-reviews-v2-review-meta {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.story-reviews-v2-stars {
    display: flex;
    align-items: center;
    gap: 2px;
}

.story-reviews-v2-stars svg { width: 21.32px; height: 20px; }

.story-reviews-v2-review-title {
    margin: 0;
    font-size: 18px;
    font-weight: 500;
    line-height: 1.4;
    color: #141414;
}

.story-reviews-v2-review-body {
    margin: 0;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
}

.story-reviews-v2-review-body p { margin: 0 0 0.75em; }
.story-reviews-v2-review-body p:last-child { margin-bottom: 0; }

.story-reviews-v2-review-author {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    color: #141414;
}

.story-reviews-v2-review-name {
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
}

.story-reviews-v2-badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 6px;
    background: #e5e5e5;
    border-radius: 2px;
    font-size: 10px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
}

.story-reviews-v2-badge--verified {
    background: transparent;
    padding: 0;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0;
}

/* Video card */
.story-reviews-v2-video {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 480px;
    padding: 24px;
    border-radius: 10px;
    overflow: hidden;
    color: #fff;
    text-decoration: none;
    box-sizing: border-box;
}

.story-reviews-v2-video-bg,
.story-reviews-v2-video-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: #141414;
}

.story-reviews-v2-video-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

.story-reviews-v2-video-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0) 55%);
}

.story-reviews-v2-video.is-playing .story-reviews-v2-video-overlay,
.story-reviews-v2-video.is-playing .story-reviews-v2-video-content {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
}

.story-reviews-v2-video-content {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
    width: 100%;
}

.story-reviews-v2-video-text {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.story-reviews-v2-video-quote {
    margin: 0;
    font-size: 26px;
    font-weight: 500;
    line-height: 1.3;
}

.story-reviews-v2-video-author {
    margin: 0;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.4;
}

.story-reviews-v2-video-play {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.16);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: transform 0.2s ease;
}

.story-reviews-v2-video-play:hover { transform: scale(1.05); }

.story-reviews-v2-video-play svg {
    width: 30px;
    height: 30px;
    color: {{ section.settings.video_play_color | default: '#672666' }};
    display: block;
}

/* Image card */
.story-reviews-v2-image {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 10px;
    overflow: hidden;
    background: #eaeaf7;
}

.story-reviews-v2-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
}

/* ---- Filter state (hide cards by data-type) ---- */
.story-reviews-v2-section[data-filter="written"] .story-reviews-v2-card:not([data-type="review"]) { display: none; }
.story-reviews-v2-section[data-filter="video"] .story-reviews-v2-card:not([data-type="video"]) { display: none; }

/* ===================== Tablet ===================== */
@media (max-width: 1100px) {
    .story-reviews-v2-grid { column-count: 2; }
}

/* ===================== Mobile ===================== */
@media (max-width: 749px) {
    .story-reviews-v2-container {
        padding: 24px 16px;
        gap: 24px;
    }

    .story-reviews-v2-filters { gap: 6px; }

    .story-reviews-v2-filter { padding: 12px 24px; }

    .story-reviews-v2-grid { column-count: 1; }

    .story-reviews-v2-avatar {
        width: 50px;
        height: 50px;
        border-radius: 25px;
    }

    .story-reviews-v2-avatar-text { font-size: 16.67px; }

    .story-reviews-v2-stars svg { width: 17.07px; height: 16px; }

    .story-reviews-v2-review-title { font-size: 16px; }

    .story-reviews-v2-video {
        height: 400px;
    }

    .story-reviews-v2-video-quote { font-size: 22px; }

    .story-reviews-v2-video-play { width: 50px; height: 50px; }
    .story-reviews-v2-video-play svg { width: 25px; height: 25px; }
}
{% endstyle %}

<div class="story-reviews-v2-container"{% if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id }}"{% endif %}>
    {% if section.settings.show_filters %}
        <div class="story-reviews-v2-filters" role="tablist">
            <button type="button" class="story-reviews-v2-filter is-active" data-filter="all">{{ section.settings.filter_all_label }}</button>
            <button type="button" class="story-reviews-v2-filter" data-filter="written">{{ section.settings.filter_written_label }}</button>
            <button type="button" class="story-reviews-v2-filter" data-filter="video">{{ section.settings.filter_video_label }}</button>
        </div>
    {% endif %}

    <div class="story-reviews-v2-grid">
        {% for block in section.blocks %}
            {% case block.type %}

            {% when 'review' %}
                <div class="story-reviews-v2-card" data-type="review" {{ block.shopify_attributes }}>
                    <div class="story-reviews-v2-review">
                        <div class="story-reviews-v2-review-header">
                            {% if block.settings.avatar_image != blank %}
                                <div class="story-reviews-v2-avatar">
                                    <img src="{{ block.settings.avatar_image | image_url: width: 120 }}"
                                         alt="{{ block.settings.author_name | default: 'Reviewer' }}"
                                         loading="lazy">
                                </div>
                            {% elsif block.settings.avatar_initials != blank %}
                                <div class="story-reviews-v2-avatar" style="background: {{ block.settings.avatar_color | default: '#eaeaf7' }};">
                                    <span class="story-reviews-v2-avatar-text">{{ block.settings.avatar_initials }}</span>
                                </div>
                            {% endif %}
                            <div class="story-reviews-v2-review-meta">
                                {%- assign star_color = block.settings.stars_color | default: section.settings.stars_color -%}
                                <div class="story-reviews-v2-stars" aria-label="{{ block.settings.stars | default: 5 }} stars">
                                    {% assign star_count = block.settings.stars | default: 5 %}
                                    {% for i in (1..star_count) %}
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 16" fill="none" aria-hidden="true"><path d="M3.85124 15.9392C3.43952 16.1504 2.97233 15.7803 3.05553 15.3078L3.94083 10.2626L0.183091 6.68298C-0.167831 6.34806 0.0145632 5.73581 0.484948 5.66968L5.70931 4.9273L8.03883 0.31199C8.24895 -0.103997 8.81747 -0.103997 9.0276 0.31199L11.3571 4.9273L16.5815 5.66968C17.0519 5.73581 17.2343 6.34806 16.8823 6.68298L13.1256 10.2626L14.0109 15.3078C14.0941 15.7803 13.6269 16.1504 13.2152 15.9392L8.53161 13.5329L3.85124 15.9392Z" fill="{{ star_color }}"/></svg>
                                    {% endfor %}
                                </div>
                                {% if block.settings.title != blank %}
                                    <h3 class="story-reviews-v2-review-title">{{ block.settings.title }}</h3>
                                {% endif %}
                            </div>
                        </div>

                        {% if block.settings.body != blank %}
                            <div class="story-reviews-v2-review-body">{{ block.settings.body }}</div>
                        {% endif %}

                        <div class="story-reviews-v2-review-author">
                            {% if block.settings.author_name != blank %}
                                <span class="story-reviews-v2-review-name">{{ block.settings.author_name }}</span>
                            {% endif %}
                            {% if block.settings.badge_type == 'verified' %}
                                <span class="story-reviews-v2-badge story-reviews-v2-badge--verified">Verified Purchase</span>
                            {% elsif block.settings.badge_type == 'unprompted' %}
                                <span class="story-reviews-v2-badge">Unprompted review</span>
                            {% endif %}
                        </div>
                    </div>
                </div>

            {% when 'video' %}
                {%- assign video_file = block.settings.video_file -%}
                {%- if block.settings.thumbnail != blank -%}
                    {%- assign video_poster = block.settings.thumbnail | image_url: width: 800 -%}
                {%- elsif video_file != blank and video_file.preview_image != blank -%}
                    {%- assign video_poster = video_file.preview_image | image_url: width: 800 -%}
                {%- else -%}
                    {%- assign video_poster = '' -%}
                {%- endif -%}
                <div class="story-reviews-v2-card" data-type="video" {{ block.shopify_attributes }}>
                    <div class="story-reviews-v2-video" data-story-video>
                        {% if video_file != blank %}
                            <video class="story-reviews-v2-video-media"
                                   playsinline
                                   muted
                                   preload="metadata"
                                   {% if video_poster != blank %}poster="{{ video_poster }}"{% endif %}
                                   data-story-video-media>
                                {% for source in video_file.sources %}
                                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                                {% endfor %}
                            </video>
                        {% elsif video_poster != blank %}
                            <div class="story-reviews-v2-video-bg">
                                <img src="{{ video_poster }}"
                                     alt="{{ block.settings.author | default: 'Video review' }}"
                                     loading="lazy">
                            </div>
                        {% endif %}
                        <div class="story-reviews-v2-video-overlay"></div>
                        <div class="story-reviews-v2-video-content">
                            <div class="story-reviews-v2-video-text">
                                {% if block.settings.quote != blank %}
                                    <p class="story-reviews-v2-video-quote">{{ block.settings.quote }}</p>
                                {% endif %}
                                {% if block.settings.author != blank %}
                                    <p class="story-reviews-v2-video-author">{{ block.settings.author }}</p>
                                {% endif %}
                            </div>
                            <button type="button" class="story-reviews-v2-video-play"
                                    data-story-video-play
                                    {% if video_file == blank and block.settings.video_url != blank %}data-external-url="{{ block.settings.video_url }}"{% endif %}
                                    aria-label="Play video">
                                <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" viewBox="0 0 30 30" fill="none" aria-hidden="true">
                                    <path d="M6.25 6.25013C6.24987 5.81025 6.36581 5.37811 6.5861 4.99737C6.8064 4.61662 7.12326 4.30074 7.50469 4.08163C7.88612 3.86251 8.3186 3.74791 8.75849 3.7494C9.19837 3.7509 9.63007 3.86843 10.01 4.09013L25.0062 12.8376C25.3847 13.0572 25.6989 13.3723 25.9174 13.7514C26.136 14.1305 26.2512 14.5603 26.2515 14.9978C26.2519 15.4354 26.1375 15.8653 25.9196 16.2448C25.7017 16.6242 25.3881 16.9399 25.01 17.1601L10.01 25.9101C9.63007 26.1318 9.19837 26.2494 8.75849 26.2509C8.3186 26.2524 7.88612 26.1378 7.50469 25.9186C7.12326 25.6995 6.8064 25.3836 6.5861 25.0029C6.36581 24.6221 6.24987 24.19 6.25 23.7501V6.25013Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>

            {% when 'image' %}
                <div class="story-reviews-v2-card" data-type="image" {{ block.shopify_attributes }}>
                    <div class="story-reviews-v2-image">
                        {% if block.settings.image != blank %}
                            <img src="{{ block.settings.image | image_url: width: 800 }}"
                                 alt="{{ block.settings.alt | default: '' }}"
                                 loading="lazy">
                        {% endif %}
                    </div>
                </div>

            {% endcase %}
        {% endfor %}
    </div>
</div>

<script>
(function() {
    var section = document.querySelector('.story-reviews-v2-section');
    if (!section) return;
    var filters = section.querySelectorAll('.story-reviews-v2-filter');
    if (filters.length === 0) return;

    filters.forEach(function(btn) {
        btn.addEventListener('click', function() {
            var type = btn.getAttribute('data-filter');
            filters.forEach(function(b) { b.classList.remove('is-active'); });
            btn.classList.add('is-active');
            if (type === 'all') {
                section.removeAttribute('data-filter');
            } else {
                section.setAttribute('data-filter', type);
            }
        });
    });

    /* Play video inline; pause any other playing video in the section */
    function pauseAllExcept(current) {
        section.querySelectorAll('[data-story-video]').forEach(function(wrap) {
            var media = wrap.querySelector('[data-story-video-media]');
            if (!media || media === current) return;
            media.pause();
            media.controls = false;
            wrap.classList.remove('is-playing');
        });
    }

    section.querySelectorAll('[data-story-video-play]').forEach(function(playBtn) {
        playBtn.addEventListener('click', function() {
            var externalUrl = playBtn.getAttribute('data-external-url');
            if (externalUrl) {
                window.open(externalUrl, '_blank', 'noopener');
                return;
            }
            var wrap = playBtn.closest('[data-story-video]');
            if (!wrap) return;
            var media = wrap.querySelector('[data-story-video-media]');
            if (!media) return;
            pauseAllExcept(media);
            media.controls = true;
            media.muted = false;
            wrap.classList.add('is-playing');
            var p = media.play();
            if (p && typeof p.catch === 'function') p.catch(function() {});
        });
    });

    /* When any <video> starts playing (controls or otherwise), pause the rest */
    section.querySelectorAll('[data-story-video-media]').forEach(function(media) {
        media.addEventListener('play', function() { pauseAllExcept(media); });
        media.addEventListener('pause', function() {
            var wrap = media.closest('[data-story-video]');
            if (wrap && media.paused && !media.ended) {
                /* Keep is-playing class while paused so UI stays out of the way */
            }
        });
        media.addEventListener('ended', function() {
            var wrap = media.closest('[data-story-video]');
            if (wrap) wrap.classList.remove('is-playing');
            media.controls = false;
        });
    });
})();
</script>

{% schema %}
{
    "name": "Story Reviews V2",
    "class": "story-reviews-v2-section",
    "settings": [
        {
            "type": "text",
            "id": "anchor_id",
            "label": "Anchor ID",
            "info": "Optional."
        },
        {
            "type": "color",
            "id": "bg_color",
            "label": "Background color",
            "default": "#ffffff"
        },
        {
            "type": "color",
            "id": "card_bg_color",
            "label": "Review card background",
            "default": "#FAFAFA"
        },
        {
            "type": "color",
            "id": "stars_color",
            "label": "Stars color",
            "default": "#FAB851"
        },
        {
            "type": "header",
            "content": "Filters"
        },
        {
            "type": "checkbox",
            "id": "show_filters",
            "label": "Show filter pills",
            "default": true
        },
        {
            "type": "color",
            "id": "filter_active_bg",
            "label": "Active filter background",
            "default": "#EAEAF7"
        },
        {
            "type": "text",
            "id": "filter_all_label",
            "label": "All label",
            "default": "All"
        },
        {
            "type": "text",
            "id": "filter_written_label",
            "label": "Written reviews label",
            "default": "Written Reviews"
        },
        {
            "type": "text",
            "id": "filter_video_label",
            "label": "Video reviews label",
            "default": "Video Reviews"
        }
    ],
    "blocks": [
        {
            "type": "review",
            "name": "Review",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "avatar_image",
                    "label": "Avatar image",
                    "info": "Optional. Falls back to initials below."
                },
                {
                    "type": "text",
                    "id": "avatar_initials",
                    "label": "Avatar initials",
                    "default": "JC"
                },
                {
                    "type": "color",
                    "id": "avatar_color",
                    "label": "Avatar background",
                    "default": "#FFDBE8"
                },
                {
                    "type": "range",
                    "id": "stars",
                    "label": "Stars",
                    "min": 1,
                    "max": 5,
                    "step": 1,
                    "default": 5
                },
                {
                    "type": "color",
                    "id": "stars_color",
                    "label": "Stars color",
                    "info": "Overrides the section default."
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Review title"
                },
                {
                    "type": "richtext",
                    "id": "body",
                    "label": "Review body"
                },
                {
                    "type": "text",
                    "id": "author_name",
                    "label": "Author name"
                },
                {
                    "type": "select",
                    "id": "badge_type",
                    "label": "Badge",
                    "options": [
                        { "value": "none", "label": "None" },
                        { "value": "unprompted", "label": "Unprompted review" },
                        { "value": "verified", "label": "Verified Purchase" }
                    ],
                    "default": "unprompted"
                }
            ]
        },
        {
            "type": "video",
            "name": "Video review",
            "settings": [
                {
                    "type": "video",
                    "id": "video_file",
                    "label": "Video (MP4)",
                    "info": "Uploads via Shopify. Preview image is auto-generated (1st frame)."
                },
                {
                    "type": "image_picker",
                    "id": "thumbnail",
                    "label": "Custom thumbnail",
                    "info": "Optional. Overrides the auto-generated preview image."
                },
                {
                    "type": "text",
                    "id": "quote",
                    "label": "Quote",
                    "default": "\u201CTry it \u2013 you\u2019ll like it.\u201D"
                },
                {
                    "type": "text",
                    "id": "author",
                    "label": "Author",
                    "default": "Hylan S."
                },
                {
                    "type": "url",
                    "id": "video_url",
                    "label": "External video URL",
                    "info": "Used as fallback if no MP4 is uploaded — opens in a new tab."
                }
            ]
        },
        {
            "type": "image",
            "name": "Image",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "Image"
                },
                {
                    "type": "text",
                    "id": "alt",
                    "label": "Alt text"
                }
            ]
        }
    ],
    "max_blocks": 40,
    "presets": [
        {
            "name": "Story Reviews V2",
            "category": "Custom"
        }
    ]
}
{% endschema %}
