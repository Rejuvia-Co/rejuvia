<style>
.uij-v2-section {
    width: 100%;
    background-color: #eaeaf7;
}

.uij-v2-container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 32px;
    padding: 64px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* Header row */
.uij-v2-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
}

.uij-v2-heading {
    font-size: 30px;
    font-weight: 500 !important;
    line-height: 1.4;
    color: #141414;
    letter-spacing: 0 !important;
    margin: 0;
}

.uij-v2-heading p {
    margin: 0; padding: 0; font: inherit; letter-spacing: inherit; color: inherit;
}

.uij-v2-heading em {
    color: #672666; font-style: normal; text-decoration: underline;
}

.uij-v2-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 32px;
    border-radius: 80px;
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow: 0 3px 16px rgba(0,0,0,0.06);
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: #672666;
    text-decoration: none;
    white-space: nowrap;
}

/* Content row */
.uij-v2-content {
    display: flex;
    gap: 64px;
    align-items: flex-start;
    width: 100%;
}

/* Image */
.uij-v2-image {
    flex: 1;
    min-width: 0;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    height: 600px;
    min-height: 600px;
}

.uij-v2-step-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.4s ease;
}

.uij-v2-step-image.is-active {
    opacity: 1;
}

/* Watermark */
.uij-v2-watermark {
    position: absolute;
    width: 150px;
    height: 150px;
    z-index: 2;
    display: none;
    pointer-events: none;
}

.uij-v2-watermark.is-active {
    display: block;
}

.uij-v2-watermark img {
    width: 100%;
    height: 100%;
    object-fit: contain;
}

.uij-v2-watermark--top-right {
    top: 20px;
    right: 20px;
}

.uij-v2-watermark--top-left {
    top: 20px;
    left: 20px;
}

/* Accordion */
.uij-v2-accordion {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.uij-v2-step {
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-radius: 10px;
    box-shadow: 0 3px 16px rgba(0,0,0,0.06);
    overflow: hidden;
}

.uij-v2-step-header {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 24px;
    cursor: pointer;
    background: none;
    border: none;
    width: 100%;
    font-family: inherit;
    text-align: left;
}

.uij-v2-step-title {
    flex: 1;
    font-size: 16px;
    line-height: 1.4;
    color: #141414;
}

.uij-v2-step.is-active .uij-v2-step-title {
    font-weight: 700;
}

.uij-v2-step:not(.is-active) .uij-v2-step-title {
    font-weight: 400;
}

.uij-v2-step-chevron {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
}

.uij-v2-step-chevron .uij-v2-icon-minus {
    display: none;
}

.uij-v2-step-chevron .uij-v2-icon-plus {
    display: block;
}

.uij-v2-step.is-active .uij-v2-step-chevron .uij-v2-icon-minus {
    display: block;
}

.uij-v2-step.is-active .uij-v2-step-chevron .uij-v2-icon-plus {
    display: none;
}

/* Step content */
.uij-v2-step-body {
    display: none;
    padding: 0 24px 24px;
    flex-direction: column;
    gap: 24px;
}

.uij-v2-step.is-active .uij-v2-step-body {
    display: flex;
}

.uij-v2-step-desc {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
    margin: 0;
}

.uij-v2-step-divider {
    width: 100%;
    height: 1px;
    background: #e5e5e5;
}

/* Tips */
.uij-v2-tips {
    display: flex;
    gap: 24px;
}

.uij-v2-tip {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.uij-v2-tip-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
}

.uij-v2-tip-label svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
}

.uij-v2-tip-text {
    font-size: 14px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
    margin: 0;
}

/* ===== Responsive ===== */
@media (max-width: 1100px) {
    .uij-v2-container { padding: 40px 32px; }
    .uij-v2-content { gap: 32px; }
    .uij-v2-heading { font-size: 26px; }
}

@media (max-width: 900px) {
    .uij-v2-container {
        padding: 40px 16px;
        gap: 24px;
        align-items: stretch;
    }
    .uij-v2-header {
        display: contents;
    }
    .uij-v2-heading { font-size: 24px; order: 1; width: 100%; text-align: left; }
    .uij-v2-content {
        order: 2;
        flex-direction: column;
        gap: 24px;
        width: 100%;
    }
    .uij-v2-accordion {
        width: 100%;
    }
    .uij-v2-link {
        font-size: 14px;
        width: auto;
        align-self: center;
        order: 3;
        padding: 12px 32px;
    }
    .uij-v2-image {
        width: 100%;
        height: 0;
        min-height: 0;
        padding-bottom: 100%;
        border-radius: 20px;
    }
    .uij-v2-step-image {
        border-radius: 20px;
    }
    .uij-v2-watermark {
        width: 80px;
        height: 80px;
    }
    .uij-v2-watermark--top-right {
        top: 15px;
        right: 30px;
    }
    .uij-v2-watermark--top-left {
        top: 15px;
        left: 30px;
    }
}
</style>

<div class="uij-v2-container">
    {%- comment -%} Header {%- endcomment -%}
    <div class="uij-v2-header">
        <div class="uij-v2-heading">{{ section.settings.heading }}</div>
        {% if section.settings.link_text != blank %}
            <a class="uij-v2-link" href="{{ section.settings.link_url }}">{{ section.settings.link_text }}</a>
        {% endif %}
    </div>

    {%- comment -%} Content {%- endcomment -%}
    <div class="uij-v2-content">
        {%- comment -%} Image {%- endcomment -%}
        <div class="uij-v2-image">
            {% if section.settings.default_image != blank %}
                <img
                    class="uij-v2-step-image"
                    data-uij-v2-default
                    src="{{ section.settings.default_image | image_url: width: 1200 }}"
                    alt="How to use"
                    loading="eager"
                >
            {% endif %}
            {% for block in section.blocks %}
                {% if block.settings.image != blank %}
                    <img
                        class="uij-v2-step-image{% if forloop.first %} is-active{% endif %}"
                        data-uij-v2-img="{{ forloop.index0 }}"
                        src="{{ block.settings.image | image_url: width: 1200 }}"
                        alt="{{ block.settings.title }}"
                        loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                    >
                {% endif %}
                {% if block.settings.watermark != blank %}
                    <div class="uij-v2-watermark uij-v2-watermark--{{ block.settings.watermark_position | default: 'top-right' }}{% if forloop.first %} is-active{% endif %}" data-uij-v2-wm="{{ forloop.index0 }}" style="opacity: {{ block.settings.watermark_opacity | default: 20 | times: 0.01 }};">
                        <img src="{{ block.settings.watermark | image_url: width: 300 }}" alt="" loading="lazy">
                    </div>
                {% endif %}
            {% endfor %}
        </div>

        {%- comment -%} Accordion {%- endcomment -%}
        <div class="uij-v2-accordion">
            {% for block in section.blocks %}
                <div class="uij-v2-step{% if forloop.first %} is-active{% endif %}" data-uij-v2-step {{ block.shopify_attributes }}>
                    <button class="uij-v2-step-header" type="button">
                        <span class="uij-v2-step-title">{{ block.settings.title }}</span>
                        <span class="uij-v2-step-chevron">
                            <svg class="uij-v2-icon-plus" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M12 5V19M5 12H19" stroke="#141414" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            <svg class="uij-v2-icon-minus" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M5 12H19" stroke="#141414" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                        </span>
                    </button>
                    <div class="uij-v2-step-body">
                        <p class="uij-v2-step-desc">{{ block.settings.description }}</p>
                        {% if block.settings.tip1_label != blank or block.settings.tip2_label != blank %}
                            <div class="uij-v2-step-divider"></div>
                            <div class="uij-v2-tips">
                                {% if block.settings.tip1_label != blank %}
                                    <div class="uij-v2-tip">
                                        <div class="uij-v2-tip-label">
                                            {% if block.settings.tip1_icon != blank %}
                                                <img src="{{ block.settings.tip1_icon | image_url: width: 32 }}" alt="" width="16" height="16">
                                            {% endif %}
                                            {{ block.settings.tip1_label }}
                                        </div>
                                        <p class="uij-v2-tip-text">{{ block.settings.tip1_text }}</p>
                                    </div>
                                {% endif %}
                                {% if block.settings.tip2_label != blank %}
                                    <div class="uij-v2-tip">
                                        <div class="uij-v2-tip-label">
                                            {% if block.settings.tip2_icon != blank %}
                                                <img src="{{ block.settings.tip2_icon | image_url: width: 32 }}" alt="" width="16" height="16">
                                            {% endif %}
                                            {{ block.settings.tip2_label }}
                                        </div>
                                        <p class="uij-v2-tip-text">{{ block.settings.tip2_text }}</p>
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>

    {%- comment -%} Mobile link (shown via CSS order) {%- endcomment -%}
</div>

<script>
(function() {
    var section = document.querySelector('.uij-v2-section');
    if (!section) return;

    var steps = section.querySelectorAll('[data-uij-v2-step]');

    var defaultImg = section.querySelector('[data-uij-v2-default]');

    function deactivateAll() {
        steps.forEach(function(s) { s.classList.remove('is-active'); });
        section.querySelectorAll('[data-uij-v2-img]').forEach(function(img) { img.classList.remove('is-active'); });
        section.querySelectorAll('[data-uij-v2-wm]').forEach(function(wm) { wm.classList.remove('is-active'); });
        if (defaultImg) defaultImg.classList.add('is-active');
    }

    function activate(index) {
        deactivateAll();
        if (defaultImg) defaultImg.classList.remove('is-active');
        steps[index].classList.add('is-active');
        var img = section.querySelector('[data-uij-v2-img="' + index + '"]');
        var wm = section.querySelector('[data-uij-v2-wm="' + index + '"]');
        if (img) img.classList.add('is-active');
        if (wm) wm.classList.add('is-active');
    }

    steps.forEach(function(step, index) {
        step.querySelector('.uij-v2-step-header').addEventListener('click', function() {
            if (step.classList.contains('is-active')) {
                deactivateAll();
            } else {
                activate(index);
            }
        });
    });
})();
</script>

