<style>
.wmd-v2-section {
    width: 100%;
    background-color: #fff;
}

.wmd-v2-container {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 64px;
    padding: 64px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* Image */
.wmd-v2-image {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

.wmd-v2-image-bg {
    position: absolute;
    width: 345px;
    height: 345px;
    background-color: #f3f0f8;
    border-radius: 10px;
    transform: rotate(0deg);
}

.wmd-v2-image img {
    position: relative;
    z-index: 1;
    max-height: 600px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
}

/* Copy */
.wmd-v2-copy {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
}

.wmd-v2-heading {
    font-size: 30px;
    font-weight: 500 !important;
    line-height: 1.4;
    color: #141414;
    letter-spacing: 0 !important;
    margin: 0;
}

.wmd-v2-heading p {
    margin: 0; padding: 0; font: inherit; letter-spacing: inherit; color: inherit;
}

.wmd-v2-heading em {
    color: #672666; font-style: normal; text-decoration: underline;
}

.wmd-v2-subtitle {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
    margin: 0;
}

/* Info card */
.wmd-v2-card {
    background: #f3f0f8;
    border-radius: 10px;
    overflow: hidden;
}

.wmd-v2-card-header {
    background: #eaeaf7;
    padding: 16px;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
    color: #141414;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.wmd-v2-card-body {
    padding: 24px 16px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
}

.wmd-v2-card-icon {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
}

.wmd-v2-card-text {
    flex: 1;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: #141414;
}

.wmd-v2-card-text strong {
    font-weight: 700;
}

.wmd-v2-card-text p {
    margin: 0 0 1em;
}

.wmd-v2-card-text p:last-child {
    margin-bottom: 0;
}

/* Mobile heading */
.wmd-v2-heading-mobile {
    display: none;
}

/* ===== Responsive ===== */
@media (max-width: 1100px) {
    .wmd-v2-container {
        gap: 40px;
        padding: 40px 32px;
    }
    .wmd-v2-heading { font-size: 26px; }
}

@media (max-width: 900px) {
    .wmd-v2-container {
        flex-direction: column;
        padding: 40px 16px;
        gap: 24px;
    }
    .wmd-v2-heading-mobile {
        display: block;
        font-size: 24px;
        font-weight: 500 !important;
        line-height: 1.4;
        color: #141414;
        letter-spacing: 0 !important;
        margin: 0;
        width: 100%;
    }
    .wmd-v2-heading-mobile p {
        margin: 0; padding: 0; font: inherit; letter-spacing: inherit; color: inherit;
    }
    .wmd-v2-heading-mobile em {
        color: #672666; font-style: normal; text-decoration: underline;
    }
    .wmd-v2-copy .wmd-v2-heading {
        display: none;
    }
    .wmd-v2-copy {
        display: contents;
    }
    .wmd-v2-heading-mobile { order: 1; }
    .wmd-v2-subtitle { order: 2; }
    .wmd-v2-image { order: 3; width: 100%; }
    .wmd-v2-card { order: 4; width: 100%; }
    .wmd-v2-image img {
        max-height: 300px;
    }
    .wmd-v2-image-bg {
        width: 195px;
        height: 195px;
    }
}
</style>

<div class="wmd-v2-container">
    {%- comment -%} Mobile heading {%- endcomment -%}
    <div class="wmd-v2-heading-mobile">{{ section.settings.heading }}</div>

    {%- comment -%} === Image === {%- endcomment -%}
    <div class="wmd-v2-image">
        <div class="wmd-v2-image-bg"></div>
        {% if section.settings.image != blank %}
            <img
                src="{{ section.settings.image | image_url: width: 800 }}"
                alt="{{ section.settings.image.alt | default: 'Product' }}"
                loading="lazy"
            >
        {% endif %}
    </div>

    {%- comment -%} === Copy Block === {%- endcomment -%}
    <div class="wmd-v2-copy">
        <div class="wmd-v2-heading">{{ section.settings.heading }}</div>
        <p class="wmd-v2-subtitle">{{ section.settings.subtitle }}</p>

        <div class="wmd-v2-card">
            <div class="wmd-v2-card-header">{{ section.settings.card_title }}</div>
            <div class="wmd-v2-card-body">
                <svg class="wmd-v2-card-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30" fill="none">
                    <path d="M15 2C10 2 6 6 6 11C6 14 7.5 16.5 10 18V22C10 22.6 10.4 23 11 23H19C19.6 23 20 22.6 20 22V18C22.5 16.5 24 14 24 11C24 6 20 2 15 2Z" stroke="#672666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                    <path d="M11 27H19" stroke="#672666" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M13 23V27M17 23V27" stroke="#672666" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                <div class="wmd-v2-card-text">
                    {{ section.settings.card_text }}
                </div>
            </div>
        </div>
    </div>
</div>

{% schema %}
{
    "name": "What Makes Different V2",
    "class": "wmd-v2-section",
    "settings": [
        {
            "type": "richtext",
            "id": "heading",
            "label": "Heading",
            "default": "<p>What makes Rejuvia <em>different?</em></p>"
        },
        {
            "type": "textarea",
            "id": "subtitle",
            "label": "Subtitle",
            "default": "A fast-acting oral sleep spray with 13+ natural ingredients that absorb under your tongue in minutes."
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "Product image"
        },
        {
            "type": "text",
            "id": "card_title",
            "label": "Card title",
            "default": "Why spraying works better"
        },
        {
            "type": "richtext",
            "id": "card_text",
            "label": "Card text",
            "default": "<p>The tissue under your tongue is packed with blood vessels.</p><p>When something absorbs there, it goes directly into your bloodstream, <strong>skipping the digestive process</strong> that destroys most pills and gummies.</p><p><strong>More of the active ingredients</strong> reach your body intact, and you feel it <strong>working faster.</strong></p>"
        },
        {
            "type": "image_picker",
            "id": "card_icon",
            "label": "Card icon (optional)"
        }
    ],
    "presets": [
        {
            "name": "What Makes Different V2",
            "category": "Custom"
        }
    ]
}
{% endschema %}
