{% style %}
  /* ===== Mobile Menu V2 ===== */
  #menu-mobile {
    background: transparent;
    display: none;
    outline: none;
    visibility: hidden;
    width: 400px;
    right: -415px;
    overflow: hidden;
    background-color: {{ settings.mobile_menu_bg_color }};
    position: absolute;
    top: 55px;
    z-index: -1;
  }

  #menu-mobile.open {
    right: 0.1em;
    visibility: visible;
  }

  #menu-mobile .wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  #menu-mobile .content {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    height: 100%;
    width: 100%;
    background: #fff;
    overflow-y: auto;
    flex: 1;
  }

  #menu-mobile .menu-mobile {
    height: calc(100% - 100px);
    overflow-y: scroll;
    padding: 0 20px;
  }

  #menu-mobile .close {
    cursor: pointer;
    min-height: 32px !important;
    min-width: 32px !important;
  }

  #menu-mobile .close svg {
    max-height: 100%;
    max-width: 100%;
  }

  {% if settings.mobile_menu_position == "left" %}
  #menu-mobile { right: auto; left: -415px; }
  #menu-mobile.open { right: auto; left: 0; }
  {% endif %}

  .header-open {
    background-color: #ffffff !important;
    transition: background-color 0.7s ease-in-out;
  }

  #header > .container {
    transition: background-color 0.7s ease-in-out;
  }

  @media(min-width: 500px) {
    #header > .container {
      background-color: #ffffff !important;
    }
  }

  .btn-open-mobile-menu {
    display: flex;
    align-items: left;
    justify-content: left;
    margin-top: 3px !important;
  }

  .btn-open-mobile-menu svg {
    width: 32px;
    height: 32px;
  }

  .hidden {
    display: none !important;
  }

  a.close > svg {
    width: 32px !important;
    height: 32px !important;
  }

  /* ===== Nav V2 Mobile Menu ===== */
  .nav-v2 #menu-mobile {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0 !important;
    width: 100%;
    background: #FFFFFF;
    border-radius: 0 0 10px 10px;
    box-shadow: 0px 3px 16px -3px rgba(0, 0, 0, 0.06);
    overflow: hidden;
    opacity: 0;
    transform: translateY(-10px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
    z-index: 100;
    visibility: hidden;
    display: block !important;
  }

  .nav-v2 #menu-mobile.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    visibility: visible;
  }

  .nav-v2 #menu-mobile .wrapper {
    height: auto;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }

  .nav-v2 #menu-mobile .content {
    height: auto;
    overflow: visible;
  }

  .nav-v2 #menu-mobile .menu-mobile {
    height: auto;
    overflow: visible;
    padding: 0;
  }

  /* V2 Product Cards (Mobile) */
  .mobile-menu-v2__products {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px;
  }

  .mobile-menu-v2__product-card {
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: center;
    background: #FFFFFF;
    border-radius: 10px;
    box-shadow: 0px 3px 16px -3px rgba(0, 0, 0, 0.06);
    padding: 16px 24px;
    text-decoration: none;
    color: #141414;
    overflow: hidden;
  }

  .mobile-menu-v2__product-card:hover {
    text-decoration: none;
    color: #141414;
  }

  .mobile-menu-v2__product-img {
    width: 60px;
    height: 60px;
    flex-shrink: 0;
  }

  .mobile-menu-v2__product-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .mobile-menu-v2__product-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-width: 0;
  }

  .mobile-menu-v2__product-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    width: 100%;
  }

  .mobile-menu-v2__product-title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 16px;
    line-height: normal;
    color: #141414;
    margin: 0;
  }

  .mobile-menu-v2__product-rating {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .mobile-menu-v2__product-rating .rating-star {
    color: #F5A623;
    width: 12px;
    height: 12px;
  }

  .mobile-menu-v2__product-rating-num {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 700;
    font-size: 11px;
    color: #141414;
  }

  .mobile-menu-v2__product-desc {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 18px;
    color: #141414;
    opacity: 0.7;
    margin: 0;
  }

  /* V2 Nav Links */
  .mobile-menu-v2__links {
    display: flex;
    flex-direction: column;
    padding: 0 16px;
  }

  .mobile-menu-v2__link-divider {
    height: 1px;
    background: rgba(20, 20, 20, 0.1);
  }

  .mobile-menu-v2__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 0;
    text-decoration: none;
    color: #141414;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 20px;
  }

  .mobile-menu-v2__link:hover {
    text-decoration: none;
    color: #141414;
    opacity: 0.7;
  }

  .mobile-menu-v2__link svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    opacity: 0.5;
  }

  /* V2 Account Button */
  .mobile-menu-v2__account {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin: 0 16px;
    padding: 12px 24px;
    background: #FFFFFF;
    border-radius: 100px;
    box-shadow: 0px 3px 16px 0px rgba(0, 0, 0, 0.06);
    text-decoration: none;
    color: #141414;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: normal;
    transition: background 0.2s ease;
  }

  .mobile-menu-v2__account:hover {
    background: #F5F5F5;
    text-decoration: none;
    color: #141414;
  }

  .mobile-menu-v2__account svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  /* V2 Traits Bar */
  .mobile-menu-v2__traits {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 16px;
    margin-top: 24px;
    border-radius: 0 0 10px 10px;
    background: linear-gradient(92.71deg, #D2D7F4 7.64%, #F9F2FF 34.21%, #EAEAF7 75%, #D2D7F4 103.66%);
  }

  .mobile-menu-v2__trait {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .mobile-menu-v2__trait-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .mobile-menu-v2__trait-icon svg {
    width: 20px;
    height: 20px;
  }

  .mobile-menu-v2__trait-label {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 18px;
    color: #141414;
    white-space: nowrap;
  }
{% endstyle %}

<div id="menu-mobile" class="ease-animation-slow" role="dialog" aria-modal="true">
  <div class="wrapper">
    <div class="content">
      <nav class="menu-mobile" role="navigation">

          {%- comment -%} Mobile Menu — products from first mega_menu block {%- endcomment -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'mega_menu' -%}
              {%- assign mega_block = block -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}

          {% if mega_block %}
          <div class="mobile-menu-v2__products">
            {%- assign product_fields = 'product_1,product_2,product_3,product_4,product_5' | split: ',' -%}
            {%- assign desc_fields = 'product_1_desc,product_2_desc,product_3_desc,product_4_desc,product_5_desc' | split: ',' -%}
            {%- for i in (0..4) -%}
              {%- assign prod_field = product_fields[i] -%}
              {%- assign desc_field = desc_fields[i] -%}
              {%- if mega_block.settings[prod_field] != blank -%}
                {%- assign product = all_products[mega_block.settings[prod_field]] -%}
                <a href="{{ product.url }}" class="mobile-menu-v2__product-card">
                  <div class="mobile-menu-v2__product-img">
                    <img
                      src="{{ product.featured_image | img_url: '200x' }}"
                      alt="{{ product.title }}"
                      loading="lazy"
                      width="60"
                      height="60"
                    />
                  </div>
                  <div class="mobile-menu-v2__product-info">
                    <div class="mobile-menu-v2__product-header">
                      <p class="mobile-menu-v2__product-title">{{ product.title }}</p>
                      <div class="mobile-menu-v2__product-rating">
                        <svg class="rating-star" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                        </svg>
                        <span class="mobile-menu-v2__product-rating-num">
                          {% if product.metafields.okendo.summaryData.reviewCount > 0 %}
                            {{ product.metafields.okendo.summaryData.reviewAverageValue | round: 1 }}
                          {% else %}
                            5.0
                          {% endif %}
                        </span>
                      </div>
                    </div>
                    <p class="mobile-menu-v2__product-desc">{{ mega_block.settings[desc_field] }}</p>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {% endif %}

          <div class="mobile-menu-v2__links">
            <div class="mobile-menu-v2__link-divider"></div>
            {% for block in section.blocks %}
              {% if block.type == 'mobile-menu-links' %}
                {% if block.settings.first_label %}
                  <a href="{{ block.settings.first_url }}" class="mobile-menu-v2__link">
                    <span>{{ block.settings.first_label }}</span>
                    {% render 'icon-nav-arrow' %}
                  </a>
                  <div class="mobile-menu-v2__link-divider"></div>
                {% endif %}
                {% if block.settings.second_label %}
                  <a href="{{ block.settings.second_url }}" class="mobile-menu-v2__link">
                    <span>{{ block.settings.second_label }}</span>
                    {% render 'icon-nav-arrow' %}
                  </a>
                  <div class="mobile-menu-v2__link-divider"></div>
                {% endif %}
                {% if block.settings.third_label %}
                  <a href="{{ block.settings.third_url }}" class="mobile-menu-v2__link">
                    <span>{{ block.settings.third_label }}</span>
                    {% render 'icon-nav-arrow' %}
                  </a>
                  <div class="mobile-menu-v2__link-divider"></div>
                {% endif %}
                {% if block.settings.fourth_label %}
                  <a href="{{ block.settings.fourth_url }}" class="mobile-menu-v2__link">
                    <span>{{ block.settings.fourth_label }}</span>
                    {% render 'icon-nav-arrow' %}
                  </a>
                  <div class="mobile-menu-v2__link-divider"></div>
                {% endif %}
              {% endif %}
            {% endfor %}

            <a href="{% if customer %}/account{% else %}/a/account/login{% endif %}" class="mobile-menu-v2__account" style="margin-top: 16px; margin-bottom: 0;">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M15 16.6666C15 15.3405 14.4732 14.0688 13.5355 13.1311C12.5979 12.1934 11.3261 11.6666 10 11.6666C8.67392 11.6666 7.40215 12.1934 6.46447 13.1311C5.52678 14.0688 5 15.3405 5 16.6666" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.0001 11.6667C11.841 11.6667 13.3334 10.1743 13.3334 8.33333C13.3334 6.49238 11.841 5 10.0001 5C8.15913 5 6.66675 6.49238 6.66675 8.33333C6.66675 10.1743 8.15913 11.6667 10.0001 11.6667Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.0001 18.3333C14.6025 18.3333 18.3334 14.6023 18.3334 9.99996C18.3334 5.39759 14.6025 1.66663 10.0001 1.66663C5.39771 1.66663 1.66675 5.39759 1.66675 9.99996C1.66675 14.6023 5.39771 18.3333 10.0001 18.3333Z" stroke="#141414" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Account Log In
            </a>
          </div>

          {% if mega_block %}
          <div class="mobile-menu-v2__traits">
            {% if mega_block.settings.benefit_1_text != blank %}
            <div class="mobile-menu-v2__trait">
              <span class="mobile-menu-v2__trait-icon">{% render 'icon-benefit-shipping' %}</span>
              <span class="mobile-menu-v2__trait-label">{{ mega_block.settings.benefit_1_text }}</span>
            </div>
            {% endif %}
            {% if mega_block.settings.benefit_2_text != blank %}
            <div class="mobile-menu-v2__trait">
              <span class="mobile-menu-v2__trait-icon">{% render 'icon-benefit-reviews' %}</span>
              <span class="mobile-menu-v2__trait-label">{{ mega_block.settings.benefit_2_text }}</span>
            </div>
            {% endif %}
            {% if mega_block.settings.benefit_3_text != blank %}
            <div class="mobile-menu-v2__trait">
              <span class="mobile-menu-v2__trait-icon">{% render 'icon-benefit-family' %}</span>
              <span class="mobile-menu-v2__trait-label">{{ mega_block.settings.benefit_3_text }}</span>
            </div>
            {% endif %}
          </div>
          {% endif %}


      </nav>
    </div>
  </div>
</div>

<script>
  (function() {
    var scrollPosition = 0;
    var menuMobile = document.getElementById('menu-mobile');
    var headerEl = document.getElementById('header');
    if (!menuMobile) return;

    function toggleMenuButtons() {
      var openBtn = document.querySelector('.btn-open-mobile-menu');
      var closeBtn = document.querySelector('.navigator-mobile .close');
      if (openBtn) openBtn.classList.toggle('hidden');
      if (closeBtn) closeBtn.classList.toggle('hidden');
    }

    function openMenu() {
      scrollPosition = window.scrollY;
      menuMobile.classList.add('open');
      var container = headerEl ? headerEl.querySelector('.container') : null;
      if (container) container.classList.add('header-open');
      toggleMenuButtons();

      if (typeof Simplistic !== 'undefined' && Simplistic.trapFocus) {
        Simplistic.trapFocus({
          $container: typeof jQuery !== 'undefined' ? jQuery(menuMobile) : null,
          namespace: 'menu-mobile'
        });
      }
    }

    function closeMenu() {
      menuMobile.classList.remove('open');
      var container = headerEl ? headerEl.querySelector('.container') : null;
      if (container) container.classList.remove('header-open');

      if (typeof Simplistic !== 'undefined' && Simplistic.removeTrapFocus) {
        Simplistic.removeTrapFocus({
          $container: typeof jQuery !== 'undefined' ? jQuery(menuMobile) : null,
          namespace: 'menu-mobile'
        });
      }
      toggleMenuButtons();
    }

    document.addEventListener('click', function(e) {
      var openBtn = e.target.closest('.btn-open-mobile-menu');
      if (openBtn) {
        e.preventDefault();
        if (!menuMobile.classList.contains('open')) {
          openMenu();
        } else {
          closeMenu();
        }
      }

      var closeBtn = e.target.closest('.navigator-mobile .close');
      if (closeBtn) {
        e.preventDefault();
        closeMenu();
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && menuMobile.classList.contains('open')) {
        e.preventDefault();
        closeMenu();
      }
    });
  })();
</script>
