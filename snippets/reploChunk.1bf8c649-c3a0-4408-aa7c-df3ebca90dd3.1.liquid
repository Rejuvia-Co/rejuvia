6-04d0-4c67-8f58-9f136bdc49d2-attributes-lineheight:120%;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-letterspacing:-0.4px"><span style="width:100%"><h1>Frequently Asked Questions</h1></span></div><div data-rid="1eb37d7b-ae7d-43dd-aed1-ee9b77107918" class="r-1qubdn3" data-orientation="vertical"><div data-rid="ee9c488e-0561-4e10-81fa-b085003fd8ba" class="r-1uxts2e" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="53925053-12f4-466e-8a31-e4838327452a" aria-expanded="false" aria-controls="replo-:Rr8b2:" tabindex="0" role="button" class="r-1clv6tb"><div data-rid="2a4afed6-d90a-4d17-ba11-b94b8068231b" class="r-190tb5w alchemy-rte"><span style="width:100%"><p>How fast will I feel Rejuvia working?</p></span></div><div data-rid="c3263de2-712d-454e-b305-2e0433da67b5" class="r-1vvzo9n" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-1yrluta" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:Rr8b2:"><div data-rid="293e0a28-4331-487c-a022-996d50b8cde4" class="r-1lug66c"><div data-rid="cf1452ed-1d2a-456f-af44-d2216dc9d4f0" class="r-sn6kun alchemy-rte"><span style="width:100%"><p>Most people feel it the first or second night. Because the spray absorbs under your tongue, it skips your stomach completely and gets to work in about 10-15 minutes instead of the 60-90 minutes pills and gummies take. That said, if you've been dealing with bad sleep for years, give it a full 7-10 nights of consistent use. The ingredients build on each other and the deeper, full-night sleep typically kicks in by the end of week one.</p></span></div></div></div></div><div data-rid="e208bd13-5f00-45f2-b0d7-9337cae3de01" class="r-mahb0n" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="34f41a92-9256-4265-9694-fb9738dfc39b" aria-expanded="false" aria-controls="replo-:R1b8b2:" tabindex="0" role="button" class="r-rgzefh"><div data-rid="22130d01-5c77-4ee3-8cf1-77740659dbbd" class="r-b94hln alchemy-rte"><span style="width:100%"><p>Will I wake up groggy in the morning?</p></span></div><div data-rid="61131edb-66ab-45c9-87eb-bb6bf8870385" class="r-170pq5" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-cznl09" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:R1b8b2:"><div data-rid="87cc922b-96f6-4045-a016-b5dd94e6f900" class="r-1ofh598"><div data-rid="bc44c1c1-a674-4218-8c0a-8a358a6cb50a" class="r-jr8pwt alchemy-rte"><span style="width:100%"><p>No, and this is the #1 reason people switch to Rejuvia. We use a low 2mg dose of melatonin (most gummies pack 5-10mg, which is what causes the morning hangover) paired with 12 natural sleep herbs that calm your mind without knocking you out cold. You'll wake up rested, not foggy.</p></span></div></div></div></div><div data-rid="73c35708-0ee5-4262-b588-80dc87aec9ad" class="r-1rg4k2s" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="48580e60-d95e-4ed4-8a4d-4392644471ea" aria-expanded="false" aria-controls="replo-:R1r8b2:" tabindex="0" role="button" class="r-1szzdaq"><div data-rid="f72b2a1e-e494-462d-9708-abe6f33b47fa" class="r-g4adh9 alchemy-rte"><span style="width:100%"><p>Is Rejuvia habit-forming? Will I become dependent on it?</p></span></div><div data-rid="d27bfeb5-e41e-4f21-8930-905cf4b2a4e7" class="r-79ole1" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-w34oz4" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:R1r8b2:"><div data-rid="10289e37-7a69-4534-9abe-a3b40ef5ee72" class="r-kh2ecj"><div data-rid="47bf8ecb-a861-4cae-849e-48504dabfad3" class="r-1fqsz64 alchemy-rte"><span style="width:100%"><p>Not at all. Rejuvia is non-habit-forming, and you can use it every night or only when you need it. Most of our customers use it nightly as part of their wind-down routine because they love how they feel, not because they have to. Plenty of customers also use it 3-4 nights a week or only when travel and stress throw off their sleep.</p></span></div></div></div></div><div data-rid="7ff475ad-67be-4c7e-a048-32b136654161" class="r-p6kz1g" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="876cbb9c-bf6d-48f0-8f40-3dd0463b1eb3" aria-expanded="false" aria-controls="replo-:R2b8b2:" tabindex="0" role="button" class="r-15aj7bh"><div data-rid="07a3bae3-fba7-460c-96e5-df6cce4ba01b" class="r-q1d63i alchemy-rte"><span style="width:100%"><p>What are the ingredients in Rejuvia?</p></span></div><div data-rid="eecec594-6ce7-4978-af33-72b7c6778579" class="r-15it24y" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-1nuynjv" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:R2b8b2:"><div data-rid="42330eb6-135b-420c-ae5b-16f0b4f1b8f0" class="r-8aj2jo"><div data-rid="4d58458b-cd26-423d-af4b-e461820ed84c" class="r-19cmt75 alchemy-rte"><span style="width:100%"><p>Rejuvia has 13 all-natural ingredients working together: a low 2mg of melatonin, plus 5-HTP, valerian root, passionflower, chamomile, lemon balm, skullcap, magnolia bark, hops, cramp bark, ginkgo biloba, peppermint, and feverfew. That's why it works on falling asleep, staying asleep, and waking up refreshed instead of just one of the three.</p></span></div></div></div></div><div data-rid="e60e5558-2a26-462a-bb77-5b623519efe0" class="r-1x24e88" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="1587318c-4f07-4eeb-8c38-1486adeee5c9" aria-expanded="false" aria-controls="replo-:R2r8b2:" tabindex="0" role="button" class="r-u85yct"><div data-rid="0bd548ac-75d0-4785-b5b0-f33ca106ba26" class="r-pccahe alchemy-rte"><span style="width:100%"><p>What if it doesn't work for me?</p></span></div><div data-rid="c24702b5-6c63-4e93-a747-7d05b16ca67f" class="r-1qu9pq2" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-uawbn" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:R2r8b2:"><div data-rid="2b74e7d1-dac8-40f0-a14f-347375af162a" class="r-eij87m"><div data-rid="9189080c-ed4e-45b7-b4c9-72696aed45c5" class="r-dlbh8w alchemy-rte"><span style="width:100%"><p>You're covered by our 90-day money-back guarantee on your first order, no questions asked. If you try Rejuvia for a few weeks and don't love it, just email us at <a href="mailto:hello@rejuvia.co">hello@rejuvia.co</a> and we'll refund you. We'd rather earn your trust than hold your money.</p></span></div></div></div></div><div data-rid="0a628f4a-6718-42a0-afaf-d157cc677b82" class="r-1u97ks0" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="0babb6ca-08f7-4e87-b843-3ac443055028" aria-expanded="false" aria-controls="replo-:R3b8b2:" tabindex="0" role="button" class="r-1lv7yx4"><div data-rid="e3a1db41-ac5c-4cae-8fab-dc93db349c36" class="r-wpynw4 alchemy-rte"><span style="width:100%"><p>Is this a subscription?</p></span></div><div data-rid="f7cdc5cc-3a56-48fb-a790-45288721f54a" class="r-scia6z" aria-hidden="true"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="img" aria-label="Collapse/Expand" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-xavz5c" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"></path></svg></div></div><div class="replo-animated" hidden="" id="replo-:R3b8b2:"><div data-rid="6e39c0c0-c98a-4fa5-8c78-45de02daffed" class="r-ihhlu7"><div data-rid="91172190-040a-4a57-b668-ad1033ce38c7" class="r-1g6n7lq alchemy-rte"><span style="width:100%"><p>Nope. This is a one-time purchase, no subscription, no auto-billing, no strings attached. You pay once, we ship it, and that's it. If you love it and want to set up automatic refills later to save more, you can do that from our main product page anytime.</p><p><br></p></span></div></div></div></div><div data-rid="18fc0ec3-be7c-4d9c-9670-cd1405735cac" class="r-qfoux8" data-replo-collapsible="true" data-state="closed" data-orientation="vertical"><div data-rid="be31ad25-72f7-421e-882a-0ab2454eb34f" aria-expanded="false" aria-controls="replo-:R3r8b2:" tabindex="0" role="button" class="r-ygi5tb"><div data-rid="71af3bfc-fa83-42b9-908d-cf0d1864f85a" class="r-1f6f