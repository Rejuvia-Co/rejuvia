ur mind stops racing and sleep takes over.</p></span></div></div></div></div><div data-rid="aa06c539-340c-4b72-bdb8-c7be4ec35caf" class="r-13smxqi"><div data-rid="a61f4dad-24a9-4e61-90a0-fc89cdebdf0f" class="r-13l7qh3"><button data-rid="7c72e565-01ba-46bc-8fef-321f0ff63778" tabindex="0" role="link" class="text r-1ost9nk alchemy-rte" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-607cccde-d509-4933-94fc-83d304f76b86-attributes-color-background-color:#672666FF"><div data-rid="28d5e9fd-2ad2-4b96-ac21-17a7b914e891" class="r-saqap alchemy-rte"><span style="width:100%"><p>TRY REJUVIA NOW</p></span></div><div data-rid="f82344eb-6b30-4e81-92a7-01625083befa" class="r-1s329py"><svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 16 16" role="presentation" style="width:var(--rsw, 100%);height:auto;max-height:100%" class="r-qltxgt" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8"></path></svg></div></button></div><div data-rid="4c76236f-0952-43bd-a508-b6132a1c489f" class="r-1a5b2jn"><picture data-rid="a0cf3861-6531-4979-a19b-18205cace5ee" class="r-xl8lo8"><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/e60f08a9-4eca-4005-b755-abe10f28724a?width=40" media="(max-width: 640px)"/><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/e60f08a9-4eca-4005-b755-abe10f28724a?width=40" media="(min-width: 641px) and (max-width: 1024px)"/><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/e60f08a9-4eca-4005-b755-abe10f28724a?width=40" media="(min-width: 1025px) and (max-width: 2400px)"/><img src="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/e60f08a9-4eca-4005-b755-abe10f28724a" class="r-bcroib" loading="eager"/></picture><div data-rid="3a9c29fa-337a-423e-aaa7-3b04fe70d463" class="r-1h3d6tx alchemy-rte"><span style="width:100%"><p>90-Day Money Back Guarantee</p></span></div></div></div></div><div data-rid="afe18cdc-5a59-461f-b0ff-b625512e9be2" class="r-jjj66y"><div data-rid="6c3d19ca-3616-4f51-bced-3514bf6a728e" class="r-14owve3"><picture data-rid="23bb254c-4c1d-4d27-bf14-6794018f1c7b" class="r-tjfroo"><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/cd18f480-1e52-40df-8057-6398081caa17?width=820" media="(max-width: 640px)"/><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/cd18f480-1e52-40df-8057-6398081caa17?width=1024" media="(min-width: 641px) and (max-width: 1024px)"/><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/cd18f480-1e52-40df-8057-6398081caa17?width=1800" media="(min-width: 1025px) and (max-width: 2400px)"/><img src="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/cd18f480-1e52-40df-8057-6398081caa17" alt="An advertisement for Rejuvia oral sleep spray, showing the product alongside a list of its 13 ingredients." class="r-7ye914" loading="eager"/></picture></div><div data-rid="1626992f-81c6-440f-983f-46e5fc19ed97" class="r-104wqkn"><div data-rid="36e08cb1-bcc3-42dd-9b52-a454eed0a689" class="r-1m3nvd4"><div data-rid="7d284c91-6ca8-4a8a-958f-1c15bac31703" class="r-1ryzwt"><div data-rid="4d8c0204-7a4f-4d41-854a-fc5d35eb2eef" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-79878d61-29c3-4fdf-a61d-7ab28574c8d6-attributes-color-background-color:#EAC78BFF" class="r-1e44r01"><div data-rid="b26f918f-99de-4078-9b2f-954726e0350b" class="r-10jao7c alchemy-rte" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-9543f1f4-fb33-41e1-907f-7d1894f1c1b1-attributes-color:#000000FF"><span style="width:100%"><p>4</p></span></div></div><div data-rid="477b4a3c-5acf-48a3-9de8-8ea6185c63c9" class="r-rfhctm alchemy-rte" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-fontsize:40px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-textdecoration:undefined;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-fontfamily:HelveticaNeueLTPro-Bd;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-fontweight:400;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-lineheight:50px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-letterspacing:-0.2px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontsize:28px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-textdecoration:undefined;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontfamily:HelveticaNeueLTPro-Bd;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontweight:400;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-lineheight:120%;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-letterspacing:-0.4px"><span style="width:100%"><p>13 Natural Ingredients, Drug-Free and Non-Habit-Forming</p></span></div></div><div data-rid="b166ab6d-14ce-492b-95de-2b0fc18833fd" class="r-2tp6ow"><div data-rid="287e4c45-8eba-4973-84d8-70f5d8a73e68" class="r-1k99jrz alchemy-rte"><span style="width:100%"><p>Most sleep aids don't tell you what's really in them — and for good reason. Artificial dyes, added sugars, synthetic fillers, mystery compounds you can't pronounce. You're putting something in your body every single night. You should know exactly what it is.</p><p><br></p><p>Rejuvia is a blend of 13 natural sleep ingredients including melatonin (just 2mg), 5-HTP, valerian root, passionflower, chamomile, lemon balm, skullcap, magnolia bark, hops, cramp bark, ginkgo biloba, peppermint, and feverfew. Every batch is triple lab-tested for purity. No fillers. No junk. No drugs.</p><p><br></p><p>And because it's drug-free, Rejuvia is non-habit-forming. No tolerance buildup, no dependency, no withdrawal. It works <em>with</em> your body's natural sleep cycle instead of overriding it. That's why customers use it every night for months — sometimes years — without ever needing to increase their dose. You stay in control.</p></span></div></div></div></div></div><div data-rid="5c32bb48-3abd-460a-995a-ba31e0210aba" class="r-jqfq8w"><div data-rid="84808c7e-28a4-4faa-99ed-0b78b1ac6c2a" class="r-kzv2ez"><picture data-rid="bf0efe2e-0e5b-4c1d-8d03-0ad09914e568" class="r-12suwu"><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/d4eb13e4-ab3b-4910-9970-a71c7fb704d2?width=820" media="(max-width: 640px)"/><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/d4eb13e4-ab3b-4910-9970-a71c7fb704d2?width=1024" media="(min-width: 641px) and (max-width: 1024px)"/><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/d4eb13e4-ab3b-4910-9970-a71c7fb704d2?width=1800" media="(min-width: 1025px) and (max-width: 2400px)"/><img src="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/d4eb13e4-ab3b-4910-9970-a71c7fb704d2" class="r-8g22vf" loading="eager"/></picture></div><div data-rid="d1220ae5-38e2-4424-b706-4697595e6a39" class="r-1003olx"><div data-rid="f969093d-75a2-4db5-94e8-05aa25044cf8" class="r-1a9hkad"><div data-rid="429ebec0-bcc9-4815-ab64-fd76b4ad44ce" class="r-1xd5fyu"><div data-rid="58bd717e-2ebf-49fe-8c3b-7d97acaa0536" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-79878d61-29c3-4fdf-a61d-7ab28574c8d6-attributes-color-background-color:#EAC78BFF" class="r-afi1hg"><div data-rid="0528d4dd-73b8-473b-b2ea-f45fb19e779f" class="r-baorca alchemy-rte" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-9543f1f4-fb33-41e1-907f-7d1894f1c1b1-attributes-color:#000000FF"><span style="width:100%"><p>5</p></span></div></div><div data-rid="3bf70241-1bdc-47b6-9d9c-4eae772dd6cc" class="r-xfqx84 alchemy-rte" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-fontsize:40px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-textdecoration:undefined;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-fontfamily:HelveticaNeueLTPro-Bd;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-fontweight:400;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-lineheight:50px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-letterspacing:-0.2px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontsize:28px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-textdecoration:undefined;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontfamily:HelveticaNeueLTPro-Bd;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontweight:400;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-lineheight:120%;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-letterspacing:-0.4px"><span style="width:100%"><p>Created By a Son For His Sleepless Mom</p></span></div></div><div data-rid="4de94b26-cd0c-460e-a057-7f1ef3590688" class="r-c4j7n0"><div data-rid="0a9890fe-0d88-471c-a5d4-9860110d7072" class="r-m282m7 alchemy-rte"><span style="width:100%"><p>When RC was growing up, his mom couldn't sleep. She'd lie awake until 2, 3, sometimes 4 AM — exhausted but wired. Her doctor put her on sleeping pills. They knocked her out, but she'd wake up foggy and feeling worse than before. Melatonin gummies. Teas. Magnesium. Nothing gave her real sleep.</p><br><p>So when RC left for the University of Pennsylvania, he made it his mission to find a real answer. What he discovered changed everything: the problem wasn't the ingredients — it was <em>how the body absorbed them</em>. That insight is what led to Rejuvia's Oral Sleep Spray. His mom was the first customer, and she finally got her sleep back.</p><br><p>Today, RC and his mom Kristen run Rejuvia together out of Philadelphia. Over 300,000 people now use the spray she helped create.</p></span></div></div></div></div></div></div></div></div><div data-rid="e994ba5e-c4fd-4984-ae78-51a1c00b1637" class="r-7vhvs9" data-alchemy-prerendered-component-id="e994ba5e-c4fd-4984-ae78-51a1c00b1637">{%- comment -%}replo-liquid-chunk-begin{%- endcomment -%}<div style="width:100%;height:100%" data-alchemy-prerendered-placeholder="true">{% section 'customer-testimonials-video' %}</div>{%- comment -%}replo-liquid-chunk-end{%- endcomment -%}</div><div data-rid="5c3e1e9c-2972-4a06-bcf3-8885365fbe27" data-alchemy-url-hashmark="Shop" tabindex="-1" id="Shop" data-alchemy-url-hashmark-ignore="true" class="r-1ks2nsc"><div data-rid="65a855e6-e151-4bc5-81a6-e0a428e0bcb2" data-alchemy-url-hashmark="Shop" tabindex="-1" id="Shop" data-alchemy-url-hashmark-ignore="true" class="r-3m5kmm">{%- comment -%}replo-liquid-chunk-begin{%- endcomment -%}<!-- -->{% assign reploOriginalProductRqb2 = product %}<!-- -->{% capture productHandle %}sleep-spray-copy{% endcapture %}<!-- -->{% assign product = all_products[productHandle] %}<!-- -->{% assign reploOriginalProductVariantRqb2 = reploSelectedVariant %}<!-- -->{% assign reploSelectedVariant = blank %}<!-- -->{% assign reploOriginalSPGRqb2 = reploSortedSellingPlans %}<!-- -->{% assign reploSortedSellingPlans = blank %}<!-- -->{% assign reploOriginalSSPRqb2 = reploSelectedSellingPlan %}<!-- -->{% assign reploSelectedSellingPlan = blank %}<!-- -->{% assign reploOriginalSSPPriceRqb2 = reploSelectedSellingPlanPrice %}<!-- -->{% assign reploSelectedSellingPlanPrice = blank %}<!-- -->{% assign reploOriginalComparePricePercentRqb2 = reploCompareAtPriceDifferencePercentage %}<!-- -->{% assign reploCompareAtPriceDifferencePercentage = blank %}<!-- -->{%- comment -%}replo-liquid-chunk-end{%- endcomment -%}<!-- -->{%- comment -%}replo-liquid-chunk-begin{%- endcomment -%}<!-- -->{% capture reploVariantIdString %}null{% endcapture %}<!-- -->{% capture reploSellingPlanIdString %}null{% endcapture %}<!-- -->{% capture reploIdKey %}id{% endcapture %}<!-- -->{% capture reploPercentageKey %}percentage{% endcapture %}<!-- -->{% capture reploPriceKey %}price{% endcapture %}<!-- -->{% capture reploFixedAmountKey %}fixed_amount{% endcapture %}<!-- -->{% capture spKey %}selling_plan{% endcapture %}<!-- -->{%- liquid
              assign reploVariantId = reploVariantIdString | times: 1
              assign reploSelectedVariant = product.variants | where: reploIdKey, reploVariantId | first
              if reploSelectedVariant == blank
                assign reploSelectedVariant = product.selected_or_first_available_variant
              endif
              assign reploSelectedSellingPlanPrice = reploSelectedVariant.price
              if product.selling_plan_groups[0]
                assign reploAllSellingPlans = reploSelectedVariant.selling_plan_allocations | map: spKey
                assign reploSortedSellingPlans = reploAllSellingPlans | sort: reploIdKey
                if true
                  assign reploSellingPlanId = reploSellingPlanIdString | times: 1
                  assign reploSelectedSellingPlan = reploSortedSellingPlans | where: reploIdKey, reploSellingPlanId | first
                  if reploSelectedSellingPlan.price_adjustments[0]
                    assign adjustment = reploSelectedSellingPlan.price_adjustments[0]
                    case adjustment.value_type
                      when reploPercentageKey
                        assign amountOff = 100 | minus: adjustment.value
                        assign reploSelectedSellingPlanPrice = reploSelectedSellingPlanPrice | times: amountOff | divided_by: 100
                      when reploFixedAmountKey
