79a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontweight:400;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-lineheight:120%;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-letterspacing:-0.4px"><span style="width:100%"><p>Safe, Drug-Free, and Non-Habit Forming</p></span></div></div><div data-rid="0afe8e5e-e1fc-4d3b-9fda-8090ad3e6cfe" class="r-1w4i34y"><div data-rid="c38d34ea-816b-4c58-af13-c788efdf7766" class="r-v9i1an alchemy-rte"><span style="width:100%"><p>If you've ever taken a sleeping pill, you know the trap: it works at first, then you need more, then you can't sleep without it. You traded one problem for another.<br><br>Rejuvia is 100% drug-free and non-habit forming. There's no tolerance buildup, no dependency, no withdrawal. It works with your body's natural sleep cycle instead of overriding it with sedation. That's why customers use it every single night for months — even years — without ever needing to increase their dose. You stay in control.</p></span></div></div></div></div></div><div data-rid="e69ad028-803e-4d20-bb45-321253891535" class="r-1440x2"><div data-rid="23808c82-4964-4dac-8b4a-5bacf99feb72" class="r-gj6dkn"><picture data-rid="481c422b-1311-48ca-997a-6b3c3b9c40ea" class="r-14hdiou"><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/de4d62bf-10df-4924-bcd7-b8d6f24bf702?width=820" media="(max-width: 640px)"/><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/de4d62bf-10df-4924-bcd7-b8d6f24bf702?width=1024" media="(min-width: 641px) and (max-width: 1024px)"/><source srcSet="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/de4d62bf-10df-4924-bcd7-b8d6f24bf702?width=1800" media="(min-width: 1025px) and (max-width: 2400px)"/><img src="https://assets.replocdn.com/projects/a6b9cd13-85b5-416b-9786-753e40672d80/de4d62bf-10df-4924-bcd7-b8d6f24bf702" class="r-4jwj8c" loading="eager"/></picture></div><div data-rid="3b1da8e1-34bf-4406-86ba-e2a14adf16b6" class="r-10oqhow"><div data-rid="9fd28d15-5124-4833-aefa-489a0b9bf88e" class="r-j3oe9x"><div data-rid="76fa757d-fc58-4aac-a46b-fd8993e62553" class="r-oga54p"><div data-rid="da589e99-1852-42d5-837c-1cb86a7c2d53" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-79878d61-29c3-4fdf-a61d-7ab28574c8d6-attributes-color-background-color:#EAC78BFF" class="r-1g9fcbk"><div data-rid="f6a05d87-4f8b-4363-bb23-f8260d2bc0c0" class="r-1xwh2wb alchemy-rte" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-9543f1f4-fb33-41e1-907f-7d1894f1c1b1-attributes-color:#000000FF"><span style="width:100%"><p>8</p></span></div></div><div data-rid="48945911-7e4c-4490-8f26-f350f8a924cb" class="r-1tkpyp0 alchemy-rte" style="--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-fontsize:40px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-textdecoration:undefined;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-fontfamily:HelveticaNeueLTPro-Bd;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-fontweight:400;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-lineheight:50px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-32eaebe0-5a60-46ca-b9b5-bb2df355112b-attributes-letterspacing:-0.2px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontsize:28px;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-textdecoration:undefined;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontfamily:HelveticaNeueLTPro-Bd;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-fontweight:400;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-lineheight:120%;--replo-library-ae6ad90b-9359-4cab-b761-99dbb2179a44-styles-5db417d6-04d0-4c67-8f58-9f136bdc49d2-attributes-letterspacing:-0.4px"><span style="width:100%"><p>She's Not Alone. 300,000 People and 500+ Doctors Use It Every Night</p></span></div></div><div data-rid="1b615ba9-9c7f-4c2f-aba4-74ae7d77255d" class="r-1qi7gi2"><div data-rid="f4f51d45-c313-40d6-b06a-cd2dac154882" class="r-1rl8jf2 alchemy-rte"><span style="width:100%"><p>It started with my mom. But it didn't stay there.</p><br><p>Over 300,000 people now use Rejuvia nightly, and 500+ doctors across the country recommend it — many of them keep it on their own nightstand. When a physician chooses a sleep aid for themselves, that says more than any ad ever could.</p><br><p>Over 6,000 five-star reviews. Featured in Forbes, Healthline, and Women's Health. It started as something I made for one person I love. We built it into something that could help everyone who needed it.</p><br><p>She's never slept better. You're next.</p></span></div></div></div></div></div></div></div></div><div data-rid="69e02e07-cec2-44f4-bbda-8066ecdabd37" class="r-1id9t70" data-alchemy-prerendered-component-id="69e02e07-cec2-44f4-bbda-8066ecdabd37">{%- comment -%}replo-liquid-chunk-begin{%- endcomment -%}<div style="width:100%;height:100%" data-alchemy-prerendered-placeholder="true">{% section 'customer-testimonials-video' %}</div>{%- comment -%}replo-liquid-chunk-end{%- endcomment -%}</div><div data-rid="dd8c43ac-1b67-4503-85a1-264036e81c17" data-alchemy-url-hashmark="Shop" tabindex="-1" id="Shop" data-alchemy-url-hashmark-ignore="true" class="r-cwgk8s"><div data-rid="6aff6e52-9e9f-41af-9593-3aaec5ce1bcc" data-alchemy-url-hashmark="Shop" tabindex="-1" id="Shop" data-alchemy-url-hashmark-ignore="true" class="r-2ww6rs">{%- comment -%}replo-liquid-chunk-begin{%- endcomment -%}<!-- -->{% assign reploOriginalProductRdb2 = product %}<!-- -->{% capture productHandle %}sleep-spray-copy{% endcapture %}<!-- -->{% assign product = all_products[productHandle] %}<!-- -->{% assign reploOriginalProductVariantRdb2 = reploSelectedVariant %}<!-- -->{% assign reploSelectedVariant = blank %}<!-- -->{% assign reploOriginalSPGRdb2 = reploSortedSellingPlans %}<!-- -->{% assign reploSortedSellingPlans = blank %}<!-- -->{% assign reploOriginalSSPRdb2 = reploSelectedSellingPlan %}<!-- -->{% assign reploSelectedSellingPlan = blank %}<!-- -->{% assign reploOriginalSSPPriceRdb2 = reploSelectedSellingPlanPrice %}<!-- -->{% assign reploSelectedSellingPlanPrice = blank %}<!-- -->{% assign reploOriginalComparePricePercentRdb2 = reploCompareAtPriceDifferencePercentage %}<!-- -->{% assign reploCompareAtPriceDifferencePercentage = blank %}<!-- -->{%- comment -%}replo-liquid-chunk-end{%- endcomment -%}<!-- -->{%- comment -%}replo-liquid-chunk-begin{%- endcomment -%}<!-- -->{% capture reploVariantIdString %}null{% endcapture %}<!-- -->{% capture reploSellingPlanIdString %}null{% endcapture %}<!-- -->{% capture reploIdKey %}id{% endcapture %}<!-- -->{% capture reploPercentageKey %}percentage{% endcapture %}<!-- -->{% capture reploPriceKey %}price{% endcapture %}<!-- -->{% capture reploFixedAmountKey %}fixed_amount{% endcapture %}<!-- -->{% capture spKey %}selling_plan{% endcapture %}<!-- -->{%- liquid
              assign reploVariantId = reploVariantIdString | times: 1
              assign reploSelectedVariant = product.variants | where: reploIdKey, reploVariantId | first
              if reploSelectedVariant == blank
                assign reploSelectedVariant = product.selected_or_first_available_variant
              endif
              assign reploSelectedSellingPlanPrice = reploSelectedVariant.price
              if product.selling_plan_groups[0]
                assign reploAllSellingPlans = reploSelectedVariant.selling_plan_allocations | map: spKey
                assign reploSortedSellingPlans = reploAllSellingPlans | sort: reploIdKey
                if true
                  assign reploSellingPlanId = reploSellingPlanIdString | times: 1
                  assign reploSelectedSellingPlan = reploSortedSellingPlans | where: reploIdKey, reploSellingPlanId | first
                  if reploSelectedSellingPlan.price_adjustments[0]
                    assign adjustment = reploSelectedSellingPlan.price_adjustments[0]
                    case adjustment.value_type
                      when reploPercentageKey
                        assign amountOff = 100 | minus: adjustment.value
                        assign reploSelectedSellingPlanPrice = reploSelectedSellingPlanPrice | times: amountOff | divided_by: 100
