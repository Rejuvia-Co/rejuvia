{%- comment -%}
  "View Supplement Facts" button (white pill) that opens the supplement-label popup.
  Requires {% render 'supplement-label-popup', product: <product> %} on the same page.
  Param: product — the product whose custom.supplement_label metaobject drives the popup.
  Renders nothing if that metafield is empty.
{%- endcomment -%}
{%- if product.metafields.custom.supplement_label != blank -%}
  <div class="supplement-label-cta">
    <a class="supplement-label-btn" href="#" data-open-supplement-popup>View Supplement Facts</a>
  </div>
  {%- unless supplement_label_btn_css -%}{%- assign supplement_label_btn_css = true -%}
  <style>
    /* position/z-index keep it clickable above accordion checkbox-hack toggles */
    .supplement-label-cta { display: flex; justify-content: center; margin-top: 16px; position: relative; z-index: 2; }
    .supplement-label-btn {
      display: flex;
      width: 100%;
      box-sizing: border-box;
      align-items: center;
      justify-content: center;
      background: #ffffff;
      color: #5d215f;
      font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-size: 16px;
      font-weight: 500;
      line-height: 1;
      letter-spacing: 0;
      text-transform: none;
      padding: 14px 28px;
      border: 1.5px solid #5d215f;
      border-radius: 100px;
      text-decoration: none;
      cursor: pointer;
      transition: background .15s ease, color .15s ease;
    }
    .supplement-label-btn:hover { background: #5d215f; color: #ffffff; }
    .supplement-label-btn:active { transform: scale(0.98); }
    @media (max-width: 749px) {
      .supplement-label-btn { padding: 13px 24px; font-size: 15px; }
    }
  </style>
  {%- endunless -%}
{%- endif -%}
