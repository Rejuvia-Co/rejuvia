{%- comment -%}
  Trusted-by social-proof bar — render INSIDE a section column (e.g. the
  offer-block / bogo-offer buybox, under the accordion tabs).
  Params: title, subtext, image_1, image_2, image_3, bg_color, check_color
{%- endcomment -%}
<div class="trusted-by" style="--tb-bg: {{ bg_color | default: '#f4f4f4' }}; --tb-check: {{ check_color | default: '#34c759' }};">
  <div class="trusted-by__avatars">
    {%- for i in (1..3) -%}
      {%- case i -%}
        {%- when 1 -%}{%- assign img = image_1 -%}
        {%- when 2 -%}{%- assign img = image_2 -%}
        {%- when 3 -%}{%- assign img = image_3 -%}
      {%- endcase -%}
      {%- if img != blank -%}
        <img class="trusted-by__avatar"
             src="{{ img | image_url: width: 160 }}"
             srcset="{{ img | image_url: width: 128 }} 1x, {{ img | image_url: width: 160 }} 2x"
             width="64" height="64" loading="lazy"
             alt="{{ img.alt | default: 'Happy customer' | escape }}">
      {%- else -%}
        <span class="trusted-by__avatar trusted-by__avatar--ph" aria-hidden="true"></span>
      {%- endif -%}
    {%- endfor -%}
    <span class="trusted-by__check" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5l4.5 4.5L19 7.5"/></svg>
    </span>
  </div>
  <div class="trusted-by__text">
    {%- if title != blank -%}<p class="trusted-by__title">{{ title }}</p>{%- endif -%}
    {%- if subtext != blank -%}<p class="trusted-by__sub">{{ subtext }}</p>{%- endif -%}
  </div>
</div>

{%- unless trusted_by_css -%}{%- assign trusted_by_css = true -%}
<style>
  .trusted-by {
    display: flex;
    align-items: center;
    gap: 20px;
    width: 100%;
    box-sizing: border-box;
    margin-top: 16px;
    padding: 16px 22px;
    background: var(--tb-bg, #f4f4f4);
    border-radius: 24px;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
  }
  .trusted-by__avatars { position: relative; display: flex; flex-shrink: 0; padding-right: 6px; }
  .trusted-by__avatar {
    width: 60px; height: 60px;
    border-radius: 50%;
    border: 3px solid #fff;
    object-fit: cover;
    background: #e3e3e3;
    margin-left: -18px;
    display: block;
  }
  .trusted-by__avatar:first-child { margin-left: 0; }
  .trusted-by__check {
    position: absolute; top: -4px; right: -4px;
    display: flex; align-items: center; justify-content: center;
    width: 26px; height: 26px;
    border-radius: 50%;
    background: var(--tb-check, #34c759);
    border: 3px solid #fff;
    box-sizing: border-box;
  }
  .trusted-by__text { min-width: 0; }
  .trusted-by__title {
    margin: 0 0 4px;
    font-size: 20px; font-weight: 700; line-height: 1.2;
    color: #141414; letter-spacing: -0.2px;
  }
  .trusted-by__sub {
    margin: 0;
    font-size: 16px; font-weight: 400; line-height: 1.35;
    color: #141414;
  }
  @media (max-width: 749px) {
    .trusted-by { gap: 14px; padding: 14px 16px; border-radius: 20px; }
    .trusted-by__avatar { width: 50px; height: 50px; border-width: 2.5px; margin-left: -15px; }
    .trusted-by__check { width: 22px; height: 22px; top: -3px; right: -3px; }
    .trusted-by__check svg { width: 12px; height: 12px; }
    .trusted-by__title { font-size: 17px; }
    .trusted-by__sub { font-size: 14px; }
  }
</style>
{%- endunless -%}
