    "founder_story_MA6p9q": {
      "type": "founder-story",
      "name": "Founder Story",
      "settings": {
        "heading": "Originally Built For My Mom, Now For Everyone",
        "text": "My mom was 55, going through menopause, and she could never freaking sleep. She'd tried everything — melatonin capsules, gummies, sleeping pills, Ambien, teas — nothing ever helped.\n\nSo I spent my entire time at the University of Pennsylvania working with her to create something different. Not another pill. Not another gummy. An oral sleep spray with 13 natural ingredients that absorbs directly under your tongue and skips your digestive system entirely. That's why it works in minutes, not hours.\n\nWe didn't even want it to be a business. We just wanted to solve her sleep so she could get back to being herself — in control of her nights, her energy, her life. But after it worked for her, she realized there were hundreds of thousands of other women just like her, 55, 60 years old, going through the same thing, who needed this too.\n\nSo we built a small family business around it. Five years later, over 300,000 customers use Rejuvia nightly. It started with my mom. She's never slept better, never felt better. And as her son, I've never seen her live a better life — and it all started with fixing her sleep.",
        "founder_name": "RC Williams",
        "founder_title": "Founder of Rejuvia",
        "image": "shopify://shop_images/rejuvia_founders.webp"
      }
    },
    "faq_center_fQVeth": {
      "type": "faq-center",
      "blocks": {
        "faq_tzyTkg": {
          "type": "faq",
          "settings": {
            "question": "What if it doesn't work for me?",
            "answer": "<p>Every order is backed by our 90-Day Money-Back Guarantee. Try Rejuvia risk-free for a full 90 nights — if you're not sleeping better, send it back for a complete refund, no questions asked.</p>"
          }
        },
        "faq_8qDeDY": {
          "type": "faq",
          "settings": {
            "question": "Will I feel groggy in the morning?",
            "answer": "<p>No. Rejuvia uses a low 2mg dose of melatonin — most gummies pack 5-10mg — paired with natural sleep herbs that calm your mind without knocking you out. You get deep, restorative sleep and wake up clear-headed, not hungover.</p>"
          }
        },
        "faq_67qEnG": {
          "type": "faq",
          "settings": {
            "question": "How fast will I feel Rejuvia working?",
            "answer": "<p>Because you spray it under your tongue, it absorbs directly into your bloodstream with no waiting on digestion. Most customers feel calm and drift off within 10-15 minutes, instead of the 60-90 minutes pills can take.</p>"
          }
        },
        "faq_NkjjkQ": {
          "type": "faq",
          "settings": {
            "question": "Is Rejuvia habit-forming?",
            "answer": "<p>No. Rejuvia is drug-free and non-habit-forming. There's no tolerance buildup, no dependency, and no withdrawal — it works with your body's natural sleep cycle instead of overriding it.</p>"
          }
        },
        "faq_AhBwnL": {
          "type": "faq",
          "settings": {
            "question": "What are the ingredients in Rejuvia?",
            "answer": "<p>A blend of 13 natural sleep ingredients including melatonin (just 2mg), 5-HTP, valerian root, passionflower, chamomile, lemon balm, skullcap, magnolia bark, hops, cramp bark, ginkgo biloba, peppermint, and feverfew. Every batch is triple lab-tested for purity — no fillers, no junk.</p>"
          }
        },
        "faq_rxDhbV": {
          "type": "faq",
          "settings": {
            "question": "What flavor is Rejuvia?",
            "answer": "<p>A light, pleasant natural mint taste that 99% of customers genuinely enjoy.</p>"
          }
        },
        "faq_mFex9e": {
          "type": "faq",
          "settings": {
            "question": "Is this a subscription?",
            "answer": "<p>No. Rejuvia is a one-time purchase, not an automatic subscription.</p>"
          }
        },
        "faq_jynxhn": {
          "type": "faq",
          "settings": {
            "question": "How long does one spray last?",
            "answer": "<p>Each Rejuvia spray will last you 30-35 nights depending on your usage. One spray contains ~240 total spritzes and our suggest dosage is 6-8 spritzes per night.</p>"
          }
        }
      },
