    "main_page_n9eJcx": {
      "type": "faqs",
      "blocks": {
        "faqs_44G4Rt": {
          "type": "faqs",
          "settings": {
            "heading": "Why are Rejuvia sprays better than oils & pills?",
            "subheading": "Oral sprays offer greater effectiveness compared to gummy and capsule supplements by enabling direct absorption through the mucous membranes in the mouth, bypassing the digestive system. This results in quicker and more efficient uptake of our sleep botanicals and amino acids, ensuring significantly higher bioavailability."
          }
        },
        "faqs_p7BBLy": {
          "type": "faqs",
          "settings": {
            "heading": "How many sprays do I use?",
            "subheading": "We suggest uses 6-8 spritzes under your tongue each night, though we have customers who have success using only 4 and some using up to 10. It's all about finding the perfect dosage that works for you and the metered oral spray makes it very easy to customize!"
          }
        },
        "faqs_q3Efrz": {
          "type": "faqs",
          "settings": {
            "heading": "How do I use the oral sprays?",
            "subheading": "To use our sprays, simply spritz 6-8 times either under your tongue or on the inside of your cheek, swish around your mouth and swallow. Use our sleep spray 20 minutes before bed and our stress spray throughout the day as needed. For the first usage, you might have to activate the spray by pumping it a few times before the liquid is ready to go."
          }
        },
        "faqs_HDrqWg": {
          "type": "faqs",
          "settings": {
            "heading": "Are Rejuvia's sprays third-party tested?",
            "subheading": "All of our products undergo rigorous independent triple lab testing to guarantee purity and potency. Each product has a Certificate of Analysis that ensures there are no impurities and confirms that what's on the label is exactly what's in the bottle."
          }
        },
        "faqs_drtKGi": {
          "type": "faqs",
          "settings": {
            "heading": "How long do the sleep sprays take to work?",
            "subheading": "Most of our customers notice the positive effects of our sleep spray within the first or second night of use. For some, consistent use over 5-7 days is all it takes to experience significant improvements in their sleep. Since everyone's body responds uniquely, results may vary, but our spray is designed to help you achieve better sleep quickly and effectively."
          }
        },
        "faqs_XNVegN": {
          "type": "faqs",
          "settings": {
            "heading": "What do Rejuvia's sprays taste like?",
            "subheading": "Our oral sprays feature a delicious, all-natural mint flavor that's refreshed and balanced, but not overpowering. Even customers who aren't typically fans of mint flavors enjoy our sprays."
          }
        }
      },
