    "faqs_1": {
      "type": "faqs",
      "blocks": {
        "faq_1": {
          "type": "faqs",
          "settings": {
            "heading": "Why are Rejuvia sprays better than gummies & pills?",
            "subheading": "Oral sprays are more effective than gummy and capsule supplements because they allow for direct absorption of nutrients through the mucous membranes in the mouth, bypassing the digestive system. This leads to quicker and more efficient uptake of vitamins and minerals, ensuring significantly higher bioavailability."
          }
        },
        "faq_2": {
          "type": "faqs",
          "settings": {
            "heading": "How many sprays should I use each night?",
            "subheading": "We suggest uses 6-8 spritzes under your tongue each night, though we have customers who have success using only 4 and some using up to 10. It's all about finding the perfect dosage that works for you and the metered oral spray makes it very easy to customize!"
          }
        },
        "faq_3": {
          "type": "faqs",
          "settings": {
            "heading": "Are Rejuvia's sprays third-party tested?",
            "subheading": "All of our products are indepdently triple lab-tested for purity and potency each batch. Each prodcut comes with a Certificate of Analysis to ensure we are using the finest ingredients and you can access it via a QR code on the packaging. We batch-test and validate with certified third-party labs to ensure purity and consistency."
          }
        },
        "faq_4": {
          "type": "faqs",
          "settings": {
            "heading": "How long do the sleep sprays take to work?",
            "subheading": "The majority of customers notice the benefits of our sleep sprays within the first few nights of using them. Some customers need to consistently use them for 5-7 days before enjoying the full benefits. Everyone's body is different and it might take more or less time depending on how your body responds to them."
          }
        },
        "faq_5": {
          "type": "faqs",
          "settings": {
            "heading": "How long will it take my order to arrive?",
            "subheading": "We do our best to ship out all orders within 24 hours after they are placed from our warehouse in Chicago. You typically can expect your order to get to you within a maximum of 3 business days after you place it."
          }
        },
        "faq_6": {
          "type": "faqs",
          "settings": {
            "heading": "Should I use Rejuvia before or after brushing my teeth?",
            "subheading": "It's up to you. Most of our customers use our sprays about 20 minutes before they head to bed, which usually falls before brushing their teeth. You can feel comfortable using them after you brush your teeth, though."
          }
        },
        "faq_7": {
          "type": "faqs",
          "settings": {
            "heading": "What is Rejuvia's return policy?",
            "subheading": "We offer a 90-day money-back guarantee on your first Rejuvia order, no questions asked. All subsequent orders are not eligible for returns or refunds. Customers are responsible for return shipping costs. To start a return, simply email us at hello@rejuvia.co for easy instructions."
          }
        },
        "faq_8": {
          "type": "faqs",
          "settings": {
            "heading": "How many sprays should I take?",
            "subheading": "Start with 4-6 sprays under your tongue, 30 minutes before bed. Less is more — most customers find their sweet spot here. If you feel groggy the next morning, reduce by 1–2 sprays. If you don't notice an effect after a week, increase gradually. The max is 6–8 sprays, but it's not the starting point."
          }
        }
      },
